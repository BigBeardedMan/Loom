GLYPH_SESSION = "✦"
GLYPH_THINK = "◇"
GLYPH_TOOL = "⟳"
GLYPH_OK = "✓"
GLYPH_ERR = "✗"
GLYPH_PROMPT = "❯"
GLYPH_WARN = "⚠"
GLYPH_SPINNER = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]

TASK_GLYPHS = {
    "pending":     ("○", "task_pending"),
    "in_progress": ("▶", "task_progress"),
    "completed":   ("✓", "task_done"),
    "cancelled":   ("⊘", "task_cancel"),
}


# =============================================================================
# Layout helpers
# =============================================================================

def term_width():
    """Live terminal width. We `ioctl(TIOCGWINSZ)` against stdout directly
    rather than going through `shutil.get_terminal_size()`, because that
    helper prefers the `COLUMNS` env var when set - and SwiftTerm-backed
    terminals (Loom, Warp, iTerm with shell integration) sometimes stamp
    `COLUMNS` once at PTY launch and never update it on resize. The ioctl
    asks the kernel, which always has the truth."""
    fd = None
    try:
        fd = sys.stdout.fileno()
    except (OSError, ValueError):
        pass
    if fd is not None:
        try:
            data = fcntl.ioctl(fd, termios.TIOCGWINSZ, b"\x00" * 8)
            _, cols, _, _ = struct.unpack("hhhh", data)
            if cols > 0:
                return cols
        except (OSError, ValueError):
            pass
    return shutil.get_terminal_size((80, 24)).columns


def box_width():
    """Box width that always fits in the current terminal. Capped at 76 so
    we leave headroom for terminals that lie slightly about their width
    and for any wide-glyph rendering surprises. Recomputed on every draw
    so resize between turns lands correctly on the next prompt."""
    return max(40, min(term_width() - 4, 76))


def _visible_len(s):
    """Length of s minus any ANSI escape sequences. Used for padding rows
    that mix styled and unstyled fragments."""
    return len(re.sub(r"\033\[[0-9;]*m", "", s))


# =============================================================================
# Banner / tips / boxed prompt
# =============================================================================

TIPS = [
    "↑ / ↓ walk through previous prompts · Ctrl-R reverse-search history",
    "Shift+Tab cycles modes: default → PLAN → ACCEPT EDITS → BYPASS PERMISSIONS",
    "Esc during a running turn stops it · Ctrl-D or /quit to exit",
    "type @path/to/file to inline a file's contents (Tab completes)",
    "slash commands: /help, /clear, /model, /bash, /cwd, /save, /resume, /cost",
    "word wrap on by default · /wrap off (or --no-wrap) for terminal hard wrap",
    "--allow-bash enables run_bash and auto-approves it · --yolo skips every prompt",
    "orchestrator auto-continues until tasks are done (max 12) · /auto off to disable",
    "task list flows into Loom's Tasks pane via ~/.loom/tasks/",
    "themes: --theme default | mono | cyberpunk | solarized",
    "non-interactive: --json streams structured events for scripting",
]


def draw_banner(model, workspace, allow_bash, session_id, theme_name,
                context_files, tree_count=0, grammar_supported=False,
                adapter=None):
    width = box_width()
    bar = "─" * (width - 2)
    side = style("│", "border")
    print(style("╭" + bar + "╮", "border"))

    headline_inner = (
        f" {style(GLYPH_SESSION, 'border')} "
        f"{style('lmstudio', 'headline')}  "
        f"{style('local LM Studio agent', 'dim')}"
    )
    headline_visible = _visible_len(headline_inner)
    pad = max(0, width - 2 - headline_visible)
    print(f"{side}{headline_inner}{' ' * pad}{side}")
    print(f"{side}{' ' * (width - 2)}{side}")

    def row(label, value, value_key="value"):
        # Inner content: " <label-10> <value>". Outer side bars consume
        # 2 of the `width` columns; the inner area is (width - 2) cols.
        padded_label = label.ljust(10)
        styled_label = style(padded_label, "key")
        styled_value = style(value, value_key) if value_key else value
        inner = f" {styled_label}{styled_value}"
        pad = max(0, width - 2 - _visible_len(inner))
        return f"{side}{inner}{' ' * pad}{side}"

    print(row("workspace", str(workspace)))
    print(row("model", model, "value"))
    if adapter is not None:
        tools_mode = "native" if adapter.native_tools else "text-mode"
        print(row("family", f"{adapter.family} ({tools_mode} tools)",
                  "ok" if adapter.native_tools else "warning"))
    print(row("bash", "on" if allow_bash else "off",
              "ok" if allow_bash else "task_pending"))
    print(row("grammar", "on (json_schema)" if grammar_supported else "off",
              "ok" if grammar_supported else "dim"))
    print(row("theme", theme_name, "value"))
    if context_files:
        print(row("context", ", ".join(context_files), "dim"))
    if tree_count:
        print(row("tree", f"{tree_count} entries", "dim"))
    print(row("session", session_id, "dim"))
    print(style("╰" + bar + "╯", "border"))


def draw_banner_extra(state):
    """Surface the new 4.0.0+ features when they're active. Called right
    after `draw_banner`; silent when nothing's interesting to report."""
    width = box_width()
    rows = []
    if state.persona_source:
        rows.append(("persona", state.persona_source, "ok"))
    if state.project_knowledge_text:
        rows.append(("knowledge", "project.json loaded", "ok"))
    if state.preview:
        rows.append(("preview", state.preview["url"], "ok"))
    if state.auto_test:
        runner = detect_test_runner(state.workspace)
        rows.append(("auto-test", "on (" + (runner["name"] if runner else "no runner") + ")", "ok"))
    if state.auto_screenshot:
        rows.append(("auto-shot", "on", "ok"))
    if state.auto_commit:
        rows.append(("autocommit", "on", "ok"))
    if state.aggressive_batching:
        rows.append(("batch", "on (aggressive)", "ok"))
    if state.lsp:
        rows.append(("lsp", "running", "ok"))
    if state.planner_model or state.coder_model or state.explainer_model:
        parts = []
        if state.planner_model: parts.append(f"plan={state.planner_model}")
        if state.coder_model: parts.append(f"code={state.coder_model}")
        if state.explainer_model: parts.append(f"explain={state.explainer_model}")
        rows.append(("router", " ".join(parts), "value"))
    if state.constitution_rules:
        rows.append(("constitution",
                     f"{len(state.constitution_rules)} rules active", "ok"))
    if state.watcher_thread:
        rows.append(("watcher",
                     f"on ({len(state.watched_files)} files)", "ok"))
    if state.self_reflect:
        rows.append(("reflect", "on", "ok"))
    if state.plugin_names:
        rows.append(("plugins", f"{len(state.plugin_names)} loaded", "ok"))
    if state.drift_warnings:
        rows.append(("drift",
                     f"{len(state.drift_warnings)} stale entries", "warning"))
    if state.hooks:
        hook_count = sum(len(v) for v in state.hooks.values())
        rows.append(("hooks", f"{hook_count} script(s) loaded", "ok"))
    if state.settings:
        rows.append(("settings", "loaded", "ok"))
    if state.active_skills:
        names = ", ".join(s["name"] for s in state.active_skills)
        rows.append(("skills", names, "ok"))
    if state.user_memory_text:
        rows.append(("memory", "user MEMORY.md loaded", "ok"))
    if state.slash_command_files:
        rows.append(("commands",
                     f"{len(state.slash_command_files)} slash command files",
                     "ok"))
    if state.bg_shells:
        rows.append(("shells", f"{len(state.bg_shells)} background", "ok"))
    if not rows:
        return
    bar = "─" * (width - 2)
    side = style("│", "border")
    print(style("╭" + bar + "╮", "border"))
    for label, value, role in rows:
        padded = label.ljust(10)
        inner = f" {style(padded, 'key')}{style(value, role)}"
        pad = max(0, width - 2 - _visible_len(inner))
        print(f"{side}{inner}{' ' * pad}{side}")
    print(style("╰" + bar + "╯", "border"))


def draw_tips():
    print()
    print(style(" Tips", "tip"))
    for tip in TIPS:
        bullet = style("•", "tip")
        print(f"   {bullet} {style(tip, 'dim')}")
    print()


def draw_task_list(tasks):
    if not tasks:
        return
    width = box_width()
    title = f" Tasks ({len(tasks)}) "
    bar = "─" * max(0, width - 2 - len(title))
    print(style(f"┌─{title}{bar}┐", "border"))
    for i, t in enumerate(tasks, 1):
        glyph, role = TASK_GLYPHS.get(t["status"], TASK_GLYPHS["pending"])
        active = t.get("activeForm") or t["subject"]
        text = active if t["status"] == "in_progress" else t["subject"]
        max_text = width - 10
        if len(text) > max_text:
            text = text[: max_text - 1] + "…"
        index = style(f"{i:>2}", "dim")
        marker = style(glyph, role)
        body_text = (style(text, "dim") if t["status"] == "completed"
                     else (style(text, "key") if t["status"] == "in_progress"
                           else text))
        line = f"│ {index} {marker} {body_text}"
        pad = max(0, width - 1 - _visible_len(line))
        print(line + " " * pad + style("│", "border"))
    print(style("└" + "─" * (width - 2) + "┘", "border"))


def draw_diff(path, old, new):
    """Inline unified diff for a single file change. Capped at 12 visible
    diff lines plus a "… N more" footer when longer."""
    if old == new:
        return
    diff = list(difflib.unified_diff(
        old.splitlines(), new.splitlines(),
        fromfile=str(path), tofile=str(path),
        lineterm="", n=2,
    ))
    body = [line for line in diff if line.startswith(("+", "-", " "))
            and not line.startswith(("+++", "---"))]
    if not body:
        return
    cap = 12
    shown = body[:cap]
    remaining = len(body) - cap
    for line in shown:
        if line.startswith("+"):
            print("    " + style(line, "diff_add"))
        elif line.startswith("-"):
            print("    " + style(line, "diff_del"))
        else:
            print("    " + style(line, "dim"))
    if remaining > 0:
        print("    " + style(f"… {remaining} more line{'s' if remaining != 1 else ''}",
                              "dim"))


def draw_prompt_box():
    width = box_width()
    bar = "─" * (width - 2)
    top = style("╭" + bar + "╮", "border")
    bottom = style("╰" + bar + "╯", "border")
    lead = style("│ ", "border") + style(GLYPH_PROMPT + " ", "prompt")
    return top, lead, bottom


def close_prompt_box(user_input):
    """Redraw a typed line with a right border for one-shot/non-TTY callers
    that didn't go through the interactive editor."""
    width = box_width()
    available = width - 5
    visible_input = re.sub(r"\033\[[0-9;]*m", "", user_input)
    if len(visible_input) > available:
        return
    if not sys.stdout.isatty():
        return
    pad = available - len(visible_input)
    line = (style("│ ", "border")
            + style(GLYPH_PROMPT + " ", "prompt")
            + user_input
            + " " * pad
            + style("│", "border"))
    sys.stdout.write("\033[A\r\033[2K" + line + "\n")
    sys.stdout.flush()


# =============================================================================
# Boxed line editor (raw-mode replacement for input() inside the prompt box)
# =============================================================================

class BoxedLineEditor:
    """Reads one line of input inside a closed box that wraps to multiple
    rows as the user types. Implements enough readline-style chords to
    feel native: printable chars, backspace, ←/→ cursor, ↑/↓ history,
    Home/End, Ctrl-A/E, Ctrl-K, Ctrl-U, Ctrl-W, Ctrl-L, Ctrl-D, Ctrl-C.

    Esc clears the current edit in place (matches Claude Code) rather
    than exiting - the previous behavior raised through the REPL loop,
    which redrew a new empty box and left a trail of them on screen.

    The box grows vertically: text wraps at word boundaries when possible
    (falls back to hard wrap for long unbroken tokens), and continuation
    rows are indented under the `❯` prefix so the input reads as one
    logical line. Each redraw clears the previous box height with
    `ESC[J` and rewrites from the top so a shrink (after delete/kill)
    can't leave stale rows behind."""

    HISTORY_FILE = HISTORY_FILE
    HISTORY_LIMIT = 1000

    LEAD_VISIBLE = 4   # "│ ❯ " on first row
    CONT_VISIBLE = 4   # "│   " on continuation rows (aligned under text)

    def __init__(self, history, state=None):
        self.history = list(history)
        self.history.append("")
        self.hist_idx = len(self.history) - 1
        self.line = ""
        self.col = 0
        self._drawn_height = 0   # screen rows the box currently occupies
        # Relative cursor position inside the box, 0-indexed from the top
        # border. 0 = top, 1..N = input rows, N+1 = bottom. The wipe step
        # of the next render uses this to move back to the top of the box
        # before clearing - moving up by self._drawn_height instead would
        # land *above* the box and march it up the screen on every redraw.
        self._cursor_box_row = 0
        self._frozen_width = box_width()  # locked for the editor's lifetime
        # 8.0.10: weak reference to AgentState for the Shift+Tab mode
        # cycle. Optional - editor still works for tools that build a
        # bare editor outside the agent loop.
        self.state = state

    @property
    def _inner_width(self):
        return max(8, self._frozen_width - 5)

    def read(self):
        if not sys.stdin.isatty() or not sys.stdout.isatty():
            return input(style("│ ", "border")
                         + style(GLYPH_PROMPT + " ", "prompt"))
        self._frozen_width = box_width()  # snapshot at session start
        fd = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        try:
            new = list(old)
            new[3] = new[3] & ~(termios.ICANON | termios.ECHO | termios.ISIG)
            # 8.0.3: VMIN/VTIME are required when ICANON is off; the prior
            # manual setup forgot these, so sys.stdin.read(1) had
            # undefined blocking behavior on some terminals (could return
            # "" immediately, losing the byte after Esc and breaking
            # arrow-key handling). 1/0 = block until exactly 1 byte.
            new[6][termios.VMIN] = 1
            new[6][termios.VTIME] = 0
            termios.tcsetattr(fd, termios.TCSANOW, new)
            # Enable bracketed paste so the terminal wraps pasted text in
            # ESC[200~ ... ESC[201~. Without this, pasted newlines look
            # identical to Enter and we submit on the first \n in the
            # paste buffer, firing each pasted line as its own prompt.
            #
            # 8.0.15: also explicitly disable every mouse-tracking mode
            # the terminal might have on from a prior program (vim,
            # tmux, etc.). When mouse tracking is active, a single
            # click in the input box generates ESC[<0;42;15M which our
            # editor would otherwise leak as printable characters.
            # ?1000 = X10 mouse, ?1002 = button-event, ?1003 = any-event,
            # ?1006 = SGR encoding, ?1015 = urxvt encoding.
            sys.stdout.write(
                "\033[?2004h"
                "\033[?1000l\033[?1002l\033[?1003l"
                "\033[?1006l\033[?1015l"
            )
            sys.stdout.flush()
            try:
                self._render()
                return self._loop()
            finally:
                sys.stdout.write("\033[?2004l")
                sys.stdout.flush()
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)

    # --- wrap + cursor mapping -----------------------------------------

    def _wrap(self):
        """Wrap self.line into a list of visual rows, preferring word
        boundaries but falling back to hard wrap when a word is wider
        than the inner area. Embedded newlines (from paste) force a row
        break. Returns (rows, row_start_offsets) where row_start_offsets[i]
        is the linear index in self.line where row i begins."""
        width = self._inner_width
        text = self.line
        if not text:
            return [""], [0]
        rows = []
        offsets = []
        # Split on explicit \n first; each segment is wrapped independently
        # at the visual width.
        segments = text.split("\n")
        pos = 0
        for seg in segments:
            seg_start = pos
            if not seg:
                rows.append("")
                offsets.append(seg_start)
            else:
                i = 0
                while i < len(seg):
                    offsets.append(seg_start + i)
                    end = min(i + width, len(seg))
                    if end >= len(seg):
                        rows.append(seg[i:end])
                        break
                    chunk = seg[i:end]
                    space = chunk.rfind(" ")
                    if space > 0:
                        rows.append(seg[i:i + space])
                        i = i + space + 1
                    else:
                        rows.append(chunk)
                        i = end
            pos += len(seg) + 1  # +1 for the \n separator (extra at end is harmless)
        if not rows:
            rows = [""]
            offsets = [0]
        return rows, offsets

    def _cursor_rc(self, rows, offsets):
        """Map self.col (linear) to (row_index, col_within_row). When the
        cursor sits at the very end of a row that ends with a consumed
        space, it logically belongs on the start of the next row."""
        if not rows:
            return (0, 0)
        for r in range(len(rows) - 1, -1, -1):
            start = offsets[r]
            if self.col >= start:
                col_in_row = self.col - start
                row_len = len(rows[r])
                # If we're sitting on a consumed space at the boundary, the
                # cursor visually lives at the start of the next row.
                if col_in_row > row_len and r + 1 < len(rows):
                    return (r + 1, 0)
                return (r, min(col_in_row, row_len))
        return (0, 0)

    # --- drawing --------------------------------------------------------

    def _render(self):
        """Full redraw. Wipe the previously drawn box (cursor is inside it
        at self._cursor_box_row), then render top + content rows + bottom
        and reposition the cursor for the new content.

        The wipe step must move up by `self._cursor_box_row` lines, NOT by
        the full box height - the cursor lives *inside* the box between
        renders, not below it. Using the box height here (the pre-fix bug)
        moved the cursor above the box and clear-to-end-of-screen wiped
        whatever was already there, marching the box up the viewport one
        keystroke at a time."""
        width = self._frozen_width
        inner = self._inner_width
        bar = "─" * (width - 2)
        top = style("╭" + bar + "╮", "border")
        # 8.0.10: when a non-default mode is active, render its pill in
        # the top border. Format: ╭── [MODE] ──...──╮. Skips silently
        # for default mode so the editor looks normal in the common case.
        if self.state is not None and self.state.mode_index != 0:
            mode = self.state.mode
            pill = f" [{mode['label']}] "
            pill_visible = len(pill)
            if pill_visible + 4 < width:
                # 2 dashes on the left, then pill (styled), then dashes to
                # fill out the rest of the bar. Total visible matches `bar`.
                left_dashes = "─" * 2
                right_dashes = "─" * (width - 2 - 2 - pill_visible)
                styled_pill = style(pill, mode["color"])
                top = (style("╭" + left_dashes, "border")
                       + styled_pill
                       + style(right_dashes + "╮", "border"))
        bot = style("╰" + bar + "╯", "border")
        right = style("│", "border")

        if self._drawn_height > 0:
            sys.stdout.write("\r")
            if self._cursor_box_row > 0:
                sys.stdout.write("\033[" + str(self._cursor_box_row) + "A")
            sys.stdout.write("\033[J")
        else:
            sys.stdout.write("\r")

        rows, offsets = self._wrap()
        height = len(rows) + 2  # top + N input rows + bottom

        sys.stdout.write(top + "\n")
        for i, row_text in enumerate(rows):
            if i == 0:
                lead = (style("│ ", "border")
                        + style(GLYPH_PROMPT + " ", "prompt"))
            else:
                lead = style("│   ", "border")
            pad = max(0, inner - len(row_text))
            sys.stdout.write(lead + row_text + " " * pad + right + "\n")
        sys.stdout.write(bot + "\n")

        self._drawn_height = height

        row, col = self._cursor_rc(rows, offsets)
        target = row + 1  # 0=top, 1..N=input rows, N+1=bot
        up = height - target  # cursor is on the line below bot (offset `height`)
        if up > 0:
            sys.stdout.write("\033[" + str(up) + "A")
        sys.stdout.write("\r")
        forward = self.LEAD_VISIBLE + col
        if forward > 0:
            sys.stdout.write("\033[" + str(forward) + "C")
        sys.stdout.flush()
        self._cursor_box_row = target

    def _leave_box(self):
        """Move the cursor below the bottom border so further output starts
        on a fresh line."""
        down = self._drawn_height - self._cursor_box_row
        if down > 0:
            sys.stdout.write("\033[" + str(down) + "B")
        sys.stdout.write("\r")
        sys.stdout.flush()
        self._drawn_height = 0
        self._cursor_box_row = 0

    # --- main loop ------------------------------------------------------

    def _loop(self):
        while True:
            ch = sys.stdin.read(1)
            if not ch:
                continue
            o = ord(ch)

            if o in (0x0d, 0x0a):  # Enter
                self._leave_box()
                return self.line

            if o == 0x03:  # Ctrl-C
                self._leave_box()
                raise KeyboardInterrupt

            if o == 0x04:  # Ctrl-D
                if not self.line:
                    self._leave_box()
                    raise EOFError
                if self.col < len(self.line):
                    self.line = self.line[:self.col] + self.line[self.col + 1:]
                    self._render()
                continue

            if o == 0x1b:  # Esc or start of CSI / SS3 sequence
                # 8.0.3: bumped from 40ms -> 120ms. Slower terminals (SSH,
                # tmux, certain GPU-accelerated emulators) can split the
                # `\x1b` from the trailing `[A` by more than 40ms, which
                # caused arrow keys to be misread as a plain Esc, wiping
                # the user's in-progress line and silently swallowing the
                # arrow. Also: handle SS3 prefix `\x1bOA` for terminals in
                # application-cursor-key mode (some `screen`, tmux setups,
                # and a few older xterm builds).
                nxt = self._read_with_timeout(0.12)
                if nxt is None:
                    # Plain Esc: clear the current edit in place. The previous
                    # behavior (raise to the REPL loop) drew a fresh empty
                    # box on top of the existing one, leaving a stack.
                    if self.line:
                        self.line = ""
                        self.col = 0
                        self._render()
                    continue
                if nxt in ("[", "O"):
                    seq = self._read_with_timeout(0.12)
                    if not seq:
                        # 8.0.4: incomplete escape sequence (Esc[ or EscO
                        # with no trailing byte). Almost always terminal
                        # latency splitting the arrow-key bytes; the user
                        # did not intend to clear their input. Drop the
                        # partial sequence and continue without touching
                        # self.line. The prior behavior wiped the line
                        # whenever a single CSI byte arrived just past the
                        # 120ms window.
                        continue
                    # 8.0.15: single-byte CSI commands we actually handle
                    # (arrow keys, Home/End, Shift+Tab). Anything else is
                    # a multi-byte sequence that must be drained to its
                    # terminator, otherwise the trailing bytes leak as
                    # printable input.
                    #
                    # The canonical offender is SGR mouse: clicking in
                    # the box emits `\x1b[<0;42;15M`, where `<` is the
                    # CSI parameter prefix. Pre-8.0.15 the handler hit
                    # `_handle_csi("<")` (a no-op), then read each of
                    # `0;42;15M` as a separate character and inserted
                    # them into self.line.
                    SINGLE_BYTE_CSI = "ABCDHFZ"
                    if nxt == "[" and seq not in SINGLE_BYTE_CSI:
                        # Multi-byte CSI. Drain until terminator: any
                        # alpha (A-Z, a-z) or `~`. Common patterns:
                        #   ESC[200~              bracketed paste start
                        #   ESC[201~              bracketed paste end
                        #   ESC[5~                Page Up
                        #   ESC[1;5A              Ctrl-Up
                        #   ESC[<0;42;15M         SGR mouse press
                        #   ESC[<0;42;15m         SGR mouse release
                        #   ESC[?2004h            bracketed paste enable
                        tail = seq
                        while True:
                            ch2 = self._read_with_timeout(0.12)
                            if ch2 is None:
                                break
                            tail += ch2
                            if ch2 == "~" or ch2.isalpha():
                                break
                        if tail == "200~":
                            self._handle_paste()
                        elif tail.endswith("A"):
                            self._history_step(-1)
                        elif tail.endswith("B"):
                            self._history_step(+1)
                        # Mouse events (terminator M or m), DEC private
                        # mode responses, function keys, etc. are
                        # silently consumed without modifying the line.
                    else:
                        self._handle_csi(seq)
                continue

            if o == 0x7f or o == 0x08:  # Backspace
                if self.col > 0:
                    self.line = self.line[:self.col - 1] + self.line[self.col:]
                    self.col -= 1
                    self._render()
                continue

            if o == 0x01:  # Ctrl-A
                self.col = 0
                self._render()
                continue
            if o == 0x05:  # Ctrl-E
                self.col = len(self.line)
                self._render()
                continue
            if o == 0x0b:  # Ctrl-K
                self.line = self.line[:self.col]
                self._render()
                continue
            if o == 0x15:  # Ctrl-U
                self.line = self.line[self.col:]
                self.col = 0
                self._render()
                continue
            if o == 0x17:  # Ctrl-W
                i = self.col
                while i > 0 and self.line[i - 1] == " ":
                    i -= 1
                while i > 0 and self.line[i - 1] != " ":
                    i -= 1
                self.line = self.line[:i] + self.line[self.col:]
                self.col = i
                self._render()
                continue
            if o == 0x0c:  # Ctrl-L (full redraw)
                self._render()
                continue

            if o >= 32:  # printable
                extra = 0
                if o >= 0xf0:
                    extra = 3
                elif o >= 0xe0:
                    extra = 2
                elif o >= 0xc0:
                    extra = 1
                if extra:
                    ch += sys.stdin.read(extra)
                self.line = self.line[:self.col] + ch + self.line[self.col:]
                self.col += 1
                self._render()
                continue

    def _handle_paste(self):
        """Consume stdin up to the bracketed-paste end marker (ESC[201~)
        and insert the pasted text at the cursor. Newlines are preserved
        as literal `\\n` in self.line; the wrap function treats them as
        forced row breaks. CR is normalized to LF so terminals that send
        \\r line endings don't double-space."""
        chunks = []
        while True:
            ch = sys.stdin.read(1)
            if not ch:
                break
            if ch == "\x1b":
                # Peek for the paste-end marker. If it isn't one, write
                # the bytes through literally.
                n1 = sys.stdin.read(1)
                if n1 == "[":
                    tail = ""
                    while True:
                        nb = sys.stdin.read(1)
                        if not nb:
                            break
                        tail += nb
                        if nb == "~" or nb.isalpha():
                            break
                    if tail == "201~":
                        break  # end of paste
                    chunks.append("\x1b[" + tail)
                else:
                    chunks.append("\x1b" + (n1 or ""))
                continue
            if ch == "\r":
                chunks.append("\n")
                continue
            chunks.append(ch)
        text = "".join(chunks)
        if not text:
            return
        self.line = self.line[:self.col] + text + self.line[self.col:]
        self.col += len(text)
        self._render()

    def _handle_csi(self, seq):
        if seq == "A":
            self._history_step(-1)
        elif seq == "B":
            self._history_step(+1)
        elif seq == "C":
            if self.col < len(self.line):
                self.col += 1
                self._render()
        elif seq == "D":
            if self.col > 0:
                self.col -= 1
                self._render()
        elif seq == "H":
            self.col = 0
            self._render()
        elif seq == "F":
            self.col = len(self.line)
            self._render()
        elif seq == "Z":
            # 8.0.10: Shift+Tab cycles the mode (default -> plan ->
            # auto-accept -> default). Redraw picks up the new pill.
            if self.state is not None:
                self.state.cycle_mode()
                self._render()

    def _history_step(self, delta):
        target = self.hist_idx + delta
        if not (0 <= target < len(self.history)):
            return
        self.history[self.hist_idx] = self.line
        self.hist_idx = target
        self.line = self.history[self.hist_idx]
        self.col = len(self.line)
        self._render()

    @staticmethod
    def _read_with_timeout(t):
        ready, _, _ = select.select([sys.stdin], [], [], t)
        if ready:
            try:
                return sys.stdin.read(1)
            except (OSError, ValueError):
                return None
        return None

    @classmethod
    def load_history(cls):
        try:
            return cls.HISTORY_FILE.read_text(encoding="utf-8").splitlines()[-cls.HISTORY_LIMIT:]
        except (FileNotFoundError, OSError):
            return []

    @classmethod
    def append_history(cls, line):
        if not line.strip():
            return
        try:
            cls.HISTORY_FILE.parent.mkdir(parents=True, exist_ok=True)
            with cls.HISTORY_FILE.open("a", encoding="utf-8") as f:
                f.write(line + "\n")
        except OSError:
            pass


def draw_status_footer(state):
    """One-line status drawn above the prompt box. Approximate token count
    (4 chars ≈ 1 token), wall-clock elapsed, model id, cwd, bash flag.
    When LM Studio told us the model's context window we show usage as
    "<used>/<max> (NN%)" so you can see how close you are to the cap,
    Claude-Code style."""
    elapsed = int(time.time() - state.started_at)
    if elapsed < 60:
        elapsed_s = f"{elapsed}s"
    elif elapsed < 3600:
        elapsed_s = f"{elapsed // 60}m{elapsed % 60:02d}s"
    else:
        elapsed_s = f"{elapsed // 3600}h{(elapsed % 3600) // 60:02d}m"
    cwd_s = _shorten_path(state.workspace)
    if state.context_window:
        pct = min(100, int(state.approx_tokens * 100 / state.context_window))
        tokens_s = f"{state.approx_tokens:,}/{state.context_window:,} tok ({pct}%)"
    else:
        tokens_s = f"{state.approx_tokens:,} tok"
    bash_s = "bash on" if state.allow_bash else "bash off"
    parts = [state.model, cwd_s, tokens_s, elapsed_s, bash_s]
    if state.context_files:
        parts.insert(2, f"ctx: {len(state.context_files)} files")
    line = " " + style(" · ".join(parts), "footer")
    print(line)


def _shorten_path(p):
    p = str(p)
    home = str(Path.home())
    if p.startswith(home):
        p = "~" + p[len(home):]
    if len(p) > 40:
        parts = p.split("/")
        if len(parts) > 4:
            p = "/".join(parts[:2]) + "/…/" + "/".join(parts[-2:])
    return p


# =============================================================================
# Esc-to-interrupt
# =============================================================================

class EscInterrupt(Exception):
    """Raised when the user hits Esc during a running turn."""


class EscWatcher:
    """Puts stdin into cbreak for the lifetime of a `with` block so Esc
    can be polled non-blockingly between SSE chunks. Stays a no-op when
    stdin isn't a TTY so the script is still scriptable."""

    def __init__(self):
        self.enabled = sys.stdin.isatty()
        self.fd = None
        self.old = None

    def __enter__(self):
        if not self.enabled:
            return self
        try:
            self.fd = sys.stdin.fileno()
            self.old = termios.tcgetattr(self.fd)
            new = list(self.old)
            new[3] = new[3] & ~(termios.ICANON | termios.ECHO)
            termios.tcsetattr(self.fd, termios.TCSANOW, new)
        except (termios.error, OSError):
            self.enabled = False
            self.old = None
        return self

    def __exit__(self, *args):
        if self.old is None:
            return
        try:
            termios.tcsetattr(self.fd, termios.TCSADRAIN, self.old)
            termios.tcflush(self.fd, termios.TCIFLUSH)
        except (termios.error, OSError):
            pass

    def check(self):
        if not self.enabled:
            return False
        saw_esc = False
        try:
            while True:
                ready, _, _ = select.select([self.fd], [], [], 0)
                if not ready:
                    break
                try:
                    ch = os.read(self.fd, 64)
                except (OSError, BlockingIOError):
                    break
                if not ch:
                    break
                if b"\x1b" in ch:
                    saw_esc = True
        except (OSError, ValueError):
            return saw_esc
        return saw_esc


# =============================================================================
# Spinner
# =============================================================================

class Spinner:
    """Background thread that animates a Braille spinner with a status
    label until `stop()` is called or the first content delta arrives.
    Renders inline above the assistant's narration."""

    def __init__(self, label="thinking"):
        self.label = label
        self._stop = threading.Event()
        self._thread = None
        self._cleared = threading.Event()

    def __enter__(self):
        if not sys.stdout.isatty():
            return self
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()
        return self

    def __exit__(self, *args):
        self.stop()

    def _run(self):
        idx = 0
        sys.stdout.write("  ")
        while not self._stop.is_set():
            glyph = GLYPH_SPINNER[idx % len(GLYPH_SPINNER)]
            sys.stdout.write("\r  " + style(glyph, "tool")
                             + " " + style(self.label + "…", "dim"))
            sys.stdout.flush()
            idx += 1
            if self._stop.wait(0.08):
                break
        # Clear the spinner line so the streamed content starts clean.
        sys.stdout.write("\r" + " " * 40 + "\r")
        sys.stdout.flush()
        self._cleared.set()

    def stop(self):
        if not self._thread:
            return
        self._stop.set()
        self._cleared.wait(timeout=0.3)
        self._thread = None


# =============================================================================
# Permission prompts
# =============================================================================

DANGEROUS_TOOLS = {"run_bash", "write_file", "edit_file", "multi_edit"}


class PermissionManager:
    """Asks the user before letting the agent run dangerous tools. Per-
    session allowlist; persisted only in memory. `--yolo` (or
    LMSTUDIO_YOLO=1, or `/yolo on`) disables prompts entirely."""

    def __init__(self, yolo=False):
        self.yolo = yolo
        self.allowed_forever = set()

    def gate(self, tool_name, args):
        if self.yolo:
            return True
        if tool_name not in DANGEROUS_TOOLS:
            return True
        if tool_name in self.allowed_forever:
            return True
        # Render a one-line preview of what's about to happen.
        summary = self._summarize(tool_name, args)
        print()
        print(f"  {style(GLYPH_WARN, 'warning')} {style('Allow', 'warning')} "
              f"{style(tool_name, 'key')} {summary}?")
        print(f"  {style('[y] yes once   [n] no   [a] yes (always this session)', 'dim')}")
        try:
            answer = input(style("  → ", "prompt")).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return False
        if answer == "a":
            self.allowed_forever.add(tool_name)
            return True
        if answer == "y":
            return True
        return False

    @staticmethod
    def _summarize(tool, args):
        if tool == "run_bash":
            cmd = args.get("command", "")
            return style(cmd[:80] + ("…" if len(cmd) > 80 else ""), "value")
        if tool in ("write_file", "edit_file"):
            return style(args.get("path", "?"), "value")
        return ""


# =============================================================================
# Filesystem mutation journal + syntax check
# =============================================================================

def record_journal(state, action, rel_path, prior, new):
    """Append an entry to the in-memory journal and the on-disk JSONL so
    /undo can roll back and a crashed CLI can recover. Silent on error so
    a journaling failure never blocks a successful write."""
    entry = {
        "action": action,
        "path": rel_path,
        "prior": prior,
        "new": new,
        "ts": _now_iso(),
    }
    state.journal.append(entry)
    try:
        JOURNAL_ROOT.mkdir(parents=True, exist_ok=True)
        with open(JOURNAL_ROOT / f"{state.session_id}.jsonl", "a",
                  encoding="utf-8") as f:
            f.write(json.dumps(entry) + "\n")
    except OSError:
        pass


_SYNTAX_VALIDATORS = {}  # populated below after stdlib imports


def _validate_python(text):
    try:
        import ast
        ast.parse(text)
    except SyntaxError as e:
        return f"SyntaxError at line {e.lineno}: {e.msg}"
    return None


def _validate_json(text):
    try:
        json.loads(text)
    except json.JSONDecodeError as e:
        return f"JSON parse error at line {e.lineno} col {e.colno}: {e.msg}"
    return None


def _validate_html(text):
    try:
        from html.parser import HTMLParser
        HTMLParser().feed(text)
    except Exception as e:
        return f"HTML parse error: {e}"
    return None


def _validate_yaml(text):
    try:
        import yaml  # type: ignore
    except ImportError:
        return None
    try:
        yaml.safe_load(text)
    except Exception as e:
        return f"YAML parse error: {e}"
    return None


def _brace_balance(text, lang):
    pairs = {"{": "}", "[": "]", "(": ")"}
    stack = []
    in_str = None
    i = 0
    while i < len(text):
        ch = text[i]
        if in_str:
            if ch == "\\":
                i += 2
                continue
            if ch == in_str:
                in_str = None
            i += 1
            continue
        if ch in ("'", '"', "`"):
            in_str = ch
            i += 1
            continue
        if ch == "/" and i + 1 < len(text) and text[i+1] == "/":
            end = text.find("\n", i)
            i = len(text) if end == -1 else end
            continue
        if ch == "/" and i + 1 < len(text) and text[i+1] == "*":
            end = text.find("*/", i)
            i = len(text) if end == -1 else end + 2
            continue
        if ch in pairs:
            stack.append(ch)
        elif ch in pairs.values():
            if not stack or pairs[stack[-1]] != ch:
                return f"{lang}: unbalanced `{ch}` at offset {i}"
            stack.pop()
        i += 1
    if stack:
        return f"{lang}: unclosed `{stack[-1]}` (line ~{text[:].count(chr(10), 0)})"
    return None


_SYNTAX_VALIDATORS = {
    ".py": _validate_python,
    ".json": _validate_json,
    ".html": _validate_html,
    ".htm": _validate_html,
    ".yml": _validate_yaml,
    ".yaml": _validate_yaml,
    ".js": lambda t: _brace_balance(t, "javascript"),
    ".mjs": lambda t: _brace_balance(t, "javascript"),
    ".ts": lambda t: _brace_balance(t, "typescript"),
    ".tsx": lambda t: _brace_balance(t, "typescript"),
    ".jsx": lambda t: _brace_balance(t, "javascript"),
    ".css": lambda t: _brace_balance(t, "css"),
    ".scss": lambda t: _brace_balance(t, "css"),
    ".swift": lambda t: _brace_balance(t, "swift"),
    ".rs": lambda t: _brace_balance(t, "rust"),
    ".go": lambda t: _brace_balance(t, "go"),
    ".c": lambda t: _brace_balance(t, "c"),
    ".cpp": lambda t: _brace_balance(t, "c++"),
    ".java": lambda t: _brace_balance(t, "java"),
}


def check_syntax(rel_path, content):
    """If the file extension has a known validator and the content fails
    it, return a one-line error string suitable for the tool result.
    Returns None when the file passes or has no validator. The model uses
    this to self-correct on the next turn instead of writing a half-broken
    project."""
    ext = "." + rel_path.rsplit(".", 1)[-1].lower() if "." in rel_path else ""
    validator = _SYNTAX_VALIDATORS.get(ext)
    if not validator:
        return None
    try:
        err = validator(content)
    except Exception:
        return None
    if not err:
        return None
    return (
        "ORCHESTRATOR syntax check: " + err
        + ". The file was written, but it won't parse. Fix it with "
        "`edit_file` or `multi_edit` before continuing."
    )


# =============================================================================
# Workspace-bounded path resolution
# =============================================================================

def resolve_in_workspace(workspace: Path, rel: str) -> Path:
    """Resolve `rel` against the workspace, accepting `~` / `~user` and
    absolute paths as long as they ultimately live under the workspace
    root. Tilde expansion is the difference between "the model gives us
    `~/Documents/foo.html` and it just works" vs. the resolver treating
    `~` as a literal directory and rejecting the call."""
    raw = rel.strip()
    if raw.startswith("~"):
        candidate = Path(raw).expanduser()
    else:
        candidate = Path(raw)
    if candidate.is_absolute():
        target = candidate.resolve()
    else:
        target = (workspace / candidate).resolve()
    root = workspace.resolve()
    if target != root and root not in target.parents:
        raise ValueError(f"path is outside the workspace: {rel}")
    return target


# =============================================================================
# Built-in tool implementations
# =============================================================================

def tool_read_file(state, args):
    """8.0.12: offset/limit support + smart head+tail truncation for
    huge files. The original behavior (return full content up to 32k
    chars) loaded the entire file into the transcript every time,
    which the agent kept re-tokenizing on every subsequent turn.
    Files > 1500 lines now return a head + tail slice with a "use
    offset/limit for specifics" hint so the model can ask for a range
    rather than holding the whole file in context forever."""
    path = resolve_in_workspace(state.workspace, args["path"])
    if not path.is_file():
        raise FileNotFoundError(f"not found: {args['path']}")
    text = path.read_text(encoding="utf-8", errors="replace")
    offset = args.get("offset")
    limit = args.get("limit")
    if offset or limit:
        lines = text.split("\n")
        start = max(0, int(offset or 1) - 1)  # 1-indexed -> 0-indexed
        end = start + int(limit) if limit else len(lines)
        end = min(end, len(lines))
        slice_text = "\n".join(lines[start:end])
        header = (f"[lines {start+1}-{end} of {len(lines)} in "
                  f"{args['path']}]\n")
        return header + slice_text
    lines = text.split("\n")
    if len(lines) > 1500:
        head = "\n".join(lines[:100])
        tail = "\n".join(lines[-50:])
        return (
            f"[showing lines 1-100 + last 50 of {len(lines)} total in "
            f"{args['path']}]\n"
            f"{head}\n\n"
            f"... [TRUNCATED {len(lines) - 150} lines in the middle. "
            f"Call read_file again with offset=<line> limit=<count> to "
            f"see a specific range] ...\n\n"
            f"{tail}"
        )
    if len(text) > 32000:
        return text[:32000] + "\n\n...(truncated at 32000 chars)"
    return text


def tool_write_file(state, args):
    path = resolve_in_workspace(state.workspace, args["path"])
    old = path.read_text(encoding="utf-8") if path.is_file() else ""
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(args["content"], encoding="utf-8")
    state.last_diff = (args["path"], old, args["content"])
    record_journal(state, "write_file", args["path"], old, args["content"])
    syntax_note = check_syntax(args["path"], args["content"])
    msg = f"Wrote {len(args['content'])} bytes to {args['path']}"
    return msg + ("\n\n" + syntax_note if syntax_note else "")


def tool_edit_file(state, args):
    path = resolve_in_workspace(state.workspace, args["path"])
    if not path.is_file():
        raise FileNotFoundError(f"not found: {args['path']}")
    text = path.read_text(encoding="utf-8")
    if args["old_string"] not in text:
        raise ValueError("old_string not found in file")
    new_text = text.replace(args["old_string"], args["new_string"], 1)
    path.write_text(new_text, encoding="utf-8")
    state.last_diff = (args["path"], text, new_text)
    record_journal(state, "edit_file", args["path"], text, new_text)
    syntax_note = check_syntax(args["path"], new_text)
    msg = f"Replaced 1 occurrence in {args['path']}"
    return msg + ("\n\n" + syntax_note if syntax_note else "")


def tool_list_dir(state, args):
    path = resolve_in_workspace(state.workspace, args.get("path", ""))
    if not path.is_dir():
        raise NotADirectoryError(f"not a directory: {args.get('path', '')}")
    return "\n".join(sorted(p.name for p in path.iterdir()))


def tool_glob(state, args):
    """Match a glob pattern against the workspace, capped at 200 hits.
    Pattern is rooted at `path` (default = workspace root) and supports
    `**` for recursive matching. Returns one line per match, relative to
    the workspace."""
    pattern = args["pattern"]
    sub = args.get("path", "")
    if sub:
        base = resolve_in_workspace(state.workspace, sub)
    else:
        base = state.workspace
    if not base.exists():
        return f"path not found: {sub or '.'}"
    hits = []
    for p in base.rglob(pattern):
        try:
            rel = p.relative_to(state.workspace)
        except ValueError:
            continue
        hits.append(str(rel))
        if len(hits) >= 200:
            break
    if not hits:
        return f"no matches for pattern {pattern!r}"
    return "\n".join(sorted(hits))


def tool_grep(state, args):
    """grep -rIn pattern path (default workspace). `path` is workspace-
    relative. Output capped at 200 lines. Binary files are skipped via
    grep -I."""
    pattern = args["pattern"]
    sub = args.get("path", "")
    if sub:
        base = resolve_in_workspace(state.workspace, sub)
    else:
        base = state.workspace
    if not base.exists():
        return f"path not found: {sub or '.'}"
    cmd = ["/usr/bin/grep", "-rIn", "--", pattern, str(base)]
    include = args.get("include")
    if include:
        cmd[1:1] = [f"--include={include}"]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=20)
    except subprocess.TimeoutExpired:
        return f"grep timed out for pattern {pattern!r}"
    if proc.returncode not in (0, 1):
        return f"grep error: {proc.stderr.strip()[:400]}"
    lines = proc.stdout.splitlines()
    if not lines:
        return f"no matches for pattern {pattern!r}"
    # Strip workspace prefix off each line so the model sees relative paths.
    prefix = str(state.workspace) + "/"
    cleaned = [ln.removeprefix(prefix) for ln in lines[:200]]
    suffix = "" if len(lines) <= 200 else f"\n... ({len(lines) - 200} more matches)"
    return "\n".join(cleaned) + suffix


def tool_multi_edit(state, args):
    """Apply N substring replacements to a single file in one call. Each
    edit is {old_string, new_string}, applied in order, replacing the first
    occurrence per edit. Errors out on the first old_string that's not
    found, identifying the index so the model can fix just that one."""
    path = resolve_in_workspace(state.workspace, args["path"])
    if not path.is_file():
        raise FileNotFoundError(f"not found: {args['path']}")
    text = path.read_text(encoding="utf-8")
    original = text
    edits = args.get("edits") or []
    if not isinstance(edits, list) or not edits:
        raise ValueError("edits must be a non-empty list")
    applied = 0
    for i, edit in enumerate(edits):
        if not isinstance(edit, dict):
            raise ValueError(f"edit #{i} is not an object")
        old_s = edit.get("old_string", "")
        new_s = edit.get("new_string", "")
        if not old_s:
            raise ValueError(f"edit #{i} missing old_string")
        if old_s not in text:
            raise ValueError(
                f"edit #{i} old_string not found in file (after {applied} "
                "successful prior edits)")
        text = text.replace(old_s, new_s, 1)
        applied += 1
    path.write_text(text, encoding="utf-8")
    state.last_diff = (args["path"], original, text)
    record_journal(state, "multi_edit", args["path"], original, text)
    syntax_note = check_syntax(args["path"], text)
    msg = f"Applied {applied} edits to {args['path']}"
    return msg + ("\n\n" + syntax_note if syntax_note else "")


def tool_run_bash(state, args):
    """Run a shell command in a *non*-interactive login shell, isolated in
    its own session so zsh's job-control bookkeeping can't leave us
    holding a terminal we don't own. The previous `zsh -lic ...` invocation
    flipped pgrp ownership around and intermittently dropped lmstudio into
    the background, where the spinner's next stdout write tripped SIGTTOU
    ("zsh: suspended (tty output)").

    Streams the command's combined output line-by-line to the terminal so
    long-running tasks aren't silent. Captures the full output to return
    as the tool result.

    Uses `select.select` so the read wakes every 1s to check the deadline.
    Without it, a child that writes a prompt without a trailing newline
    would block readline forever and the deadline check would never fire."""
    import select as _select
    command = args["command"]
    timeout = max(1, min(int(args.get("timeout_seconds", 30)), 600))
    proc = subprocess.Popen(
        ["/bin/zsh", "-lc", command],
        cwd=str(state.workspace),
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
        start_new_session=True,
    )
    deadline = time.time() + timeout
    chunks = []
    truncated = False
    total_bytes = 0
    cap = 32000
    quiet = not sys.stdout.isatty()
    killed_for_timeout = False
    try:
        while True:
            remaining = deadline - time.time()
            if remaining <= 0:
                proc.kill()
                killed_for_timeout = True
                chunks.append("\n[orchestrator killed: timeout exceeded]\n")
                break
            ready, _, _ = _select.select([proc.stdout], [], [],
                                          min(1.0, remaining))
            if not ready:
                if proc.poll() is not None:
                    # Drain any final buffered output.
                    rest = proc.stdout.read()
                    if rest:
                        if not quiet:
                            sys.stdout.write(rest)
                            sys.stdout.flush()
                        chunks.append(rest)
                    break
                continue
            line = proc.stdout.readline()
            if not line:
                if proc.poll() is not None:
                    break
                continue
            if not quiet:
                sys.stdout.write("  " + style("│", "dim") + " " + line)
                sys.stdout.flush()
            if not truncated:
                if total_bytes + len(line) > cap:
                    chunks.append(line[:cap - total_bytes])
                    chunks.append(f"\n...(streamed truncated at {cap} bytes; "
                                  f"continued running)\n")
                    truncated = True
                else:
                    chunks.append(line)
                    total_bytes += len(line)
    finally:
        if proc.poll() is None:
            try:
                proc.wait(timeout=2)
            except subprocess.TimeoutExpired:
                proc.kill()
                proc.wait()
    rc = proc.returncode if not killed_for_timeout else -1
    header = f"$ {command}\n[exit {rc}]\n"
    return header + "".join(chunks)


# =============================================================================
# Headless browser (Playwright via persistent subprocess)
# =============================================================================
#
# The agent gets a Chromium it can drive: navigate, screenshot, click,
# type, evaluate JS. Implemented as a persistent Python subprocess running
# Playwright's sync API so we don't pay launch cost per call. The
# subprocess speaks one-line JSON over stdin/stdout.
#
# Degrades gracefully: if `playwright` isn't importable in the child, the
# child reports it on first command and the tool returns an instructive
# error pointing to the install steps.

BROWSER_DRIVER = r"""
import sys, json, traceback

try:
    from playwright.sync_api import sync_playwright
except Exception as e:
    sys.stdout.write(json.dumps({
        "error": "playwright not installed",
        "hint": "pip install playwright && python -m playwright install chromium"
    }) + "\n")
    sys.stdout.flush()
    sys.exit(0)

pw = sync_playwright().start()
browser = None
page = None

def _ensure_browser():
    global browser, page
    if browser is None:
        browser = pw.chromium.launch(headless=True)
    if page is None:
        ctx = browser.new_context(viewport={"width": 1280, "height": 800})
        page = ctx.new_page()

for raw in sys.stdin:
    raw = raw.strip()
    if not raw:
        continue
    try:
        cmd = json.loads(raw)
    except json.JSONDecodeError as e:
        print(json.dumps({"error": f"bad json: {e}"}))
        sys.stdout.flush()
        continue
    method = cmd.get("method")
    out = {}
    try:
        if method == "goto":
            _ensure_browser()
            page.goto(cmd["url"], wait_until="domcontentloaded", timeout=30000)
            out = {"url": page.url, "title": page.title()}
        elif method == "screenshot":
            _ensure_browser()
            full = bool(cmd.get("full_page", True))
            page.screenshot(path=cmd["path"], full_page=full)
            out = {"path": cmd["path"]}
        elif method == "click":
            _ensure_browser()
            page.click(cmd["selector"], timeout=10000)
            out = {"clicked": cmd["selector"]}
        elif method == "type":
            _ensure_browser()
            page.fill(cmd["selector"], cmd["text"], timeout=10000)
            out = {"typed": True}
        elif method == "eval":
            _ensure_browser()
            out = {"result": page.evaluate(cmd["script"])}
        elif method == "text":
            _ensure_browser()
            out = {"text": page.inner_text("body")[:32000]}
        elif method == "close":
            if browser is not None:
                browser.close()
                browser = None
                page = None
            pw.stop()
            print(json.dumps({"closed": True}))
            sys.stdout.flush()
            sys.exit(0)
        else:
            out = {"error": f"unknown method: {method}"}
    except Exception as e:
        out = {"error": str(e), "trace": traceback.format_exc()[:2000]}
    print(json.dumps(out))
    sys.stdout.flush()
"""


class BrowserSession:
    """Long-lived Playwright subprocess. Lazy-launched on first call."""

    def __init__(self):
        self.proc = None

    def _ensure(self):
        if self.proc and self.proc.poll() is None:
            return
        self.proc = subprocess.Popen(
            ["python3", "-u", "-c", BROWSER_DRIVER],
            stdin=subprocess.PIPE, stdout=subprocess.PIPE,
            stderr=subprocess.PIPE, text=True, bufsize=1,
        )

    def call(self, method, **kwargs):
        self._ensure()
        msg = {"method": method, **kwargs}
        try:
            self.proc.stdin.write(json.dumps(msg) + "\n")
            self.proc.stdin.flush()
        except (BrokenPipeError, OSError) as e:
            return {"error": f"browser subprocess died: {e}"}
        line = self.proc.stdout.readline()
        if not line:
            # Maybe an early exit (playwright missing). Read stderr too.
            err = self.proc.stderr.read() if self.proc.stderr else ""
            return {"error": "browser subprocess produced no output",
                    "stderr": err[:400]}
        try:
            return json.loads(line)
        except json.JSONDecodeError as e:
            return {"error": f"browser returned non-JSON: {e}", "raw": line[:400]}

    def close(self):
        if not self.proc:
            return
        try:
            self.proc.stdin.write(json.dumps({"method": "close"}) + "\n")
            self.proc.stdin.flush()
        except Exception:
            pass
        try:
            self.proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            self.proc.kill()
        self.proc = None


def _ensure_browser(state):
    if state.browser is None:
        state.browser = BrowserSession()
    return state.browser


def tool_browser_open(state, args):
    res = _ensure_browser(state).call("goto", url=args["url"])
    if res.get("error"):
        return _browser_error(res)
    return f"opened {res['url']}\ntitle: {res.get('title','?')}"


def tool_browser_screenshot(state, args):
    target = args.get("path")
    if not target:
        ts = int(time.time())
        target_path = state.workspace / "screenshots" / f"shot-{ts}.png"
    else:
        target_path = resolve_in_workspace(state.workspace, target)
    target_path.parent.mkdir(parents=True, exist_ok=True)
    full = bool(args.get("full_page", True))
    res = _ensure_browser(state).call(
        "screenshot", path=str(target_path), full_page=full)
    if res.get("error"):
        return _browser_error(res)
    try:
        rel = target_path.relative_to(state.workspace)
    except ValueError:
        rel = target_path
    return f"saved screenshot to {rel}"


def tool_browser_click(state, args):
    res = _ensure_browser(state).call("click", selector=args["selector"])
    if res.get("error"):
        return _browser_error(res)
    return f"clicked {args['selector']}"


def tool_browser_type(state, args):
    res = _ensure_browser(state).call(
        "type", selector=args["selector"], text=args["text"])
    if res.get("error"):
        return _browser_error(res)
    return f"typed into {args['selector']}"


def tool_browser_eval(state, args):
    res = _ensure_browser(state).call("eval", script=args["script"])
    if res.get("error"):
        return _browser_error(res)
    val = res.get("result")
    return f"result: {json.dumps(val)[:2000]}"


def tool_browser_text(state, _args):
    res = _ensure_browser(state).call("text")
    if res.get("error"):
        return _browser_error(res)
    return res.get("text", "")


def tool_browser_close(state, _args):
    if state.browser:
        state.browser.close()
        state.browser = None
        return "browser closed."
    return "browser was not running."


def _browser_error(res):
    msg = res.get("error", "unknown browser error")
    hint = res.get("hint")
    if hint:
        msg += f"\nhint: {hint}"
    return f"browser error: {msg}"


def _run_git(state, *args, timeout=20, max_bytes=16000):
    """Run a git subcommand inside the workspace. Returns the combined
    stdout+stderr, capped. The model uses these for repository awareness."""
    try:
        proc = subprocess.run(
            ["/usr/bin/env", "git", *args],
            cwd=str(state.workspace),
            capture_output=True, text=True, timeout=timeout,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return f"git error: {e}"
    out = (proc.stdout or "") + (proc.stderr or "")
    if not out.strip():
        return f"(empty) git {' '.join(args)} -> exit {proc.returncode}"
    if len(out) > max_bytes:
        out = out[:max_bytes] + f"\n…(truncated; {len(out) - max_bytes} more bytes)"
    return out


def tool_git_status(state, _args):
    return _run_git(state, "status", "--short", "--branch")


def tool_git_diff(state, args):
    target = args.get("path", "")
    staged = args.get("staged", False)
    cmd = ["diff"]
    if staged:
        cmd.append("--staged")
    if target:
        cmd.append("--")
        cmd.append(target)
    return _run_git(state, *cmd, max_bytes=32000)


def tool_git_log(state, args):
    limit = max(1, min(int(args.get("limit", 20)), 200))
    return _run_git(state, "log", f"-{limit}", "--oneline", "--decorate")


def tool_git_blame(state, args):
    path = args["path"]
    return _run_git(state, "blame", "--", path, max_bytes=20000)


def tool_git_show(state, args):
    target = args.get("commit", "HEAD")
    return _run_git(state, "show", "--stat", target, max_bytes=20000)


def tool_find_todos(state, args):
    """Scan the workspace for TODO/FIXME/XXX/HACK markers. Returns
    `path:line: text` per hit, capped at 200 hits. Skip dirs that
    `WORKSPACE_TREE_IGNORE` already filters from the workspace scan."""
    pattern = args.get("pattern") or "TODO|FIXME|XXX|HACK|NOTE"
    paths_arg = args.get("path", "")
    if paths_arg:
        base = resolve_in_workspace(state.workspace, paths_arg)
    else:
        base = state.workspace
    exclude = [f"--exclude-dir={d}" for d in WORKSPACE_TREE_IGNORE]
    cmd = ["/usr/bin/grep", "-rInE", *exclude, "--", pattern, str(base)]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=20)
    except subprocess.TimeoutExpired:
        return f"find_todos timed out"
    lines = (proc.stdout or "").splitlines()
    if not lines:
        return "no TODO/FIXME markers found"
    prefix = str(state.workspace) + "/"
    cleaned = [ln.removeprefix(prefix) for ln in lines[:200]]
    suffix = "" if len(lines) <= 200 else f"\n... ({len(lines) - 200} more)"
    return "\n".join(cleaned) + suffix


def tool_spawn_agent(state, args):
    """Dispatch a focused subprompt to a fresh `lmstudio` subprocess.

    With `isolation="worktree"` (8.0.0), creates a temporary git worktree
    under ~/.loom/worktrees/<id> from the current HEAD; the subagent runs
    there. On clean exit, the diff against the parent is included in the
    return value. Files modified in the worktree are NOT auto-merged back
    — caller decides what to do with them."""
    role = args.get("role", "subagent")
    prompt = args["prompt"]
    isolation = args.get("isolation", "")
    system = args.get("system", f"You are a focused {role} subagent. "
                                "Answer briefly with the final result.")

    workspace_arg = str(state.workspace)
    worktree = None
    if isolation == "worktree":
        try:
            wt_path, _branch = make_worktree(state.workspace,
                                              branch_hint=f"sub-{role}")
            worktree = wt_path
            workspace_arg = str(wt_path)
        except RuntimeError as e:
            return f"spawn_agent worktree setup failed: {e}"

    cmd = [
        sys.argv[0], "--no-banner", "--json",
        "--workspace", workspace_arg,
        "--base-url", state.base_url, "--model", state.model,
        "--system", system,
    ]
    if state.allow_bash:
        cmd.append("--allow-bash")
    if state.yolo:
        cmd.append("--yolo")
    cmd.append(prompt)
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True,
                              timeout=600)
    except subprocess.TimeoutExpired:
        if worktree:
            tear_down_worktree(worktree, state.workspace)
        return "spawn_agent timed out after 10 minutes"
    final = ""
    for line in proc.stdout.splitlines():
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if event.get("type") == "completed":
            final = event.get("text") or final

    out_parts = [final or proc.stdout or "(subagent returned no output)"]
    if worktree:
        try:
            diff = subprocess.run(
                ["/usr/bin/env", "git", "diff", "--stat", "HEAD"],
                cwd=str(worktree), capture_output=True, text=True,
                timeout=15,
            )
            if diff.stdout.strip():
                out_parts.append(f"\n\n--- worktree diff vs HEAD ---\n"
                                  + diff.stdout.strip())
            # The worktree itself is preserved so the user can inspect it;
            # branch + path are reported.
            out_parts.append(
                f"\n\nworktree retained at: {worktree}\n"
                "(use `git -C <workspace> worktree remove <path>` to clean up)")
        except (FileNotFoundError, subprocess.TimeoutExpired):
            tear_down_worktree(worktree, state.workspace)
    return "\n".join(out_parts)


# =============================================================================
# Network & web (6.0.0)
# =============================================================================

_DDG_USER_AGENT = ("Mozilla/5.0 (Macintosh; Intel Mac OS X 14_4) "
                   "AppleWebKit/605.1.15 (KHTML, like Gecko) "
                   "Version/17.4 Safari/605.1.15")


def _http_open(url, *, method="GET", headers=None, body=None, timeout=30):
    """Thin urllib wrapper. Returns (status, headers_dict, body_bytes)."""
    hdrs = {"User-Agent": _DDG_USER_AGENT}
    if headers:
        hdrs.update(headers)
    data = None
    if body is not None:
        if isinstance(body, (dict, list)):
            data = json.dumps(body).encode("utf-8")
            hdrs.setdefault("Content-Type", "application/json")
        elif isinstance(body, str):
            data = body.encode("utf-8")
        else:
            data = bytes(body)
    req = urllib.request.Request(url, data=data, headers=hdrs, method=method)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return (resp.status, dict(resp.headers), resp.read())
    except urllib.error.HTTPError as e:
        return (e.code, dict(e.headers), e.read())


_DDG_HTML_TITLE_RE = re.compile(
    r'<a[^>]*class="result__a"[^>]*href="([^"]+)"[^>]*>(.*?)</a>', re.S)
_DDG_HTML_SNIPPET_RE = re.compile(
    r'<a[^>]*class="result__snippet"[^>]*>(.*?)</a>', re.S)
_HTML_TAG_RE = re.compile(r'<[^>]+>')


def _strip_html(text):
    text = _HTML_TAG_RE.sub(' ', text)
    # Decode the small set of HTML entities we care about.
    replacements = {
        '&amp;': '&', '&lt;': '<', '&gt;': '>', '&quot;': '"',
        '&#39;': "'", '&nbsp;': ' ', '&hellip;': '…', '&mdash;': '—',
    }
    for k, v in replacements.items():
        text = text.replace(k, v)
    return re.sub(r'\s+', ' ', text).strip()


def tool_web_search(state, args):
    """DuckDuckGo HTML scrape. Stdlib only, no API key. Cap at `limit` (default 10, max 20)."""
    query = args["query"].strip()
    if not query:
        return "empty query"
    limit = max(1, min(int(args.get("limit", 10)), 20))
    url = f"https://html.duckduckgo.com/html/?q={urllib.parse.quote(query)}"
    try:
        _, _, body = _http_open(url, timeout=15)
    except (urllib.error.URLError, OSError) as e:
        return f"web_search failed: {e}"
    html = body.decode("utf-8", errors="replace")
    titles = _DDG_HTML_TITLE_RE.findall(html)
    snippets = _DDG_HTML_SNIPPET_RE.findall(html)
    rows = []
    for i, (href, title_html) in enumerate(titles[:limit]):
        snippet = _strip_html(snippets[i]) if i < len(snippets) else ""
        title = _strip_html(title_html)
        rows.append(f"{title}\n  {href}\n  {snippet[:200]}")
    if not rows:
        return f"no results for {query!r}"
    return "\n\n".join(rows)


def tool_web_fetch(state, args):
    """GET the URL and return a readability-ish text extraction.
    mode ∈ {text (default), raw, html}."""
    url = args["url"]
    if state.web_blocklist:
        host = urllib.parse.urlparse(url).netloc.lower()
        for blocked in state.web_blocklist:
            if blocked in host:
                return f"web_fetch refused: {host} is blocklisted"
    mode = args.get("mode", "text")
    try:
        status, _, body = _http_open(url, timeout=30)
    except (urllib.error.URLError, OSError) as e:
        return f"web_fetch failed: {e}"
    text = body.decode("utf-8", errors="replace")
    if mode == "raw":
        out = text
    elif mode == "html":
        out = text  # caller wants HTML; trim only
    else:
        # Naive readability: drop scripts/styles/nav, then strip tags.
        cleaned = re.sub(r'<script[^>]*>.*?</script>', ' ', text,
                         flags=re.S | re.I)
        cleaned = re.sub(r'<style[^>]*>.*?</style>', ' ', cleaned,
                         flags=re.S | re.I)
        cleaned = re.sub(r'<(nav|header|footer|aside)[^>]*>.*?</\1>', ' ',
                         cleaned, flags=re.S | re.I)
        out = _strip_html(cleaned)
    if len(out) > 65536:
        out = out[:65536] + f"\n\n…(truncated; original {len(text)} bytes)"
    return f"HTTP {status} {url}\n\n{out}"


def tool_http_request(state, args):
    """Arbitrary REST. Permission-gated by _dispatch_tool (in DANGEROUS_TOOLS)."""
    method = args.get("method", "GET").upper()
    url = args["url"]
    headers = args.get("headers") or {}
    body = args.get("body")
    timeout = max(1, min(int(args.get("timeout", 30)), 120))
    try:
        status, resp_headers, resp_body = _http_open(
            url, method=method, headers=headers, body=body, timeout=timeout)
    except (urllib.error.URLError, OSError) as e:
        return f"http_request failed: {e}"
    text = resp_body.decode("utf-8", errors="replace")
    if len(text) > 32000:
        text = text[:32000] + f"\n…(truncated; {len(resp_body) - 32000} more bytes)"
    head_pairs = "\n".join(f"  {k}: {v}" for k, v in
                            list(resp_headers.items())[:20])
    return (f"HTTP {status} {method} {url}\n\n"
            f"--- response headers ---\n{head_pairs}\n\n"
            f"--- response body ---\n{text}")


def tool_rss_fetch(state, args):
    """Parse an RSS or Atom feed. Returns recent items."""
    url = args["url"]
    limit = max(1, min(int(args.get("limit", 10)), 50))
    try:
        _, _, body = _http_open(url, timeout=15)
    except (urllib.error.URLError, OSError) as e:
        return f"rss_fetch failed: {e}"
    import xml.etree.ElementTree as ET
    try:
        root = ET.fromstring(body)
    except ET.ParseError as e:
        return f"rss_fetch parse error: {e}"
    rows = []
    # Handle both RSS 2.0 and Atom.
    items = root.findall(".//item") or root.findall(
        ".//{http://www.w3.org/2005/Atom}entry")
    for entry in items[:limit]:
        title = entry.findtext("title") or entry.findtext(
            "{http://www.w3.org/2005/Atom}title") or ""
        link = entry.findtext("link") or ""
        if not link:
            link_el = entry.find("{http://www.w3.org/2005/Atom}link")
            link = link_el.get("href") if link_el is not None else ""
        pub = (entry.findtext("pubDate") or
               entry.findtext("{http://www.w3.org/2005/Atom}published") or
               entry.findtext("{http://www.w3.org/2005/Atom}updated") or "")
        summary = (entry.findtext("description") or
                   entry.findtext("{http://www.w3.org/2005/Atom}summary") or
                   "")
        rows.append(f"{title.strip()}\n  {link.strip()}  "
                    f"{pub.strip()}\n  {_strip_html(summary)[:240]}")
    if not rows:
        return "no items"
    return "\n\n".join(rows)


def tool_websocket_subscribe(state, args):
    """Minimal RFC 6455 client. Connects, optionally sends one frame, reads
    frames until `until` regex matches OR the 30s deadline. Permission-
    gated."""
    import socket as _socket
    import struct
    import base64 as _b64
    import os as _os
    url = args["url"]
    parsed = urllib.parse.urlparse(url)
    scheme = parsed.scheme
    if scheme not in ("ws", "wss"):
        return f"websocket_subscribe: bad scheme {scheme!r}"
    host = parsed.hostname
    port = parsed.port or (443 if scheme == "wss" else 80)
    path = parsed.path or "/"
    if parsed.query:
        path += "?" + parsed.query
    initial = args.get("message")
    until = args.get("until")
    deadline = time.time() + min(int(args.get("timeout", 30)), 60)
    sock = _socket.create_connection((host, port), timeout=15)
    if scheme == "wss":
        import ssl
        ctx = ssl.create_default_context()
        sock = ctx.wrap_socket(sock, server_hostname=host)
    key = _b64.b64encode(_os.urandom(16)).decode()
    handshake = (
        f"GET {path} HTTP/1.1\r\n"
        f"Host: {host}:{port}\r\n"
        "Upgrade: websocket\r\n"
        "Connection: Upgrade\r\n"
        f"Sec-WebSocket-Key: {key}\r\n"
        "Sec-WebSocket-Version: 13\r\n\r\n"
    )
    sock.sendall(handshake.encode())
    resp = b""
    while b"\r\n\r\n" not in resp:
        chunk = sock.recv(4096)
        if not chunk:
            break
        resp += chunk
    if b"101" not in resp[:15]:
        sock.close()
        return f"websocket handshake failed:\n{resp[:400].decode('utf-8', errors='replace')}"

    def _send_text(s, payload):
        data = payload.encode("utf-8")
        header = bytearray([0x81])  # FIN + text frame
        mask = _os.urandom(4)
        length = len(data)
        if length < 126:
            header.append(0x80 | length)
        elif length <= 0xFFFF:
            header.append(0x80 | 126)
            header += struct.pack("!H", length)
        else:
            header.append(0x80 | 127)
            header += struct.pack("!Q", length)
        header += mask
        masked = bytes(b ^ mask[i % 4] for i, b in enumerate(data))
        s.sendall(header + masked)

    def _recv_exact(s, n):
        """Read exactly `n` bytes from a socket, looping over partial
        recv()s. Returns b'' on close. recv() doesn't promise to return
        the full requested size; without this, websocket frames silently
        truncate when the kernel fragments a payload across packets."""
        buf = b""
        while len(buf) < n:
            chunk = s.recv(n - len(buf))
            if not chunk:
                return b""
            buf += chunk
        return buf

    if initial:
        _send_text(sock, initial)
    frames = []
    sock.settimeout(2)
    while time.time() < deadline:
        try:
            head = _recv_exact(sock, 2)
            if len(head) < 2:
                break
            opcode = head[0] & 0x0F
            length = head[1] & 0x7F
            if length == 126:
                ext = _recv_exact(sock, 2)
                if len(ext) < 2:
                    break
                length = struct.unpack("!H", ext)[0]
            elif length == 127:
                ext = _recv_exact(sock, 8)
                if len(ext) < 8:
                    break
                length = struct.unpack("!Q", ext)[0]
            data = b""
            while len(data) < length:
                chunk = sock.recv(length - len(data))
                if not chunk:
                    break
                data += chunk
            text = data.decode("utf-8", errors="replace")
            frames.append(text)
            if until and re.search(until, text):
                break
        except _socket.timeout:
            continue
        except Exception as e:
            frames.append(f"[error: {e}]")
            break
    sock.close()
    if not frames:
        return "(no frames received)"
    return "\n---\n".join(frames[:30])[:32000]


# =============================================================================
# GitHub workflow (6.0.0)
# =============================================================================

def _gh(args_list, timeout=30):
    try:
        proc = subprocess.run(
            ["/usr/bin/env", "gh", *args_list],
            capture_output=True, text=True, timeout=timeout,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return f"gh error: {e}\n(install with `brew install gh` if missing)"
    out = (proc.stdout or "") + (proc.stderr or "")
    return out.strip() or f"(empty) exit {proc.returncode}"


def tool_gh_create_pr(state, args):
    cmd = ["pr", "create",
           "--title", args["title"],
           "--body", args.get("body", ""),
           "--base", args.get("base", "main")]
    if args.get("draft", True):
        cmd.append("--draft")
    return _gh(cmd, timeout=60)


def tool_gh_pr_view(state, args):
    cmd = ["pr", "view"]
    if "number" in args:
        cmd.append(str(args["number"]))
    cmd += ["--json", "title,body,state,reviews,checks"]
    return _gh(cmd)


def tool_gh_pr_comment(state, args):
    return _gh(["pr", "comment", str(args["number"]), "--body", args["body"]])


def tool_gh_issue_list(state, args):
    cmd = ["issue", "list"]
    if "state" in args:
        cmd += ["--state", args["state"]]
    if "label" in args:
        cmd += ["--label", args["label"]]
    cmd += ["--limit", str(args.get("limit", 20))]
    return _gh(cmd)


def tool_gh_issue_create(state, args):
    cmd = ["issue", "create",
           "--title", args["title"],
           "--body", args.get("body", "")]
    if "label" in args:
        cmd += ["--label", args["label"]]
    return _gh(cmd)


def tool_gh_issue_view(state, args):
    return _gh(["issue", "view", str(args["number"]),
                "--comments", "--json", "title,body,state,comments"])


# =============================================================================
# Communication (Slack, Messages, Mail) (6.0.0)
# =============================================================================

def _osascript(script, *args, timeout=15):
    cmd = ["/usr/bin/osascript", "-e", script] + list(args)
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True,
                              timeout=timeout)
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return None, str(e)
    return proc.stdout.strip(), proc.stderr.strip() if proc.returncode else None


def tool_slack_post(state, args):
    url = args["webhook_url"]
    payload = {"text": args["text"]}
    if "channel" in args:
        payload["channel"] = args["channel"]
    try:
        status, _, body = _http_open(url, method="POST", body=payload,
                                     timeout=10)
    except (urllib.error.URLError, OSError) as e:
        return f"slack_post failed: {e}"
    return f"slack: HTTP {status} {body.decode('utf-8', errors='replace')[:200]}"


def tool_imessage_send(state, args):
    recipient = args["recipient"].replace('"', r'\"')
    body = args["body"].replace('"', r'\"').replace("\n", " ")
    script = (f'tell application "Messages" to send "{body}" '
              f'to buddy "{recipient}" of '
              f'(service 1 whose service type is iMessage)')
    out, err = _osascript(script)
    if err:
        return f"imessage_send failed: {err}"
    return f"imessage sent to {args['recipient']}"


def tool_mail_send(state, args):
    to_addr = args["to"].replace('"', r'\"')
    subject = args["subject"].replace('"', r'\"')
    body = args["body"].replace('"', r'\"').replace("\n", " ")
    script = (
        f'tell application "Mail"\n'
        f'  set theMessage to make new outgoing message with properties '
        f'{{subject:"{subject}", content:"{body}", visible:false}}\n'
        f'  tell theMessage to make new to recipient at end of to recipients '
        f'with properties {{address:"{to_addr}"}}\n'
        f'  send theMessage\n'
        f'end tell'
    )
    out, err = _osascript(script, timeout=30)
    if err:
        return f"mail_send failed: {err}"
    return f"email sent to {args['to']}"


# =============================================================================
# Database tools (6.0.0)
# =============================================================================

_MUTATION_RE = re.compile(
    r"^\s*(INSERT|UPDATE|DELETE|DROP|TRUNCATE|ALTER|CREATE|REPLACE)\b",
    re.I)


def _md_table(rows, headers=None):
    if not rows:
        return "(no rows)"
    if headers is None:
        headers = list(range(len(rows[0])))
    widths = [max(len(str(h)), *(len(str(r[i])) for r in rows))
              for i, h in enumerate(headers)]
    sep = "| " + " | ".join("-" * w for w in widths) + " |"
    head = "| " + " | ".join(str(h).ljust(widths[i])
                              for i, h in enumerate(headers)) + " |"
    body_rows = ["| " + " | ".join(str(r[i]).ljust(widths[i])
                                    for i in range(len(headers))) + " |"
                 for r in rows]
    return "\n".join([head, sep, *body_rows])


def tool_sqlite_query(state, args):
    import sqlite3
    db = args["database"]
    db_path = (state.workspace / db).resolve() if not Path(db).is_absolute() else Path(db)
    sql = args["sql"]
    if _MUTATION_RE.match(sql) and not args.get("allow_mutation"):
        return ("sqlite_query refused: mutation detected. Re-call with "
                "allow_mutation=true to proceed.")
    try:
        conn = sqlite3.connect(str(db_path))
        cur = conn.cursor()
        cur.execute(sql, args.get("params") or [])
        if cur.description:
            headers = [d[0] for d in cur.description]
            rows = cur.fetchmany(200)
            conn.close()
            return _md_table(rows, headers)
        conn.commit()
        rc = cur.rowcount
        conn.close()
        return f"OK (rows affected: {rc})"
    except sqlite3.Error as e:
        return f"sqlite error: {e}"


def tool_sqlite_schema(state, args):
    import sqlite3
    db = args["database"]
    db_path = (state.workspace / db).resolve() if not Path(db).is_absolute() else Path(db)
    table = args.get("table")
    try:
        conn = sqlite3.connect(str(db_path))
        cur = conn.cursor()
        if table:
            cur.execute(f"PRAGMA table_info({table})")
            rows = cur.fetchall()
            return _md_table(rows, ["cid", "name", "type", "notnull", "dflt", "pk"])
        cur.execute("SELECT name FROM sqlite_master WHERE type='table' ORDER BY name")
        tables = [r[0] for r in cur.fetchall()]
        sections = [f"# Tables: {', '.join(tables)}"]
        for t in tables[:30]:
            cur.execute(f"PRAGMA table_info({t})")
            rows = cur.fetchall()
            sections.append(f"\n## {t}\n" + _md_table(
                rows, ["cid", "name", "type", "notnull", "dflt", "pk"]))
        conn.close()
        return "\n".join(sections)
    except sqlite3.Error as e:
        return f"sqlite error: {e}"


def _shell_db(cmd_args, timeout=30):
    try:
        proc = subprocess.run(cmd_args, capture_output=True, text=True,
                              timeout=timeout)
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return f"db tool error: {e}"
    out = (proc.stdout or "") + (proc.stderr or "")
    if len(out) > 32000:
        out = out[:32000] + "\n…(truncated)"
    return out


def tool_postgres_query(state, args):
    sql = args["sql"]
    if _MUTATION_RE.match(sql) and not args.get("allow_mutation"):
        return "postgres_query refused: mutation. Re-call with allow_mutation=true."
    cmd = ["/usr/bin/env", "psql"]
    if "conn_string" in args:
        cmd += [args["conn_string"]]
    cmd += ["-A", "-F", "|", "-c", sql]
    return _shell_db(cmd)


def tool_mysql_query(state, args):
    sql = args["sql"]
    if _MUTATION_RE.match(sql) and not args.get("allow_mutation"):
        return "mysql_query refused: mutation. Re-call with allow_mutation=true."
    cmd = ["/usr/bin/env", "mysql"]
    if "conn_string" in args:
        cmd += [args["conn_string"]]
    cmd += ["-e", sql]
    return _shell_db(cmd)


def tool_redis_query(state, args):
    cmd = ["/usr/bin/env", "redis-cli"]
    if "host" in args:
        cmd += ["-h", args["host"]]
    cmd += args["command"].split()
    return _shell_db(cmd, timeout=15)


