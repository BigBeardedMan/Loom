def tool_calendar_today(state, _args):
    script = (
        'set today_start to current date\n'
        'set time of today_start to 0\n'
        'set today_end to today_start + (1 * days)\n'
        'tell application "Calendar"\n'
        '  set out to ""\n'
        '  repeat with cal in calendars\n'
        '    set evs to (every event of cal whose start date ≥ today_start and start date < today_end)\n'
        '    repeat with e in evs\n'
        '      set out to out & ((start date of e) as string) & " · " & (summary of e) & linefeed\n'
        '    end repeat\n'
        '  end repeat\n'
        '  return out\n'
        'end tell'
    )
    out, err = _osascript(script, timeout=30)
    if err:
        return f"calendar_today failed: {err}"
    return out or "no events today"


def tool_calendar_create(state, args):
    title = args["title"].replace('"', r'\"')
    when = args["when"]  # ISO-ish string the model gives us
    duration = int(args.get("duration", 60))
    # Parse `when` very loosely.
    script = (
        f'set startDate to date "{when}"\n'
        f'set endDate to startDate + ({duration} * minutes)\n'
        'tell application "Calendar"\n'
        '  tell calendar 1 to make new event with properties '
        f'{{summary:"{title}", start date:startDate, end date:endDate}}\n'
        'end tell'
    )
    out, err = _osascript(script, timeout=15)
    if err:
        return f"calendar_create failed: {err}"
    return f"calendar: created {args['title']!r} at {when}"


def tool_screen_capture_region(state, _args):
    """Interactive region selection via screencapture -i; saves to
    screenshots/region-<ts>.png and returns the path."""
    target = state.workspace / "screenshots" / f"region-{int(time.time())}.png"
    target.parent.mkdir(parents=True, exist_ok=True)
    try:
        proc = subprocess.run(
            ["/usr/sbin/screencapture", "-i", str(target)],
            capture_output=True, timeout=300,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return f"screen_capture failed: {e}"
    if not target.is_file():
        return "screen_capture cancelled (no file saved)"
    try:
        rel = target.relative_to(state.workspace)
    except ValueError:
        rel = target
    return f"saved screen capture to {rel}"


# =============================================================================
# Symbol intelligence + dependency manager (6.0.0)
# =============================================================================

def _build_symbol_index_via_ctags(workspace):
    tags_path = workspace / ".loom" / "tags"
    tags_path.parent.mkdir(parents=True, exist_ok=True)
    excludes = [f"--exclude={d}" for d in WORKSPACE_TREE_IGNORE]
    for binary in ("/opt/homebrew/bin/ctags", "/usr/local/bin/ctags",
                   "/usr/bin/ctags"):
        if not Path(binary).is_file():
            continue
        try:
            proc = subprocess.run(
                [binary, "--fields=+l-n", "-R", *excludes,
                 "-f", str(tags_path), str(workspace)],
                capture_output=True, timeout=60,
            )
            if proc.returncode == 0:
                return tags_path
        except (FileNotFoundError, subprocess.TimeoutExpired):
            continue
    return None


def _load_symbol_index(workspace):
    """Return a {symbol: [(path, line, kind), ...]} dict. Build via ctags
    if available, else fall back to a regex scan for python/js/ts."""
    tags_path = _build_symbol_index_via_ctags(workspace)
    index = {}
    if tags_path and tags_path.is_file():
        try:
            for line in tags_path.read_text(encoding="utf-8",
                                            errors="replace").splitlines():
                if line.startswith("!"):
                    continue
                parts = line.split("\t")
                if len(parts) < 3:
                    continue
                sym, path, _addr = parts[0], parts[1], parts[2]
                kind = ""
                lineno = 0
                for extra in parts[3:]:
                    if extra.startswith("line:"):
                        try:
                            lineno = int(extra.split(":", 1)[1])
                        except ValueError:
                            pass
                    elif len(extra) <= 2:
                        kind = extra
                index.setdefault(sym, []).append((path, lineno, kind))
            return index
        except OSError:
            pass
    # Regex fallback for the most common languages.
    py_def = re.compile(r"^\s*(?:def|class)\s+(\w+)")
    js_def = re.compile(r"(?:function\s+(\w+)|(?:const|let|var)\s+(\w+)\s*=\s*(?:async\s+)?\(?)")
    swift_def = re.compile(r"^\s*(?:(?:public|private|fileprivate|internal|open|final|static|class|struct|@\w+)\s+)*(?:func|class|struct|enum|protocol|extension|actor|typealias)\s+(\w+)")
    go_def = re.compile(r"^\s*func\s+(?:\([^)]+\)\s+)?(\w+)")
    rs_def = re.compile(r"^\s*(?:pub\s+)?(?:fn|struct|enum|trait|impl)\s+(?:<[^>]*>\s+)?(\w+)")
    for ext in (".py", ".js", ".ts", ".tsx", ".jsx", ".swift", ".go", ".rs"):
        for path in workspace.rglob(f"*{ext}"):
            if any(part in WORKSPACE_TREE_IGNORE for part in path.parts):
                continue
            try:
                ext_pat = {
                    ".py": py_def, ".js": js_def, ".ts": js_def,
                    ".tsx": js_def, ".jsx": js_def,
                    ".swift": swift_def, ".go": go_def, ".rs": rs_def,
                }.get(ext, py_def)
                for lineno, line in enumerate(
                        path.read_text(encoding="utf-8",
                                        errors="replace").splitlines(),
                        start=1):
                    m = ext_pat.search(line)
                    if m:
                        # Pick the first non-empty capture group.
                        sym = next((g for g in m.groups() if g), None)
                        if sym:
                            try:
                                rel = str(path.relative_to(workspace))
                            except ValueError:
                                rel = str(path)
                            index.setdefault(sym, []).append(
                                (rel, lineno, "function"))
            except OSError:
                continue
    return index


def tool_symbol_search(state, args):
    if not state.symbol_index:
        state.symbol_index = _load_symbol_index(state.workspace)
    query = args["query"]
    kind = args.get("kind")
    hits = []
    for sym, locs in state.symbol_index.items():
        if query.lower() in sym.lower():
            for path, line, k in locs:
                if kind and k != kind:
                    continue
                hits.append(f"{path}:{line}:{k or '?'}:{sym}")
                if len(hits) >= 200:
                    break
        if len(hits) >= 200:
            break
    return "\n".join(hits) if hits else f"no symbols matching {query!r}"


def _detect_pkg_manager(workspace):
    if (workspace / "package.json").is_file():
        return "npm"
    if (workspace / "requirements.txt").is_file() or (workspace / "pyproject.toml").is_file():
        return "pip"
    if (workspace / "Cargo.toml").is_file():
        return "cargo"
    if (workspace / "go.mod").is_file():
        return "go"
    if (workspace / "Brewfile").is_file():
        return "brew"
    return None


def tool_package_list(state, _args):
    mgr = _detect_pkg_manager(state.workspace)
    if not mgr:
        return "no package manager detected"
    if mgr == "npm":
        try:
            data = json.loads((state.workspace / "package.json").read_text(encoding="utf-8"))
            deps = {**data.get("dependencies", {}),
                    **data.get("devDependencies", {})}
            return f"# npm ({len(deps)} deps)\n" + "\n".join(
                f"  {n}: {v}" for n, v in sorted(deps.items()))
        except (OSError, json.JSONDecodeError) as e:
            return f"package_list npm error: {e}"
    if mgr == "pip":
        req = state.workspace / "requirements.txt"
        if req.is_file():
            return f"# requirements.txt\n{req.read_text(encoding='utf-8')[:8000]}"
        py = state.workspace / "pyproject.toml"
        return f"# pyproject.toml\n{py.read_text(encoding='utf-8')[:8000]}"
    if mgr == "cargo":
        return f"# Cargo.toml\n{(state.workspace / 'Cargo.toml').read_text(encoding='utf-8')[:8000]}"
    if mgr == "go":
        return f"# go.mod\n{(state.workspace / 'go.mod').read_text(encoding='utf-8')[:4000]}"
    return f"manager {mgr}: no list implementation"


def tool_package_install(state, args):
    name = args["name"]
    version = args.get("version")
    mgr = args.get("manager") or _detect_pkg_manager(state.workspace)
    if not mgr:
        return "package_install: no manager detected; pass `manager` explicitly"
    if mgr == "npm":
        cmd = ["npm", "install", f"{name}@{version}" if version else name]
    elif mgr == "pip":
        cmd = ["pip", "install", f"{name}=={version}" if version else name]
    elif mgr == "cargo":
        cmd = ["cargo", "add", name] + (["--version", version] if version else [])
    elif mgr == "brew":
        cmd = ["brew", "install", name]
    else:
        return f"package_install: manager {mgr!r} not supported"
    try:
        proc = subprocess.run(
            ["/usr/bin/env", *cmd],
            cwd=str(state.workspace),
            capture_output=True, text=True, timeout=300,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return f"package_install error: {e}"
    out = (proc.stdout or "") + (proc.stderr or "")
    return f"$ {' '.join(cmd)}\n[exit {proc.returncode}]\n{out[:8000]}"


# =============================================================================
# Sandboxed code execution (6.0.0)
# =============================================================================

def tool_exec_python(state, args):
    code = args["code"]
    timeout = max(1, min(int(args.get("timeout", 10)), 60))
    import tempfile
    with tempfile.TemporaryDirectory() as tmp:
        try:
            proc = subprocess.run(
                ["/usr/bin/env", "python3", "-I", "-S", "-c", code],
                cwd=tmp, capture_output=True, text=True, timeout=timeout,
                env={"PATH": "/usr/bin:/bin", "LANG": "C.UTF-8"},
            )
        except subprocess.TimeoutExpired:
            return f"exec_python timed out after {timeout}s"
        out = (proc.stdout or "") + (proc.stderr or "")
        return f"[exit {proc.returncode}]\n{out[:16000]}"


def tool_exec_js(state, args):
    code = args["code"]
    timeout = max(1, min(int(args.get("timeout", 10)), 60))
    import tempfile
    with tempfile.TemporaryDirectory() as tmp:
        try:
            proc = subprocess.run(
                ["/usr/bin/env", "node", "-e", code],
                cwd=tmp, capture_output=True, text=True, timeout=timeout,
                env={"PATH": "/usr/bin:/bin:/usr/local/bin:/opt/homebrew/bin",
                     "LANG": "C.UTF-8"},
            )
        except (FileNotFoundError, subprocess.TimeoutExpired) as e:
            return f"exec_js error: {e}"
        out = (proc.stdout or "") + (proc.stderr or "")
        return f"[exit {proc.returncode}]\n{out[:16000]}"


