        "warning":       "1;33",
    },
}

_active_theme = _THEMES["default"]
_use_color = True


def set_theme(name):
    global _active_theme
    _active_theme = _THEMES.get(name, _THEMES["default"])


def configure_styling(*, use_color):
    """Disable ANSI codes when stdout isn't a TTY, NO_COLOR is set, or
    --theme mono is selected. Call once at startup before any output."""
    global _use_color
    _use_color = use_color


def style(s, key):
    """Wrap s in the ANSI codes for the named theme role. No-op when
    coloring is off."""
    if not _use_color or not key:
        return s
    code = _active_theme.get(key, "")
    if not code:
        return s
    return f"\033[{code}m{s}\033[0m"


# =============================================================================
# Glyphs
# =============================================================================

GLYPH_SESSION = "✦"
GLYPH_THINK = "◇"
GLYPH_TOOL = "⟳"
GLYPH_OK = "✓"
GLYPH_ERR = "✗"
GLYPH_PROMPT = "❯"
GLYPH_WARN = "⚠"
GLYPH_SPINNER = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]

TASK_GLYPHS = {
    "pending":     ("○", "task_pending"),
    "in_progress": ("▶", "task_progress"),
    "completed":   ("✓", "task_done"),
    "cancelled":   ("⊘", "task_cancel"),
}


# =============================================================================
# Layout helpers
# =============================================================================

def term_width():
    return shutil.get_terminal_size((80, 24)).columns


def box_width():
    """Box width that always fits in the current terminal, recomputed each
    call so resize-between-turns just works on the next draw. Mid-input
    resize still leaves the in-flight box mis-sized; SIGWINCH redraws the
    prompt area for the next turn."""
    return max(40, min(term_width() - 4, 92))


def _visible_len(s):
    """Length of s minus any ANSI escape sequences. Used for padding rows
    that mix styled and unstyled fragments."""
    return len(re.sub(r"\033\[[0-9;]*m", "", s))


# =============================================================================
# Banner / tips / boxed prompt
# =============================================================================

TIPS = [
    "↑ / ↓ walk through previous prompts · Ctrl-R reverse-search history",
    "Esc during a running turn stops it · Ctrl-D or /quit to exit",
    "type @path/to/file to inline a file's contents (Tab completes)",
    "slash commands: /help, /clear, /model, /bash, /cwd, /save, /resume, /cost",
    "task list flows into Loom's Tasks pane via ~/.loom/tasks/",
    "themes: --theme default | mono | cyberpunk | solarized",
    "non-interactive: --json streams structured events for scripting",
]


def draw_banner(model, workspace, allow_bash, session_id, theme_name,
                context_files):
    width = box_width()
    bar = "─" * (width - 2)
    side = style("│", "border")
    print(style("╭" + bar + "╮", "border"))

    headline_inner = (
        f" {style(GLYPH_SESSION, 'border')} "
        f"{style('lmstudio', 'headline')}  "
        f"{style('local LM Studio agent', 'dim')}"
    )
    headline_visible = _visible_len(headline_inner)
    pad = max(0, width - 2 - headline_visible)
    print(f"{side}{headline_inner}{' ' * pad}{side}")
    print(f"{side}{' ' * (width - 2)}{side}")

    def row(label, value, value_key="value"):
        # Inner content: " <label-10> <value>". Outer side bars consume
        # 2 of the `width` columns; the inner area is (width - 2) cols.
        padded_label = label.ljust(10)
        styled_label = style(padded_label, "key")
        styled_value = style(value, value_key) if value_key else value
        inner = f" {styled_label}{styled_value}"
        pad = max(0, width - 2 - _visible_len(inner))
        return f"{side}{inner}{' ' * pad}{side}"

    print(row("workspace", str(workspace)))
    print(row("model", model, "value"))
    print(row("bash", "on" if allow_bash else "off",
              "ok" if allow_bash else "task_pending"))
    print(row("theme", theme_name, "value"))
    if context_files:
        print(row("context", ", ".join(context_files), "dim"))
    print(row("session", session_id, "dim"))
    print(style("╰" + bar + "╯", "border"))


def draw_tips():
    print()
    print(style(" Tips", "tip"))
    for tip in TIPS:
        bullet = style("•", "tip")
        print(f"   {bullet} {style(tip, 'dim')}")
    print()


def draw_task_list(tasks):
    if not tasks:
        return
    width = box_width()
    title = f" Tasks ({len(tasks)}) "
    bar = "─" * max(0, width - 2 - len(title))
    print(style(f"┌─{title}{bar}┐", "border"))
    for i, t in enumerate(tasks, 1):
        glyph, role = TASK_GLYPHS.get(t["status"], TASK_GLYPHS["pending"])
        active = t.get("activeForm") or t["subject"]
        text = active if t["status"] == "in_progress" else t["subject"]
        max_text = width - 10
        if len(text) > max_text:
            text = text[: max_text - 1] + "…"
        index = style(f"{i:>2}", "dim")
        marker = style(glyph, role)
        body_text = (style(text, "dim") if t["status"] == "completed"
                     else (style(text, "key") if t["status"] == "in_progress"
                           else text))
        line = f"│ {index} {marker} {body_text}"
        pad = max(0, width - 1 - _visible_len(line))
        print(line + " " * pad + style("│", "border"))
    print(style("└" + "─" * (width - 2) + "┘", "border"))


def draw_diff(path, old, new):
    """Inline unified diff for a single file change. Capped at 12 visible
    diff lines plus a "… N more" footer when longer."""
    if old == new:
        return
    diff = list(difflib.unified_diff(
        old.splitlines(), new.splitlines(),
        fromfile=str(path), tofile=str(path),
        lineterm="", n=2,
    ))
    body = [line for line in diff if line.startswith(("+", "-", " "))
            and not line.startswith(("+++", "---"))]
    if not body:
        return
    cap = 12
    shown = body[:cap]
    remaining = len(body) - cap
    for line in shown:
        if line.startswith("+"):
            print("    " + style(line, "diff_add"))
        elif line.startswith("-"):
            print("    " + style(line, "diff_del"))
        else:
            print("    " + style(line, "dim"))
    if remaining > 0:
        print("    " + style(f"… {remaining} more line{'s' if remaining != 1 else ''}",
                              "dim"))


def draw_prompt_box():
    width = box_width()
    bar = "─" * (width - 2)
    top = style("╭" + bar + "╮", "border")
    bottom = style("╰" + bar + "╯", "border")
    lead = style("│ ", "border") + style(GLYPH_PROMPT + " ", "prompt")
    return top, lead, bottom


def draw_status_footer(state):
    """One-line status drawn above the prompt box. Approximate token count
    (4 chars ≈ 1 token), wall-clock elapsed, model id, cwd, bash flag."""
    elapsed = int(time.time() - state.started_at)
    if elapsed < 60:
        elapsed_s = f"{elapsed}s"
    elif elapsed < 3600:
        elapsed_s = f"{elapsed // 60}m{elapsed % 60:02d}s"
    else:
        elapsed_s = f"{elapsed // 3600}h{(elapsed % 3600) // 60:02d}m"
    cwd_s = _shorten_path(state.workspace)
    tokens_s = f"{state.approx_tokens:,} tok"
    bash_s = "bash on" if state.allow_bash else "bash off"
    parts = [state.model, cwd_s, tokens_s, elapsed_s, bash_s]
    if state.context_files:
        parts.insert(2, f"context: {len(state.context_files)}")
    line = " " + style(" · ".join(parts), "footer")
    print(line)


def _shorten_path(p):
    p = str(p)
    home = str(Path.home())
    if p.startswith(home):
        p = "~" + p[len(home):]
    if len(p) > 40:
        parts = p.split("/")
        if len(parts) > 4:
            p = "/".join(parts[:2]) + "/…/" + "/".join(parts[-2:])
    return p


# =============================================================================
# Esc-to-interrupt
# =============================================================================

class EscInterrupt(Exception):
    """Raised when the user hits Esc during a running turn."""


class EscWatcher:
    """Puts stdin into cbreak for the lifetime of a `with` block so Esc
    can be polled non-blockingly between SSE chunks. Stays a no-op when
    stdin isn't a TTY so the script is still scriptable."""

    def __init__(self):
        self.enabled = sys.stdin.isatty()
        self.fd = None
        self.old = None

    def __enter__(self):
        if not self.enabled:
            return self
        try:
            self.fd = sys.stdin.fileno()
            self.old = termios.tcgetattr(self.fd)
            new = list(self.old)
            new[3] = new[3] & ~(termios.ICANON | termios.ECHO)
            termios.tcsetattr(self.fd, termios.TCSANOW, new)
        except (termios.error, OSError):
            self.enabled = False
            self.old = None
        return self

    def __exit__(self, *args):
        if self.old is None:
            return
        try:
            termios.tcsetattr(self.fd, termios.TCSADRAIN, self.old)
            termios.tcflush(self.fd, termios.TCIFLUSH)
        except (termios.error, OSError):
            pass

    def check(self):
        if not self.enabled:
            return False
        saw_esc = False
        try:
            while True:
                ready, _, _ = select.select([self.fd], [], [], 0)
                if not ready:
                    break
                try:
                    ch = os.read(self.fd, 64)
                except (OSError, BlockingIOError):
                    break
                if not ch:
                    break
                if b"\x1b" in ch:
                    saw_esc = True
        except (OSError, ValueError):
            return saw_esc
        return saw_esc


# =============================================================================
# Spinner
# =============================================================================

class Spinner:
    """Background thread that animates a Braille spinner with a status
    label until `stop()` is called or the first content delta arrives.
    Renders inline above the assistant's narration."""

    def __init__(self, label="thinking"):
        self.label = label
        self._stop = threading.Event()
        self._thread = None
        self._cleared = threading.Event()

    def __enter__(self):
        if not sys.stdout.isatty():
            return self
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()
        return self

    def __exit__(self, *args):
        self.stop()

    def _run(self):
        idx = 0
        sys.stdout.write("  ")
        while not self._stop.is_set():
            glyph = GLYPH_SPINNER[idx % len(GLYPH_SPINNER)]
            sys.stdout.write("\r  " + style(glyph, "tool")
                             + " " + style(self.label + "…", "dim"))
            sys.stdout.flush()
            idx += 1
            if self._stop.wait(0.08):
                break
        # Clear the spinner line so the streamed content starts clean.
        sys.stdout.write("\r" + " " * 40 + "\r")
        sys.stdout.flush()
        self._cleared.set()

    def stop(self):
        if not self._thread:
            return
        self._stop.set()
        self._cleared.wait(timeout=0.3)
        self._thread = None


# =============================================================================
# Permission prompts
# =============================================================================

DANGEROUS_TOOLS = {"run_bash", "write_file", "edit_file"}


class PermissionManager:
    """Asks the user before letting the agent run dangerous tools. Per-
    session allowlist; persisted only in memory. `--yolo` (or
    LMSTUDIO_YOLO=1, or `/yolo on`) disables prompts entirely."""

    def __init__(self, yolo=False):
        self.yolo = yolo
        self.allowed_forever = set()

    def gate(self, tool_name, args):
        if self.yolo:
            return True
        if tool_name not in DANGEROUS_TOOLS:
            return True
        if tool_name in self.allowed_forever:
            return True
        # Render a one-line preview of what's about to happen.
        summary = self._summarize(tool_name, args)
        print()
        print(f"  {style(GLYPH_WARN, 'warning')} {style('Allow', 'warning')} "
              f"{style(tool_name, 'key')} {summary}?")
        print(f"  {style('[y] yes once   [n] no   [a] yes (always this session)', 'dim')}")
        try:
            answer = input(style("  → ", "prompt")).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return False
        if answer == "a":
            self.allowed_forever.add(tool_name)
            return True
        if answer == "y":
            return True
        return False

    @staticmethod
    def _summarize(tool, args):
        if tool == "run_bash":
            cmd = args.get("command", "")
            return style(cmd[:80] + ("…" if len(cmd) > 80 else ""), "value")
        if tool in ("write_file", "edit_file"):
            return style(args.get("path", "?"), "value")
        return ""


# =============================================================================
# Workspace-bounded path resolution
# =============================================================================

def resolve_in_workspace(workspace: Path, rel: str) -> Path:
    target = (workspace / rel).resolve()
    root = workspace.resolve()
    if target != root and root not in target.parents:
        raise ValueError(f"path is outside the workspace: {rel}")
    return target


# =============================================================================
# Built-in tool implementations
# =============================================================================

def tool_read_file(state, args):
    path = resolve_in_workspace(state.workspace, args["path"])
    if not path.is_file():
        raise FileNotFoundError(f"not found: {args['path']}")
    text = path.read_text(encoding="utf-8", errors="replace")
    if len(text) > 32000:
        return text[:32000] + "\n\n...(truncated at 32000 chars)"
    return text


def tool_write_file(state, args):
    path = resolve_in_workspace(state.workspace, args["path"])
    old = path.read_text(encoding="utf-8") if path.is_file() else ""
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(args["content"], encoding="utf-8")
    state.last_diff = (args["path"], old, args["content"])
    return f"Wrote {len(args['content'])} bytes to {args['path']}"


def tool_edit_file(state, args):
    path = resolve_in_workspace(state.workspace, args["path"])
    if not path.is_file():
        raise FileNotFoundError(f"not found: {args['path']}")
    text = path.read_text(encoding="utf-8")
    if args["old_string"] not in text:
        raise ValueError("old_string not found in file")
    new_text = text.replace(args["old_string"], args["new_string"], 1)
    path.write_text(new_text, encoding="utf-8")
    state.last_diff = (args["path"], text, new_text)
    return f"Replaced 1 occurrence in {args['path']}"


def tool_list_dir(state, args):
    path = resolve_in_workspace(state.workspace, args.get("path", ""))
    if not path.is_dir():
        raise NotADirectoryError(f"not a directory: {args.get('path', '')}")
    return "\n".join(sorted(p.name for p in path.iterdir()))


def tool_run_bash(state, args):
    command = args["command"]
    timeout = max(1, min(int(args.get("timeout_seconds", 30)), 300))
    proc = subprocess.run(
        ["/bin/zsh", "-lic", command],
        cwd=str(state.workspace),
        capture_output=True,
        text=True,
        timeout=timeout,
    )
    header = f"$ {command}\n[exit {proc.returncode}]\n"
    body = proc.stdout + proc.stderr
    if len(body) > 16000:
        body = body[:16000] + "\n...(truncated)"
    return header + body


def tool_spawn_agent(state, args):
    """Dispatches a focused subprompt to a fresh `lmstudio` subprocess with
    its own transcript and a custom system message. Returns the child's
    final assistant message. Useful for delegating expensive subtasks
    (research, test-writing) without polluting the parent context."""
    role = args.get("role", "subagent")
    prompt = args["prompt"]
    system = args.get("system", f"You are a focused {role} subagent. "
                                "Answer briefly with the final result.")
    cmd = [
        sys.argv[0], "--no-banner", "--json",
        "--workspace", str(state.workspace),
        "--base-url", state.base_url, "--model", state.model,
        "--system", system,
    ]
    if state.allow_bash:
        cmd.append("--allow-bash")
    if state.yolo:
        cmd.append("--yolo")
    cmd.append(prompt)
    proc = subprocess.run(cmd, capture_output=True, text=True, timeout=600)
    final = ""
    for line in proc.stdout.splitlines():
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if event.get("type") == "completed":
            final = event.get("text") or final
    return final or proc.stdout or "(subagent returned no output)"


