# Paths + constants
# =============================================================================

DEFAULT_BASE_URL = "http://localhost:1234/v1"
DEFAULT_MAX_TURNS = 30
TASK_ROOT = Path.home() / ".loom" / "tasks"
SESSION_ROOT = Path.home() / ".loom" / "sessions"
HISTORY_FILE = Path.home() / ".config" / "loom" / "lmstudio-history"
CONTEXT_FILES = ["CLAUDE.md", "AGENTS.md", "GUIDE.md", "README.md"]
CONTEXT_CAP_BYTES = 5_000


# =============================================================================
# Themes
# =============================================================================

# A theme is just a mapping of semantic role -> ANSI codes (without the
# leading ESC[ or trailing m, just the ; -joined numbers). The empty string
# means "no styling," used by the mono theme and the no-TTY path.
_BASE_NO_COLOR = {
    "border": "", "headline": "", "key": "", "value": "", "dim": "",
    "thinking": "", "tool": "", "ok": "", "err": "",
    "task_pending": "", "task_progress": "", "task_done": "",
    "task_cancel": "", "tip": "", "prompt": "", "footer": "",
    "diff_add": "", "diff_del": "", "warning": "",
}

_THEMES = {
    "default": {
        "border":        "96",                 # bright cyan
        "headline":      "1;96",               # bold bright cyan
        "key":           "1",                  # bold
        "value":         "96",                 # bright cyan
        "dim":           "2",
        "thinking":      "2;3;33",             # dim italic yellow
        "tool":          "96",                 # bright cyan
        "ok":            "92",                 # bright green
        "err":           "31",                 # red
        "task_pending":  "90",                 # gray
        "task_progress": "1;96",
        "task_done":     "2;92",
        "task_cancel":   "90",
        "tip":           "2;95",
        "prompt":        "1;96",
        "footer":        "2;36",
