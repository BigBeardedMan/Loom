DEFAULT_BASE_URL = "http://localhost:1234/v1"
DEFAULT_MAX_TURNS = 30
TASK_ROOT = Path.home() / ".loom" / "tasks"
SESSION_ROOT = Path.home() / ".loom" / "sessions"
HISTORY_FILE = Path.home() / ".config" / "loom" / "lmstudio-history"
CONTEXT_FILES = ["CLAUDE.md", "AGENTS.md", "GUIDE.md", "README.md"]
CONTEXT_CAP_BYTES = 5_000

WORKSPACE_TREE_IGNORE = {
    ".git", "node_modules", "__pycache__", ".venv", "venv", ".mypy_cache",
    ".pytest_cache", ".ruff_cache", "dist", "build", ".next", ".nuxt",
    "target", ".idea", ".vscode", "DerivedData", ".DS_Store",
    "Pods", ".gradle", "out", "coverage",
}
WORKSPACE_TREE_MAX_DEPTH = 3
WORKSPACE_TREE_MAX_ENTRIES = 200


