# A theme is just a mapping of semantic role -> ANSI codes (without the
# leading ESC[ or trailing m, just the ; -joined numbers). The empty string
# means "no styling," used by the mono theme and the no-TTY path.
_BASE_NO_COLOR = {
    "border": "", "headline": "", "key": "", "value": "", "dim": "",
    "thinking": "", "tool": "", "ok": "", "err": "",
    "task_pending": "", "task_progress": "", "task_done": "",
    "task_cancel": "", "tip": "", "prompt": "", "footer": "",
    "diff_add": "", "diff_del": "", "warning": "",
}

