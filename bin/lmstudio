def tool_keychain_get(state, args):
    """security find-generic-password. Returns raw password (model may use
    it as an API key); not printed to the terminal explicitly."""
    service = args["service"]
    cmd = ["/usr/bin/security", "find-generic-password",
           "-s", service, "-w"]
    if "account" in args:
        cmd += ["-a", args["account"]]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return f"keychain error: {e}"
    if proc.returncode != 0:
        return f"keychain miss: {proc.stderr.strip()[:200]}"
    # Return the value so the model can use it (e.g. as a Bearer token).
    return proc.stdout.strip()


def tool_mdfind(state, args):
    query = args["query"]
    cmd = ["/usr/bin/mdfind"]
    if "path" in args:
        cmd += ["-onlyin", args["path"]]
    cmd += [query]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=20)
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return f"mdfind error: {e}"
    lines = (proc.stdout or "").splitlines()[:200]
    return "\n".join(lines) or "no matches"


