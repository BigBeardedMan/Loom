# Read-only tools that are safe to fan out in parallel (no fs mutation, no
# shell escape, no permission prompt). Anything not in this set is run
# sequentially to keep permission prompts ordered and writes deterministic.
SAFE_PARALLEL_TOOLS = {
    "read_file", "list_dir", "glob", "grep",
