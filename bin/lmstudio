def install_completer(workspace, slash_commands):
    """Wire readline tab completion for @paths and /commands."""
    if not _HAS_READLINE:
        return

    def completer(text, state_idx):
        buf = readline.get_line_buffer()
        begin = readline.get_begidx()
        token = buf[begin:readline.get_endidx()]
        candidates = []
        if token.startswith("@"):
            prefix = token[1:]
            base = workspace
            sub = ""
            if "/" in prefix:
                sub, _, prefix = prefix.rpartition("/")
                base = (workspace / sub).resolve()
                if not base.is_dir() or workspace.resolve() not in (base, *base.parents):
                    return None
            try:
                entries = sorted(base.iterdir(),
                                 key=lambda p: (not p.is_dir(), p.name))
            except OSError:
                return None
            for entry in entries:
                if entry.name.startswith("."):
                    continue
                if entry.name.startswith(prefix):
                    rel = entry.name + ("/" if entry.is_dir() else "")
                    full = f"@{sub}/{rel}" if sub else f"@{rel}"
                    candidates.append(full)
        elif token.startswith("/"):
            for cmd in slash_commands:
                if cmd.startswith(token):
                    candidates.append(cmd + " ")
        try:
            return candidates[state_idx]
        except IndexError:
            return None

    try:
        readline.set_completer(completer)
        readline.set_completer_delims(" \t\n")
        # macOS ships libedit; binding differs from GNU readline.
        if "libedit" in readline.__doc__ or "":
            readline.parse_and_bind("bind ^I rl_complete")
        readline.parse_and_bind("tab: complete")
        readline.parse_and_bind('"\\C-r": reverse-search-history')
    except Exception:
        pass


# =============================================================================
# Project context loader
# =============================================================================

def load_project_context(workspace):
    """Read CLAUDE.md / AGENTS.md / GUIDE.md / README.md (priority order)
    from the workspace, concatenate them up to CONTEXT_CAP_BYTES, and
    return (text, file_list). Falls back to ("", []) when nothing exists."""
    parts = []
    used = []
    remaining = CONTEXT_CAP_BYTES
    for name in CONTEXT_FILES:
        path = workspace / name
        if not path.is_file():
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="replace").strip()
        except OSError:
            continue
        if not text:
            continue
        slice_ = text[:remaining]
        parts.append(f"## {name}\n{slice_}")
        used.append(name)
        remaining -= len(slice_)
        if remaining <= 0:
            break
    if not parts:
        return "", []
    return "# Project Context\n\n" + "\n\n".join(parts), used


def load_workspace_tree(workspace,
                        max_depth=WORKSPACE_TREE_MAX_DEPTH,
                        max_entries=WORKSPACE_TREE_MAX_ENTRIES):
    """Walk the workspace top-down and emit a compact tree summary. Used as
    auto-injected system-prompt context so the model has a workspace map
    without burning list_dir calls to orient itself.

    Returns (tree_string, entry_count). Empty string when the workspace is
    empty (or unreadable)."""
    lines = []
    counter = [0]

    def walk(dirpath, depth):
        if counter[0] >= max_entries or depth > max_depth:
            return
        try:
            entries = sorted(
                dirpath.iterdir(),
                key=lambda p: (not p.is_dir(), p.name.lower()),
            )
        except (OSError, PermissionError):
            return
        for entry in entries:
            if counter[0] >= max_entries:
                lines.append("  " * depth + "... (more)")
                return
            name = entry.name
            if name in WORKSPACE_TREE_IGNORE or name.startswith("."):
                continue
            indent = "  " * depth
            try:
                is_dir = entry.is_dir()
            except OSError:
                continue
            if is_dir:
                lines.append(f"{indent}{name}/")
                counter[0] += 1
                walk(entry, depth + 1)
            else:
                lines.append(f"{indent}{name}")
                counter[0] += 1

    try:
        walk(Path(workspace), 0)
    except (OSError, PermissionError):
        return "", 0
    if not lines:
        return "", 0
    body = "\n".join(lines)
    header = (f"# Workspace Layout ({counter[0]} entries"
              + (", truncated" if counter[0] >= max_entries else "")
              + ")")
    return f"{header}\n\n{body}", counter[0]


# =============================================================================
# Session save / load
# =============================================================================

def save_session(state, name=None):
    SESSION_ROOT.mkdir(parents=True, exist_ok=True)
    if not name:
        name = datetime.now().strftime("%Y%m%d-%H%M%S")
    path = SESSION_ROOT / f"{name}.json"
    payload = {
        "saved_at": _now_iso(),
        "model": state.model,
        "workspace": str(state.workspace),
        "session_id": state.session_id,
        "transcript": state.transcript,
        "tasks": state.sink.current,
        "allow_bash": state.allow_bash,
    }
    path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
    return path


def load_session(name):
    if not name or name == "latest":
        candidates = sorted(SESSION_ROOT.glob("*.json"),
                            key=lambda p: p.stat().st_mtime, reverse=True)
        if not candidates:
            raise FileNotFoundError("no saved sessions in ~/.loom/sessions/")
        path = candidates[0]
    else:
        path = SESSION_ROOT / f"{name}.json"
        if not path.is_file():
            raise FileNotFoundError(f"no such session: {name}")
    return json.loads(path.read_text(encoding="utf-8")), path.stem


def list_sessions():
    SESSION_ROOT.mkdir(parents=True, exist_ok=True)
    return sorted(SESSION_ROOT.glob("*.json"),
                  key=lambda p: p.stat().st_mtime, reverse=True)


# =============================================================================
# MCP client (stdio JSON-RPC, minimal viable)
# =============================================================================

class MCPClient:
    """Minimal Model Context Protocol client. Spawns the server as a
    subprocess, runs the `initialize` + `tools/list` handshake, and routes
    `tools/call` for any tool name the server advertises.

    This is intentionally bare: no resources, prompts, sampling, or
    notification handling. Enough to expose third-party MCP tools to the
    agent loop. Pass `--mcp "/path/to/server arg1 arg2"` once per server."""

    def __init__(self, command_line):
        self.command_line = command_line
        self.proc = None
        self.tools = []
        self.next_id = 1
        self._stdout_lock = threading.Lock()

    def start(self):
        try:
            self.proc = subprocess.Popen(
                self.command_line,
                shell=isinstance(self.command_line, str),
                stdin=subprocess.PIPE, stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=False, bufsize=0,
            )
        except OSError as e:
            raise RuntimeError(f"failed to launch MCP server '{self.command_line}': {e}")
        # Handshake
        self._send({"jsonrpc": "2.0", "id": self._id(), "method": "initialize",
                    "params": {"protocolVersion": "2024-11-05",
                               "capabilities": {}, "clientInfo": {
                                   "name": "lmstudio", "version": "1.0"}}})
        self._recv()  # initialize response (ignored)
        self._send({"jsonrpc": "2.0", "method": "notifications/initialized",
                    "params": {}})
        # Tool discovery
        self._send({"jsonrpc": "2.0", "id": self._id(),
                    "method": "tools/list", "params": {}})
        resp = self._recv()
        for t in (resp.get("result") or {}).get("tools", []):
            self.tools.append(t)

    def stop(self):
        if self.proc:
            try:
                self.proc.stdin.close()
            except OSError:
                pass
            try:
                self.proc.wait(timeout=1)
            except subprocess.TimeoutExpired:
                self.proc.kill()
        self.proc = None

    def call(self, name, arguments):
        with self._stdout_lock:
            self._send({"jsonrpc": "2.0", "id": self._id(),
                        "method": "tools/call",
                        "params": {"name": name, "arguments": arguments}})
            resp = self._recv()
        if "error" in resp:
            raise RuntimeError(resp["error"].get("message", "MCP error"))
        result = resp.get("result") or {}
        # MCP responses use a `content` array of typed blocks; we join the
        # text blocks for the agent's tool result.
        text_parts = []
        for block in result.get("content", []):
            if block.get("type") == "text":
                text_parts.append(block.get("text", ""))
        return "\n".join(text_parts) or json.dumps(result)

    def _id(self):
        self.next_id += 1
        return self.next_id - 1

    def _send(self, msg):
        if not self.proc or not self.proc.stdin:
            raise RuntimeError("MCP server not running")
        data = json.dumps(msg) + "\n"
        try:
            self.proc.stdin.write(data.encode("utf-8"))
            self.proc.stdin.flush()
        except BrokenPipeError:
            raise RuntimeError("MCP server stdin closed unexpectedly")

    def _recv(self):
        line = self.proc.stdout.readline()
        if not line:
            raise RuntimeError("MCP server closed stdout")
        return json.loads(line.decode("utf-8"))


def build_mcp_tool_schemas(clients):
    """Convert MCP tool definitions to OpenAI-style function tool schemas
    so the model sees them alongside our built-ins."""
    schemas = []
    for client in clients:
        for tool in client.tools:
            schemas.append({
                "type": "function",
                "function": {
                    "name": f"mcp__{tool['name']}",
                    "description": tool.get("description", ""),
                    "parameters": tool.get("inputSchema",
                                            {"type": "object", "properties": {}}),
                },
            })
    return schemas


def call_mcp_tool(clients, full_name, arguments):
    raw_name = full_name[len("mcp__"):]
    for client in clients:
        for tool in client.tools:
            if tool["name"] == raw_name:
                return client.call(raw_name, arguments)
    raise ValueError(f"no MCP server exposes tool {raw_name}")


# =============================================================================
# LM Studio HTTP
# =============================================================================

def _http_json(url, timeout=5):
    req = urllib.request.Request(url, headers={"Accept": "application/json"})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read().decode("utf-8"))


def fetch_model_context_window(base_url, model_id):
    """Ask LM Studio's /api/v0/models how big the loaded model's context
    is, so we can show "X / Y tok (Z%)" in the status footer like Claude
    Code does. Returns None on any failure - the footer just shows the
    raw token count when we don't know the cap.

    8.0.7: prefer `loaded_context_length` (the actual runtime capacity)
    over `max_context_length` (the model's hard cap from the GGUF). The
    two can differ wildly - e.g. a 262k-cap Gemma 4 model loaded with
    only 4k of context. The status footer should show what the model
    CAN ACCEPT, not what it could accept if reloaded."""
    info = fetch_model_info(base_url, model_id)
    if not info:
        return None
    ctx = (info.get("loaded_context_length")
           or info.get("context_length")
           or info.get("max_context_length"))
    if isinstance(ctx, int) and ctx > 0:
        return ctx
    return None


def fetch_model_info(base_url, model_id):
    """Return the full /api/v0/models entry for the named model id, or
    None when LM Studio doesn't expose v0 or the model isn't listed.
    Used by both context detection and auto-scaling."""
    base = base_url.rstrip("/")
    v0_url = (base[:-len("/v1")] + "/api/v0/models"
              if base.endswith("/v1") else base + "/api/v0/models")
    try:
        v0 = _http_json(v0_url)
    except (urllib.error.HTTPError, urllib.error.URLError, OSError):
        return None
    for entry in v0.get("data") or []:
        if entry.get("id") == model_id:
            return entry
    return None


def _locate_lms_cli():
    """Find the lms CLI. Standard install lives at ~/.lmstudio/bin/lms;
    PATH lookup is the fallback."""
    on_path = shutil.which("lms")
    if on_path:
        return on_path
    candidate = Path.home() / ".lmstudio" / "bin" / "lms"
    if candidate.is_file() and os.access(candidate, os.X_OK):
        return str(candidate)
    return None


# 8.0.14 — friendly install detection.
LMSTUDIO_DOWNLOAD_URL = "https://lmstudio.ai/"


def detect_lmstudio_installation(base_url):
    """Probe whether LM Studio is installed and reachable on this host.
    Returns a dict {installed, server_reachable, lms_cli_path,
    app_path}. Used at the top of the entrypoint to give friendly
    messages before any normal check fires.

    "Installed" is true when ANY of the standard markers exist:
        - the lms CLI on PATH or at ~/.lmstudio/bin/lms
        - the LM Studio macOS .app at /Applications/LM Studio.app
        - the user's ~/.lmstudio directory (LM Studio creates this
          on first launch even if the CLI helper hasn't been linked
          via `lms bootstrap` yet)
    """
    lms_cli = _locate_lms_cli()
    app_path = None
    for candidate in (
        Path("/Applications") / "LM Studio.app",
        Path.home() / "Applications" / "LM Studio.app",
    ):
        if candidate.is_dir():
            app_path = str(candidate)
            break
    lmstudio_dir = Path.home() / ".lmstudio"
    installed = bool(lms_cli or app_path or lmstudio_dir.is_dir())

    # Quick reachability check - HEAD-equivalent GET on /v1/models
    # with a short timeout. Don't raise; just record the result.
    server_reachable = False
    base = (base_url or "").rstrip("/")
    if base:
        try:
            req = urllib.request.Request(f"{base}/models",
                                          headers={"Accept": "application/json"})
            with urllib.request.urlopen(req, timeout=2) as resp:
                # Any 2xx means there's an OpenAI-compatible server.
                server_reachable = 200 <= resp.status < 300
        except (urllib.error.HTTPError, urllib.error.URLError, OSError):
            server_reachable = False

    return {
        "installed":        installed,
        "server_reachable": server_reachable,
        "lms_cli_path":     lms_cli,
        "app_path":         app_path,
    }


def print_lmstudio_missing_help(status, base_url):
    """Friendly multi-line message for users who run `lmstudio` without
    LM Studio installed or with the server cold. Goes to stderr."""
    if not status["installed"]:
        print(file=sys.stderr)
        print(style(
            "  LM Studio does not appear to be installed on this Mac.",
            "err"), file=sys.stderr)
        print(file=sys.stderr)
        print(style("  This CLI talks to LM Studio's local model server. "
                    "Install it from:", "warning"), file=sys.stderr)
        print(file=sys.stderr)
        print(f"    {style(LMSTUDIO_DOWNLOAD_URL, 'value')}",
              file=sys.stderr)
        print(file=sys.stderr)
        print(style(
            "  After install: open LM Studio, download a small (4B-class) "
            "tool-use model from inside the app (Discover tab), then "
            "re-run `lmstudio`. The CLI auto-loads a default model on "
            "first launch.", "dim"), file=sys.stderr)
        print(file=sys.stderr)
        return
    # Installed but server unreachable.
    print(file=sys.stderr)
    print(style(
        f"  LM Studio is installed but the local server isn't reachable "
        f"at {base_url}.", "err"), file=sys.stderr)
    print(file=sys.stderr)
    print(style("  Start it one of these ways:", "warning"), file=sys.stderr)
    print(file=sys.stderr)
    print(style("    1. Open LM Studio.app, click Developer in the left "
                "sidebar, then Local Server → Start.", "dim"),
          file=sys.stderr)
    if status["lms_cli_path"]:
        print(style(f"    2. Run: {style('lms server start', 'value')}",
                    "dim"), file=sys.stderr)
    else:
        print(style("    2. Or install the `lms` CLI helper: open LM "
                    "Studio, then run `~/.lmstudio/bin/lms bootstrap` to "
                    "add it to PATH.", "dim"), file=sys.stderr)
    print(file=sys.stderr)
    print(style("  Download LM Studio: " + LMSTUDIO_DOWNLOAD_URL, "dim"),
          file=sys.stderr)
    print(file=sys.stderr)


_OOM_HINTS = (
    "insufficient system resources",
    "would likely overload",
    "out of memory",
    "vram",
    "ggml_metal",
    "metalbuffer_new",
    "failed to load model",
)


def auto_scale_context(base_url, model_id, target_minimum,
                       max_target=32768, gpu="max", parallel=1):
    """If the model's loaded_context_length is below target_minimum AND
    its max_context_length supports more, reload via the `lms` CLI with
    a larger context. Returns (success, message, new_context).

    8.0.8: always unload-then-load and force `--parallel 1` on the
    reload. The default LM Studio JIT load uses parallel=4 which
    multiplies the KV cache by 4 - on Apple Silicon unified memory,
    that single setting is the difference between a 4k context fitting
    AND a 128k context fitting at exactly the same memory footprint
    (KV cache is 4x smaller per slot). The agent only runs one
    completion at a time anyway, so the user gives up nothing.

    OOM-retry ladder: 100% -> 75% -> 50% -> 33% -> 25% of initial
    target. Stops at the first successful load. Non-OOM errors (bad
    model id, server cold) abort immediately - no point retrying.

    Final verification compares the API's reported
    loaded_context_length AFTER reload against the prior value, so a
    `lms` exit-0 with no actual context change is treated as
    inconclusive rather than success."""
    info = fetch_model_info(base_url, model_id)
    if not info:
        return False, "could not query /api/v0/models", None
    loaded = info.get("loaded_context_length")
    cap = info.get("max_context_length")
    current_parallel = info.get("parallel") or info.get("max_parallel") or None
    if not isinstance(loaded, int) or loaded <= 0:
        return False, ("loaded_context_length unavailable; LM Studio "
                        "may be too old"), None
    # 8.0.8: even if loaded >= target, force-reload when parallel > 1
    # and we can squeeze a much bigger context out by dropping parallel.
    # Otherwise short-circuit.
    can_dramatic_bump = (isinstance(cap, int) and cap > loaded * 2
                         and (current_parallel or 1) > 1)
    if loaded >= target_minimum and not can_dramatic_bump:
        return True, (f"loaded context is {loaded} (>= target "
                      f"{target_minimum}); no reload needed"), loaded
    if isinstance(cap, int) and cap > 0:
        upper = min(max_target, cap)
    else:
        upper = max_target
    # With parallel=1 the KV cache is small enough that we can usually
    # take a big jump. Initial target = full max_target (capped to model
    # cap), not just 4x current. The ladder steps back if that fails.
    initial_target = max(target_minimum, upper)
    if initial_target <= loaded:
        return False, (f"no headroom: loaded {loaded}, "
                       f"max_target {max_target}, cap {cap}"), loaded
    lms_cmd = _locate_lms_cli()
    if not lms_cmd:
        return False, "`lms` CLI not found at ~/.lmstudio/bin/lms or on PATH", loaded
    candidates = []
    for frac in (1.0, 0.75, 0.5, 0.33, 0.25):
        c = max(loaded + 1, int(initial_target * frac))
        c = (c // 1024) * 1024 if c >= 1024 else c
        if c > loaded and c not in candidates:
            candidates.append(c)
    # Unload the existing instance first so the reload reclaims its
    # identifier (otherwise lms appends ":2" / ":3" / ...) and we don't
    # double-instance the model in memory.
    try:
        subprocess.run([lms_cmd, "unload", model_id],
                       capture_output=True, timeout=30)
    except subprocess.TimeoutExpired:
        pass  # if unload hangs, try the load anyway
    last_error = ""
    for cand in candidates:
        cmd = [lms_cmd, "load", model_id, "-c", str(cand), "-y",
               "--parallel", str(parallel)]
        if gpu:
            cmd.extend(["--gpu", gpu])
        try:
            proc = subprocess.run(cmd, capture_output=True, timeout=240)
        except subprocess.TimeoutExpired:
            last_error = f"timeout at {cand}"
            continue
        if proc.returncode == 0:
            after = fetch_model_info(base_url, model_id)
            new_loaded = (after.get("loaded_context_length")
                          if after else None)
            if isinstance(new_loaded, int) and new_loaded > loaded:
                tag = (f" (requested {cand})" if new_loaded != cand
                       else "")
                return True, (f"context bumped {loaded} -> {new_loaded}"
                              + tag + f", parallel={parallel}"), new_loaded
            # lms returned 0 but the API didn't reflect a change. Try
            # the next candidate rather than reporting a phantom success.
            last_error = (f"lms exit 0 at {cand} but loaded still "
                          f"{new_loaded}")
            continue
        err_raw = (proc.stderr or b"").decode("utf-8", "replace")
        err_low = err_raw.lower()
        last_error = err_raw.strip()[:200]
        if any(h in err_low for h in _OOM_HINTS):
            continue
        # Try to re-load the original size so the user isn't left with
        # nothing loaded after a non-OOM failure.
        try:
            subprocess.run(
                [lms_cmd, "load", model_id, "-c", str(loaded), "-y",
                 "--parallel", str(parallel)],
                capture_output=True, timeout=120)
        except Exception:
            pass
        return False, f"lms load failed: {last_error}", loaded
    # All candidates exhausted. Try to leave the model in its prior
    # loaded state so the user can still run a session.
    try:
        subprocess.run(
            [lms_cmd, "load", model_id, "-c", str(loaded), "-y",
             "--parallel", str(parallel)],
            capture_output=True, timeout=120)
    except Exception:
        pass
    return False, (f"all targets exhausted; smallest tried "
                   f"{candidates[-1] if candidates else '?'}; "
                   f"last error: {last_error}"), loaded


def fetch_available_models(*, local_only=True, tool_use_only=True):
    """8.0.13: enumerate LLMs on disk via `lms ls --json`. Returns a
    list of normalized dicts with the fields we actually use:

        {"key", "paramsB", "context", "arch", "local", "tool_use",
         "size_bytes"}

    `paramsB` is the parsed parameter count from `paramsString` ("31B"
    -> 31, "26B-A4B" -> 4 (the active-experts count for MoE), "4B" -> 4).
    For MoE models we prefer the active-params number because that's
    what matters for inference cost.

    local_only filters to deviceIdentifier=null (the host LM Studio
    rather than LM Link remotes). tool_use_only drops checkpoints
    without `trainedForToolUse: true`."""
    lms_cmd = _locate_lms_cli()
    if not lms_cmd:
        return []
    try:
        proc = subprocess.run([lms_cmd, "ls", "--json"],
                              capture_output=True, timeout=15)
    except (subprocess.TimeoutExpired, OSError):
        return []
    if proc.returncode != 0:
        return []
    try:
        data = json.loads(proc.stdout.decode("utf-8", "replace"))
    except json.JSONDecodeError:
        return []
    out = []
    for entry in data if isinstance(data, list) else []:
        if entry.get("type") != "llm":
            continue
        if local_only and entry.get("deviceIdentifier") is not None:
            continue
        if tool_use_only and not entry.get("trainedForToolUse"):
            continue
        params = entry.get("paramsString") or ""
        params_b = _parse_params_string(params)
        out.append({
            "key":        entry.get("modelKey") or entry.get("path", ""),
            "paramsB":    params_b,
            "context":    entry.get("maxContextLength") or 0,
            "arch":       entry.get("architecture") or "",
            "local":      entry.get("deviceIdentifier") is None,
            "tool_use":   bool(entry.get("trainedForToolUse")),
            "size_bytes": entry.get("sizeBytes") or 0,
            "params_raw": params,
        })
    return out


def _parse_params_string(s):
    """Parse paramsString like "31B", "26B-A4B", "4B" into a small int
    that represents inference cost. For MoE models in "<total>B-A<active>B"
    format we prefer the active-experts number since that's what dictates
    speed. Returns None when unparseable."""
    if not s:
        return None
    s = s.strip().upper()
    # MoE: "26B-A4B" => active 4
    m = re.match(r"\d+\.?\d*B-A(\d+\.?\d*)B?$", s)
    if m:
        try:
            return int(float(m.group(1)))
        except ValueError:
            pass
    # Plain: "31B" or "7.5B"
    m = re.match(r"(\d+\.?\d*)B$", s)
    if m:
        try:
            return int(float(m.group(1)))
        except ValueError:
            pass
    return None


_CODER_FAMILY_HINTS = re.compile(
    r"(?:^|\W)(qwen|deepseek|codestral|coder|stable.?code|yi.?coder|"
    r"magicoder|wizardcoder|starcoder|granite.?code|code(?:llama|gemma))",
    re.I,
)


def _coder_score(model):
    """Return 0 when the model's key or architecture suggests strong
    coding ability, 1 otherwise. Used as the primary tie-break in
    pick_default_model so the user gets a coder-class default when
    available (Qwen, DeepSeek, Codestral, etc.) over a generalist
    same-size model (Gemma, Mistral, Phi)."""
    key = model.get("key") or ""
    arch = model.get("arch") or ""
    return 0 if (_CODER_FAMILY_HINTS.search(key)
                  or _CODER_FAMILY_HINTS.search(arch)) else 1


def pick_default_model(models, *, prefer_b=7, max_b=12):
    """Choose the best auto-load default. Scoring (lower better):
      1. coder-family bias (qwen/deepseek/codestral etc. score 0,
         others 1). Primary factor - a 9B qwen beats a 7B gemma.
      2. closeness to prefer_b (distance from preferred size).
      3. total file size on disk (4B dense model beats a 26B-A4B
         MoE that shares active-params count).
      4. alphabetical key for determinism.

    Returns the model key or None when nothing fits."""
    candidates = []
    for m in models:
        b = m.get("paramsB")
        if not isinstance(b, int) or b < 1 or b > max_b:
            continue
        score = (
            _coder_score(m),
            abs(b - prefer_b),
            m.get("size_bytes") or 0,
            m.get("key", ""),
        )
        candidates.append((score, m["key"]))
    if not candidates:
        return None
    candidates.sort()
    return candidates[0][1]


def auto_load_dual_models(base_url, *, planner_b=4, coder_b=9, max_b=12,
                           ctx=16384, parallel=1, gpu="max"):
    """8.0.19: load BOTH a small fast planner model and a stronger coder
    model simultaneously, so per-turn routing has something to actually
    route between. Returns (planner_id, coder_id) - either can be None
    if loading that role failed (typically due to memory constraint).

    The trade-off: dual-loading uses more memory (~9GB for 4B+9B Q4
    GGUFs on top of the runtime) but enables Claude-style per-turn
    model routing. Most coding sessions become noticeably better
    because the coder model handles tool sequences while the planner
    handles narration/Q&A turns quickly.

    On OOM during the second load, returns (None, coder_id) so the
    session continues on the single model. Caller decides what to do.

    Memory floor is the coder model itself; the planner is the bonus.
    If the user's machine can't fit even the coder, callers should
    fall back to auto_load_default_model with a smaller target."""
    available = fetch_available_models()
    if not available:
        return None, None, "no available models on disk"
    # Pick the coder first using the existing logic (coder-bias).
    coder = pick_default_model(available, prefer_b=coder_b, max_b=max_b)
    if not coder:
        return None, None, f"no model in 1-{max_b}B range"
    # Pick the planner from the remaining candidates. Use a tighter
    # max so we genuinely get a small fast model, not another mid-size.
    planner_candidates = [m for m in available if m["key"] != coder]
    planner = pick_default_model(planner_candidates,
                                  prefer_b=planner_b,
                                  max_b=planner_b + 2)
    lms_cmd = _locate_lms_cli()
    if not lms_cmd:
        return None, None, "`lms` CLI not found"
    # Wipe existing loads first so we don't fight stale identifiers.
    try:
        subprocess.run([lms_cmd, "unload", "--all"],
                       capture_output=True, timeout=30)
    except subprocess.TimeoutExpired:
        pass
    # Load coder (bigger, takes longer).
    cmd_coder = [lms_cmd, "load", coder, "-y",
                 "--parallel", str(parallel), "-c", str(ctx)]
    if gpu:
        cmd_coder.extend(["--gpu", gpu])
    try:
        proc = subprocess.run(cmd_coder, capture_output=True, timeout=240)
    except subprocess.TimeoutExpired:
        return None, None, f"timeout loading coder {coder}"
    if proc.returncode != 0:
        err = (proc.stderr or b"").decode("utf-8", "replace")[:200]
        return None, None, f"coder load failed: {err}"
    if not planner:
        return None, coder, f"coder {coder} loaded; no planner candidate"
    # Load planner alongside.
    cmd_planner = [lms_cmd, "load", planner, "-y",
                   "--parallel", str(parallel), "-c", str(ctx)]
    if gpu:
        cmd_planner.extend(["--gpu", gpu])
    try:
        proc = subprocess.run(cmd_planner, capture_output=True, timeout=180)
    except subprocess.TimeoutExpired:
        return None, coder, f"coder {coder} loaded; planner timed out"
    if proc.returncode != 0:
        err = (proc.stderr or b"").decode("utf-8", "replace")[:200]
        err_low = err.lower()
        if any(h in err_low for h in _OOM_HINTS):
            return None, coder, (f"coder {coder} loaded; planner "
                                  f"{planner} skipped (insufficient RAM)")
        return None, coder, f"coder loaded; planner load failed: {err}"
    return planner, coder, (f"dual-loaded planner={planner} + "
                             f"coder={coder} at {ctx}-tok context")


def auto_load_default_model(base_url, *, prefer_b=7, max_b=12,
                             ctx=16384, parallel=1, gpu="max"):
    """When LM Studio has no model loaded, pick the smallest tool-use
    model on disk and load it. Returns (key, message). On any failure
    returns (None, reason) so the caller can decide whether to error
    out or just keep going."""
    available = fetch_available_models()
    if not available:
        return None, "no models on disk that are local + tool-use trained"
    chosen = pick_default_model(available, prefer_b=prefer_b, max_b=max_b)
    if not chosen:
        sizes = sorted({m.get("paramsB") for m in available
                        if m.get("paramsB")})
        return None, (f"no model in 1-{max_b}B range available; sizes "
                      f"on disk: {sizes}")
    lms_cmd = _locate_lms_cli()
    if not lms_cmd:
        return None, "lms CLI not found"
    cmd = [lms_cmd, "load", chosen, "-y",
           "--parallel", str(parallel), "-c", str(ctx)]
    if gpu:
        cmd.extend(["--gpu", gpu])
    try:
        proc = subprocess.run(cmd, capture_output=True, timeout=180)
    except subprocess.TimeoutExpired:
        return None, f"lms load {chosen} timed out"
    if proc.returncode != 0:
        err = (proc.stderr or b"").decode("utf-8", "replace")[:200]
        return None, f"lms load {chosen} failed: {err}"
    return chosen, f"auto-loaded {chosen} ({ctx}-tok context, parallel=1)"


def fetch_loaded_models(base_url):
    """List currently *loaded* model ids. Tries LM Studio's /api/v0/models
    first (state-aware), falls back to OpenAI-compatible /v1/models."""
    base = base_url.rstrip("/")
    v0_url = (base[:-len("/v1")] + "/api/v0/models"
              if base.endswith("/v1") else base + "/api/v0/models")
    try:
        v0 = _http_json(v0_url)
        data = v0.get("data") or []
        loaded = [e["id"] for e in data if e.get("state") == "loaded" and "id" in e]
        if loaded:
            return loaded
        if data:
            return []
    except urllib.error.HTTPError:
        pass
    except urllib.error.URLError as e:
        raise RuntimeError(
            f"Could not reach LM Studio at {base_url}. "
            f"Start the server: LM Studio > Developer > Local Server > Start.\n"
            f"Underlying error: {e.reason}") from None
    try:
        v1 = _http_json(f"{base}/models")
    except urllib.error.URLError as e:
        raise RuntimeError(f"Could not reach LM Studio at {base_url}.\n"
                           f"Underlying error: {e.reason}") from None
    data = v1.get("data") or []
    return [entry["id"] for entry in data if "id" in entry]


# =============================================================================
# Model adapters  (8.0.5)
# =============================================================================
#
# Different model families served by LM Studio have different conventions for
# tool calling, reasoning content, and chat-template quirks. The adapter
# detects the family from the model id (heuristic) and exposes a uniform
# surface for the rest of the agent:
#
#   - native_tools: whether the model server emits `tool_calls` in the
#     streamed message structure. When False (Gemma, base Llama, Phi-3),
#     the agent falls through to TEXT EXTRACTION: it parses tool calls out
#     of the assistant's free-text response in any of several common wire
#     formats. Text fallback is always on (even for native-tool families)
#     so a model that occasionally narrates a tool call as JSON-in-text
#     instead of emitting the structured field still does useful work.
#
#   - uses_reasoning_content: Qwen3-thinking and DeepSeek-R1 route their
#     output through `reasoning_content` instead of `content`. We already
#     merge both in stream_completion; this flag is informational, used
#     by `/model-info` for the user.
#
#   - system_addendum(): family-specific addition to the system prompt,
#     describing how to emit tool calls for models without native support.
#
#   - default_essential_only(): True for small / less-reliable families
#     so the runtime tool schema stays tight and the chat template fits
#     the model's actual context window.

TEXT_TOOL_INSTRUCTIONS = """\
# CRITICAL: TOOL CALL FORMAT (read this FIRST)

Your runtime does NOT support native tool calling. To take any action -
creating a file, reading a file, running a command, marking a task done,
anything - you MUST emit your tool invocation as a fenced JSON block in
the assistant response. The orchestrator parses these and runs them.

## How to invoke a tool

End your response with EXACTLY one fenced block in this format:

```tool_call
{"name": "<tool_name>", "arguments": {<args_object>}}
```

Then STOP. Do not narrate further. The orchestrator will run the call,
feed the result back to you, and you'll continue on the next turn.

## Complete worked example

If the user asks "create a Python hello world", your ENTIRE response
should be:

I'll create hello.py now.

```tool_call
{"name": "write_file", "arguments": {"path": "hello.py", "content": "print('hello, world')\\n"}}
```

That is it. One sentence of preface (optional). One tool_call block.
Stop.

## Anti-patterns - DO NOT do any of these

- Writing a multi-step plan as prose ("Step 1: Create folder. Step 2:
  Initialize project. Step 3: ..."). Plans are for `update_tasks` only.
- Listing "Commands to Execute" in markdown. These get ignored - they
  are not tool calls, just text the orchestrator throws away.
- Describing what the tool will do. Just emit the call.
- Ending the response without a ```tool_call block when the user wants
  you to actually do something. A response with no tool call is a wasted
  turn - the orchestrator will nudge you to retry immediately.
- More than one tool_call block per response. The orchestrator runs
  the FIRST one and ignores the rest.

## The tool catalogue is in the system prompt below

Use ONLY the tool names listed there. Common ones:

- `write_file({"path": "...", "content": "..."})` - create/overwrite a file
- `edit_file({"path": "...", "old_string": "...", "new_string": "..."})` - surgical edit
- `read_file({"path": "..."})` - read a file
- `list_dir({"path": "..."})` - list a directory
- `run_bash({"command": "..."})` - shell command (when --allow-bash is on)
- `update_tasks({"tasks": [{"subject": "...", "activeForm": "...", "status": "pending"}, ...]})` - plan tracker

Make ONE call per response. Wait for the result. Then the next call.
"""


class ModelAdapter:
    """Per-family quirks. Detected from the model id, refined by runtime
    behavior. Centralizes "what does this model need" so the rest of the
    agent doesn't sprinkle family checks everywhere."""

    FAMILY_PATTERNS = [
        (re.compile(r"qwen.?3", re.I),            "qwen3"),
        (re.compile(r"qwen.?2\.?5.?coder", re.I), "qwen-coder"),
        (re.compile(r"qwen", re.I),               "qwen"),
        (re.compile(r"deepseek.?r1", re.I),       "deepseek-r1"),
        (re.compile(r"deepseek.?coder", re.I),    "deepseek-coder"),
        (re.compile(r"deepseek", re.I),           "deepseek"),
        (re.compile(r"codestral", re.I),          "codestral"),
        (re.compile(r"mistral", re.I),            "mistral"),
        (re.compile(r"llama.?3\.[12]", re.I),     "llama3"),
        (re.compile(r"llama.?3\.3", re.I),        "llama3"),
        (re.compile(r"llama", re.I),              "llama"),
        (re.compile(r"gemma.?3", re.I),           "gemma3"),
        (re.compile(r"gemma", re.I),              "gemma"),
        (re.compile(r"phi.?3\.5", re.I),          "phi35"),
        (re.compile(r"phi.?4", re.I),             "phi4"),
        (re.compile(r"phi", re.I),                "phi"),
        (re.compile(r"granite", re.I),            "granite"),
        (re.compile(r"hermes", re.I),             "hermes"),
        (re.compile(r"yi.?coder", re.I),          "yi-coder"),
    ]

    # Each row: (native_tools, uses_reasoning, default_essential_only).
    CAPABILITIES = {
        "qwen3":          (True,  True,  False),
        "qwen-coder":     (True,  False, False),
        "qwen":           (True,  False, False),
        "deepseek-r1":    (True,  True,  False),
        "deepseek-coder": (True,  False, False),
        "deepseek":       (True,  False, False),
        "codestral":      (True,  False, False),
        "mistral":        (True,  False, False),
        "llama3":         (True,  False, False),
        "llama":          (False, False, True),
        "gemma3":         (False, False, True),
        "gemma":          (False, False, True),
        "phi35":          (True,  False, True),
        "phi4":           (True,  False, True),
        "phi":            (False, False, True),
        "granite":        (True,  False, True),
        "hermes":         (True,  False, False),
        "yi-coder":       (True,  False, False),
        "unknown":        (True,  False, False),
    }

    def __init__(self, model_id):
        self.model_id = model_id or ""
        self.family = self._detect_family(self.model_id)
        native, reasoning, essential = self.CAPABILITIES[self.family]
        self.native_tools = native
        self.uses_reasoning = reasoning
        self.default_essential_only = essential

    @classmethod
    def _detect_family(cls, model_id):
        if not model_id:
            return "unknown"
        for rx, family in cls.FAMILY_PATTERNS:
            if rx.search(model_id):
                return family
        return "unknown"

    def system_addendum(self):
        """Family-specific note appended to the system prompt. Only emitted
        for families without reliable native tool calling, since those
        models need explicit instructions to format their tool calls as
        text that we can parse back out."""
        if self.native_tools:
            return ""
        return TEXT_TOOL_INSTRUCTIONS

    def parse_tool_calls_from_text(self, text, schema_names):
        """Scan assistant free-text for JSON-shaped tool calls. Always-on
        fallback - even native-tool families occasionally narrate a call
        as JSON-in-text on tricky prompts. schema_names is the set of
        valid tool names; anything outside the set is rejected so prose
        containing `"name":` doesn't accidentally match.

        Returns a list of {id, name, arguments} dicts shaped like
        stream_completion's `tool_call` yield."""
        if not text:
            return []
        calls = []
        seen_payloads = set()

        def push(parsed):
            if not parsed:
                return
            key = (parsed["name"], parsed["arguments"])
            if key in seen_payloads:
                return
            seen_payloads.add(key)
            calls.append(parsed)

        # Pattern 1: <tool_call>{...}</tool_call> or <function_call>{...}</function_call>.
        for m in re.finditer(
                r"<(?:tool_call|function_call|tool)>\s*(\{.*?\})\s*"
                r"</(?:tool_call|function_call|tool)>",
                text, re.DOTALL | re.IGNORECASE):
            push(_try_parse_tool_call_json(m.group(1), schema_names))

        # Pattern 2: fenced JSON / tool_call blocks (Gemma's preferred
        # format under TEXT_TOOL_INSTRUCTIONS, plus generic ```json```).
        for m in re.finditer(
                r"```(?:tool_call|tool_calls|json|function|function_call)?\s*"
                r"(\{.*?\}|\[.*?\])\s*```",
                text, re.DOTALL | re.IGNORECASE):
            body = m.group(1).strip()
            # The body might be a wrapper {"tool_calls": [...]}, a single
            # call object, or a bare list of calls.
            try:
                obj = json.loads(body)
            except json.JSONDecodeError:
                continue
            if isinstance(obj, dict) and isinstance(obj.get("tool_calls"), list):
                for entry in obj["tool_calls"]:
                    push(_try_parse_tool_call_json(json.dumps(entry),
                                                  schema_names))
            elif isinstance(obj, dict):
                push(_try_parse_tool_call_json(body, schema_names))
            elif isinstance(obj, list):
                for entry in obj:
                    if isinstance(entry, dict):
                        push(_try_parse_tool_call_json(json.dumps(entry),
                                                      schema_names))

        # Pattern 3: trailing bare JSON object. Last-resort - only fires
        # when nothing else matched, to avoid double-counting calls that
        # were already captured by patterns 1 or 2.
        if not calls:
            m = re.search(
                r"(\{[^{}]*\"(?:name|tool|function)\"\s*:\s*\"\w+\"[^{}]*"
                r"(?:\{[^{}]*\}[^{}]*)*\})\s*\Z",
                text, re.DOTALL)
            if m:
                push(_try_parse_tool_call_json(m.group(1), schema_names))

        return calls


def _estimate_model_billions(model_id):
    """Pull the parameter count from a model id like `foo-31b` or
    `qwen2.5-coder-7b-instruct`. Returns int billions, or None. Used
    by auto-routing to pick the smallest loaded model as planner."""
    if not model_id:
        return None
    m = re.search(r"(?:^|[\W_])(\d{1,3})(?:\.\d+)?\s*b\b",
                  model_id.lower())
    if m:
        try:
            return int(m.group(1))
        except ValueError:
            return None
    return None


def _try_parse_tool_call_json(body, schema_names):
    """Parse a JSON string into the canonical {id, name, arguments} shape.
    Returns None when the body doesn't actually look like a tool call -
    name missing, name unknown, or arguments un-JSON-able."""
    try:
        obj = json.loads(body)
    except (json.JSONDecodeError, TypeError):
        return None
    if not isinstance(obj, dict):
        return None
    name = (obj.get("name") or obj.get("tool")
            or obj.get("function") or obj.get("tool_name"))
    if not isinstance(name, str) or name not in schema_names:
        return None
    args = (obj.get("arguments") or obj.get("parameters")
            or obj.get("args") or obj.get("input") or {})
    if isinstance(args, str):
        try:
            args = json.loads(args)
        except json.JSONDecodeError:
            return None
    if not isinstance(args, dict):
        return None
    return {
        "id": f"text_call_{uuid.uuid4().hex[:10]}",
        "name": name,
        "arguments": json.dumps(args),
    }


# =============================================================================
# Streaming word-wrap
# =============================================================================

class StreamingWrapper:
    """Word-boundary wrap for streamed output. Buffers each word until
    whitespace/newline arrives, then flushes with an inserted newline if
    placing the word would overflow the right margin. ANSI escape codes
    pass through transparently and don't count toward column position.

    Designed for the model's streamed content: each delta might be a few
    tokens or a single character, so we keep a column cursor across feeds.
    Falls back to passthrough when `enabled=False` so the terminal's hard
    wrap takes over."""

    _ANSI_RE = re.compile(r"\033\[[0-9;]*m")

    def __init__(self, get_width, enabled=True):
        self.get_width = get_width
        self.enabled = enabled
        self.column = 0
        self.word = ""

    def feed(self, chunk):
        if not self.enabled:
            self.column = self._visible_advance(self.column, chunk)
            return chunk
        out = []
        i = 0
        while i < len(chunk):
            m = self._ANSI_RE.match(chunk, i)
            if m:
                out.append(m.group(0))
                i = m.end()
                continue
            ch = chunk[i]
            if ch == "\n":
                if self.word:
                    out.append(self._flush_word())
                out.append("\n")
                self.column = 0
            elif ch in " \t":
                if self.word:
                    out.append(self._flush_word())
                # Only emit whitespace when we're past column 0 - leading
                # spaces on a wrapped line look like accidental indent.
                if self.column > 0:
                    if self.column + 1 >= self.get_width():
                        out.append("\n")
                        self.column = 0
                    else:
                        out.append(ch)
                        self.column += 1
            else:
                self.word += ch
            i += 1
        return "".join(out)

    def finish(self):
        if self.word:
            return self._flush_word()
        return ""

    def reset_column(self, value=0):
        self.column = value
        self.word = ""

    def _flush_word(self):
        word = self.word
        self.word = ""
        word_len = len(self._ANSI_RE.sub("", word))
        width = self.get_width()
        if self.column > 0 and self.column + word_len > width:
            self.column = word_len
            return "\n" + word
        self.column += word_len
        return word

    @classmethod
    def _visible_advance(cls, column, text):
        stripped = cls._ANSI_RE.sub("", text)
        if "\n" in stripped:
            tail = stripped.rsplit("\n", 1)[-1]
            return len(tail)
        return column + len(stripped)


# =============================================================================
# Think-tag streaming
# =============================================================================

class ThinkStreamer:
    """Renders streamed assistant text, dimming content between
    <think>...</think>. Markers can split across chunks, so we keep a
    small tail buffer and only commit characters we know aren't part of
    a partial marker. Quiet mode skips stdout (used by --json)."""

    OPEN = "<think>"
    CLOSE = "</think>"

    def __init__(self, quiet=False, emit_event=None, wrap=True):
        self.in_think = False
        self.buf = ""
        self.full = []
        self._started_line = False
        self.quiet = quiet
        self.emit_event = emit_event or (lambda *a, **kw: None)
        # Width for wrapping - use the real terminal width (not the box
        # cap) so model output gets the full screen, just wrapped at word
        # boundaries instead of mid-token.
        self._wrapper = StreamingWrapper(
            get_width=lambda: max(40, term_width() - 2),
            enabled=wrap and not quiet,
        )

    def feed(self, chunk):
        if not chunk:
            return
        self.full.append(chunk)
        self.buf += chunk
        keep = max(len(self.OPEN), len(self.CLOSE))
        while True:
            if self.in_think:
                idx = self.buf.find(self.CLOSE)
                if idx == -1:
                    if len(self.buf) > keep:
                        emit = self.buf[:-keep]
                        self._emit_think(emit)
                        self.buf = self.buf[-keep:]
                    return
                self._emit_think(self.buf[:idx])
                self.buf = self.buf[idx + len(self.CLOSE):]
                self.in_think = False
                if self._started_line and not self.quiet:
                    sys.stdout.write("\n")
                    self._started_line = False
            else:
                idx = self.buf.find(self.OPEN)
                if idx == -1:
                    if len(self.buf) > keep:
                        emit = self.buf[:-keep]
                        self._emit_plain(emit)
                        self.buf = self.buf[-keep:]
                    return
                self._emit_plain(self.buf[:idx])
                self.buf = self.buf[idx + len(self.OPEN):]
                self.in_think = True
                if self._started_line and not self.quiet:
                    sys.stdout.write("\n")
                    self._started_line = False
                if not self.quiet:
                    sys.stdout.write(style(f"  {GLYPH_THINK} ", "thinking"))

    def finish(self):
        if self.buf:
            if self.in_think:
                self._emit_think(self.buf)
            else:
                self._emit_plain(self.buf)
            self.buf = ""
        tail = self._wrapper.finish()
        if tail and not self.quiet:
            sys.stdout.write(tail)
        if self.in_think and not self.quiet:
            sys.stdout.write("\n")
            self.in_think = False
        if self._started_line and not self.quiet:
            sys.stdout.write("\n")
            self._started_line = False
        if not self.quiet:
            sys.stdout.flush()
        return "".join(self.full)

    def _emit_plain(self, text):
        if not text:
            return
        self.emit_event("content", text=text)
        if self.quiet:
            return
        sys.stdout.write(self._wrapper.feed(text))
        sys.stdout.flush()
        self._started_line = not text.endswith("\n")

    def _emit_think(self, text):
        if not text:
            return
        self.emit_event("thinking", text=text)
        if self.quiet:
            return
        rendered = text.replace("\n", "\n  " + style(GLYPH_THINK + " ", "thinking"))
        styled = style(rendered, "thinking")
        sys.stdout.write(self._wrapper.feed(styled))
        sys.stdout.flush()
        self._started_line = not text.endswith("\n")


def _extract_grammar_payload(message):
    """Pull grammar-constrained JSON text out of an assistant message.
    Thinking models (Qwen3, DeepSeek-R1) sometimes route the entire
    response through `reasoning_content` while leaving `content` empty -
    the JSON's still schema-valid, we just have to look in two places."""
    if not isinstance(message, dict):
        return ""
    for key in ("content", "reasoning_content"):
        val = message.get(key)
        if isinstance(val, str) and val.strip():
            return val.strip()
    return ""


GRAMMAR_PROBE_CACHE_DIR = Path.home() / ".loom" / "cache" / "grammar"
GRAMMAR_PROBE_CACHE_TTL = 7 * 24 * 3600  # 7 days


def _grammar_probe_cache_path(base_url, model):
    """One cache file per (base_url, model) pair. Sanitize the model id
    so it works as a filename on every platform we ship on."""
    safe = re.sub(r"[^A-Za-z0-9._-]", "_", f"{base_url}__{model}")
    return GRAMMAR_PROBE_CACHE_DIR / f"{safe[:120]}.json"


def _grammar_probe_cached(base_url, model):
    """Return cached probe result if fresh, else None."""
    path = _grammar_probe_cache_path(base_url, model)
    if not path.is_file():
        return None
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    if not isinstance(data, dict):
        return None
    ts = data.get("ts", 0)
    if time.time() - ts > GRAMMAR_PROBE_CACHE_TTL:
        return None
    return bool(data.get("supported", False))


def _grammar_probe_save(base_url, model, supported):
    """Persist a probe result. Best-effort; cache miss next time on
    write failure is fine."""
    try:
        GRAMMAR_PROBE_CACHE_DIR.mkdir(parents=True, exist_ok=True)
        path = _grammar_probe_cache_path(base_url, model)
        path.write_text(json.dumps({
            "ts": int(time.time()),
            "model": model,
            "base_url": base_url,
            "supported": bool(supported),
        }), encoding="utf-8")
    except OSError:
        pass


def probe_grammar_support(base_url, model, *, use_cache=True):
    """Ask LM Studio for a tiny structured response with a json_schema
    response_format. Returns True if the server accepts it, False otherwise
    (older servers, non-LM-Studio backends, MLX kernels without grammar).

    8.0.12: results are cached to ~/.loom/cache/grammar/<key>.json with a
    7-day TTL. Subsequent sessions with the same model skip the 5-10s
    startup probe entirely. Pass use_cache=False to force a fresh probe.

    Disabled entirely when LMSTUDIO_NO_GRAMMAR=1 is set."""
    if os.environ.get("LMSTUDIO_NO_GRAMMAR") == "1":
        return False
    if use_cache:
        cached = _grammar_probe_cached(base_url, model)
        if cached is not None:
            return cached
    payload = {
        "model": model,
        "messages": [{"role": "user", "content":
            "Reply with valid JSON matching the schema."}],
        "max_tokens": 64,
        "stream": False,
        "response_format": {
            "type": "json_schema",
            "json_schema": {
                "name": "lmstudio_grammar_probe",
                "schema": {
                    "type": "object",
                    "properties": {"ok": {"type": "boolean"}},
                    "required": ["ok"],
                    "additionalProperties": False,
                },
                "strict": True,
            },
        },
    }
    req = urllib.request.Request(
        f"{base_url.rstrip('/')}/chat/completions",
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            body = resp.read().decode("utf-8", errors="replace")
        parsed = json.loads(body)
    except (urllib.error.HTTPError, urllib.error.URLError, OSError,
            json.JSONDecodeError):
        return False
    try:
        message = parsed["choices"][0]["message"]
    except (KeyError, IndexError, TypeError):
        return False
    text = _extract_grammar_payload(message)
    if not text:
        return False
    try:
        result = json.loads(text)
    except (TypeError, json.JSONDecodeError):
        return False
    supported = isinstance(result, dict) and "ok" in result
    _grammar_probe_save(base_url, model, supported)
    return supported


def force_grammar_args(base_url, model, transcript, tool_name, tool_schema,
                       partial_args, narration, workspace):
    """Make a non-streaming completion with strict JSON schema output, asking
    the model to fill in the args for a specific tool. Returns the parsed
    args dict on success, or None on any failure.

    Grammar-constrained generation refuses to produce JSON that violates the
    schema, so a successful return is guaranteed to have all required
    fields. Used by the dispatcher as a last-resort fallback when the model
    keeps emitting tool calls with missing required arguments."""
    # Constrain to a strict object schema so the server-side decoder rejects
    # missing required keys.
    strict = dict(tool_schema) if isinstance(tool_schema, dict) else {}
    if strict.get("type") == "object":
        strict.setdefault("additionalProperties", False)
        # `strict: true` on OpenAI / LM Studio requires every property to
        # also appear in `required`. Force that to avoid 400s.
        props = strict.get("properties") or {}
        strict["required"] = sorted(props.keys())

    # Carve down the transcript a bit so we don't pay for huge contexts on a
    # one-shot helper call. Keep system + last ~10 turns.
    trimmed = []
    if transcript and transcript[0].get("role") == "system":
        trimmed.append(transcript[0])
    trimmed.extend(transcript[-10:])

    partial_dump = json.dumps(partial_args, indent=2) if partial_args else "{}"
    forced_messages = list(trimmed) + [{
        "role": "user",
        "content": (
            f"ORCHESTRATOR (grammar retry): your last `{tool_name}` call was "
            f"missing required arguments. Re-emit the arguments as a JSON "
            f"object matching the schema exactly. Fill EVERY required field "
            f"with a concrete value.\n\n"
            f"Partial call you made:\n{partial_dump}\n\n"
            f"Your narration mentioned:\n{(narration or '').strip()[-500:]}\n\n"
            f"Workspace root (paths resolve from here): {workspace}\n\n"
            f"Respond with ONLY the JSON object. No prose, no markdown, "
            f"no code fences."
        ),
    }]

    payload = {
        "model": model,
        "messages": forced_messages,
        "stream": False,
        "cache_prompt": True,
        "max_tokens": 1024,
        "response_format": {
            "type": "json_schema",
            "json_schema": {
                "name": f"{tool_name}_args",
                "schema": strict,
                "strict": True,
            },
        },
    }
    req = urllib.request.Request(
        f"{base_url.rstrip('/')}/chat/completions",
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=180) as resp:
            body = json.loads(resp.read().decode("utf-8", errors="replace"))
    except (urllib.error.HTTPError, urllib.error.URLError, OSError,
            json.JSONDecodeError):
        return None
    try:
        message = body["choices"][0]["message"]
    except (KeyError, IndexError, TypeError):
        return None
    text = _extract_grammar_payload(message)
    if not text:
        return None
    # Some models still wrap the JSON in code fences despite the strict
    # response_format. Peel a trailing ``` and a leading ``` (with optional
    # language tag) so json.loads gets clean input.
    stripped = text.strip()
    if stripped.startswith("```"):
        lines = stripped.split("\n")
        if lines:
            lines = lines[1:]
        if lines and lines[-1].strip().startswith("```"):
            lines = lines[:-1]
        stripped = "\n".join(lines).strip()
    try:
        parsed = json.loads(stripped)
    except (TypeError, json.JSONDecodeError):
        return None
    if not isinstance(parsed, dict):
        return None
    return parsed


def request_plain_completion(base_url, model, messages, *, timeout=120):
    """Non-streaming chat completion. Returns the assistant text (content
    or reasoning_content fallback) or None on error. Used by compaction,
    project-knowledge enrichment, and any other helper that just wants a
    one-shot answer without the streaming machinery."""
    payload = {"model": model, "messages": messages, "stream": False}
    req = urllib.request.Request(
        f"{base_url.rstrip('/')}/chat/completions",
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            body = json.loads(resp.read().decode("utf-8", errors="replace"))
    except (urllib.error.HTTPError, urllib.error.URLError, OSError,
            json.JSONDecodeError):
        return None
    try:
        return _extract_grammar_payload(body["choices"][0]["message"]) or None
    except (KeyError, IndexError, TypeError):
        return None


def stream_completion(base_url, model, messages, tools, *,
                      max_tokens=None, stop=None):
    # 8.0.9: cache_prompt tells llama.cpp / LM Studio to reuse the KV
    # state for unchanged prefixes across turns. Massive win on
    # multi-turn sessions where the system prompt + tool catalogue
    # are stable - cuts time-to-first-token by 60-80%.
    payload = {"model": model, "messages": messages, "tools": tools,
               "tool_choice": "auto", "stream": True,
               "cache_prompt": True}
    if max_tokens:
        payload["max_tokens"] = max_tokens
    if stop:
        payload["stop"] = stop
    req = urllib.request.Request(
        f"{base_url.rstrip('/')}/chat/completions",
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST")
    tool_calls_by_index = {}
    try:
        with urllib.request.urlopen(req, timeout=600) as resp:
            for raw in resp:
                line = raw.decode("utf-8", errors="replace").rstrip("\r\n")
                if not line or not line.startswith("data:"):
                    continue
                data_str = line[len("data:"):].strip()
                if data_str == "[DONE]":
                    break
                try:
                    event = json.loads(data_str)
                except json.JSONDecodeError:
                    continue
                # LM Studio reports mid-stream errors as `event: error\n
                # data: {"error": {...}}` SSE frames. The `event:` line
                # gets skipped (doesn't start with `data:`), but the
                # payload still arrives here without a `choices` key.
                # Without this check the loop silently drops the error,
                # the streamer never gets fed, and the agent looks dead.
                if "error" in event and "choices" not in event:
                    err = event["error"]
                    msg = err.get("message") if isinstance(err, dict) else str(err)
                    yield ("error", f"LM Studio: {msg}")
                    return
                choices = event.get("choices") or []
                if not choices:
                    continue
                delta = choices[0].get("delta") or {}
                content = delta.get("content")
                if content:
                    yield ("content", content)
                reasoning = delta.get("reasoning_content")
                if reasoning:
                    yield ("content", reasoning)
                for tc_delta in delta.get("tool_calls") or []:
                    index = tc_delta.get("index", 0)
                    slot = tool_calls_by_index.setdefault(index,
                        {"id": None, "name": "", "arguments": ""})
                    if tc_delta.get("id"):
                        slot["id"] = tc_delta["id"]
                    fn = tc_delta.get("function") or {}
                    if fn.get("name"):
                        slot["name"] += fn["name"]
                    if fn.get("arguments"):
                        slot["arguments"] += fn["arguments"]
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")
        yield ("error", f"HTTP {e.code}: {body[:400]}")
        return
    except urllib.error.URLError as e:
        yield ("error", f"Could not reach LM Studio: {e.reason}")
        return
    for index in sorted(tool_calls_by_index.keys()):
        slot = tool_calls_by_index[index]
        if slot["name"]:
            yield ("tool_call", {
                "id": slot["id"] or f"call_{index}",
                "name": slot["name"],
                "arguments": slot["arguments"] or "{}"})
    yield ("done", None)


# =============================================================================
# Orchestrator: loop detection + argument repair
# =============================================================================
#
# Local models like Qwen3 / DeepSeek hit two predictable failure modes that
# tank the agent loop:
#
#   1. They lock into a degenerate retry cycle (calling the same tool with
#      the same broken arguments over and over, narrating "I keep making
#      the same mistake" between attempts). Forwarding each failure to the
#      model just makes the loop deeper.
#
#   2. They drop required arguments - typically `path` for write_file /
#      edit_file or `command` for run_bash - while clearly *describing*
#      the missing value in their narration ("The path is X. Let me create
#      X with this HTML..."). The schema-violation error tells them
#      nothing they don't already know.
#
# This block gives the orchestrator two compensating tricks:
#
#   - `detect_loop` watches the last few tool calls. If the model
#     re-emits the same (tool, args) twice in a row and we'd be about to
#     run it a third time, we synthesize an intervention message instead
#     of dispatching. The message names the pattern explicitly. Local
#     models almost always break out when the orchestrator points out
#     they're stuck.
#
#   - `repair_args` runs *before* dispatch on calls with missing required
#     fields, scanning the model's recent narration (assistant text from
#     the in-progress turn) for the value it forgot to pass. Today this
#     covers the two highest-leverage cases: path inference for file
#     tools, command inference for run_bash. The repair is annotated in
#     the tool result so the model sees what was fixed.

_PATH_PATTERNS = (
    # Quoted path - highest confidence, handles spaces.
    re.compile(r"""(?:path|file|location)\s*(?:is|=|:)\s*["']([^"'\n]+)["']""", re.I),
    # Backticked path (allows spaces inside the backticks).
    re.compile(r"`([^`\n]+\.[A-Za-z0-9]{1,5})`"),
    # Tilde-rooted path through to the extension, spaces allowed.
    re.compile(r"(~/[^\n,;:`\"']+?\.[A-Za-z0-9]{1,5})"),
    # Absolute path through to the extension.
    re.compile(r"(/[A-Za-z][^\n,;:`\"']+?\.[A-Za-z0-9]{1,5})"),
    # `path is X`, `path: X` with unquoted single-token value.
    re.compile(r"(?:path|file)\s*(?:is|=|:)\s*([^\s,;:`\"'\n]+\.[A-Za-z0-9]{1,5})", re.I),
    # `create X.html`, `write X.py`, etc - allow spaces inside the name
    # up to the extension.
    re.compile(r"(?:create|write|edit|build|update|save)\s+(?:the\s+)?([\w][\w./ -]*?\.[A-Za-z0-9]{1,5})\b", re.I),
    # Bare multi-segment relative path with extension.
    re.compile(r"\b((?:[\w][\w -]*/)+[\w][\w -]*\.[A-Za-z0-9]{1,5})\b"),
    # Bare filename with extension.
    re.compile(r"\b([\w][\w-]*\.[A-Za-z0-9]{1,5})\b"),
)

_COMMAND_PATTERNS = (
    re.compile(r"```(?:bash|sh|zsh)?\s*\n([^\n][^`]*?)```", re.S),
    re.compile(r"^\s*\$\s+(.+?)$", re.M),
    re.compile(r"`([^`\n]{2,})`"),
)


def _canonical(args_obj):
    try:
        return json.dumps(args_obj, sort_keys=True)
    except (TypeError, ValueError):
        return str(args_obj)


def detect_repeat_failure(history, name, args_canonical):
    """True when the last two recorded tool calls match `(name, args)` and
    both ended in error - i.e. this call would be the third identical
    failed attempt in a row."""
    if len(history) < 2:
        return False
    last = history[-1]
    prev = history[-2]
    return (last["name"] == prev["name"] == name
            and last["args"] == prev["args"] == args_canonical
            and last["error"] and prev["error"])


def build_intervention_message(name, args, schema_summary):
    """Synthetic tool-result body returned in place of the dispatch when
    we catch the model in a retry loop. Names the pattern explicitly and
    re-states the schema so the model has something concrete to fix."""
    arg_dump = json.dumps(args, indent=2) if args else "{}"
    return (
        "ORCHESTRATOR INTERVENTION: you have called `" + name + "` three "
        "times in a row with identical arguments and the call has failed "
        "every time. Stop retrying with the same arguments.\n\n"
        "Last attempt:\n" + arg_dump + "\n\n"
        "Required schema:\n" + schema_summary + "\n\n"
        "Action: respond in plain text (no tool calls) describing what "
        "you intended to do, OR call `" + name + "` once with every "
        "required field filled in concretely."
    )


def _scan_for_path(text, workspace):
    """Find a plausible workspace path in the model's narration. Patterns
    are ordered from highest-confidence (quoted / backticked / tilde-
    rooted) to lowest. Each candidate is rejected if the resolver would
    refuse it (outside workspace, no extension, scheme-y, etc.); we keep
    trying patterns until something resolves."""
    if not text:
        return None
    seen = set()
    for pat in _PATH_PATTERNS:
        for m in pat.finditer(text):
            candidate = m.group(1).strip("'\"`,. ;:")
            if not candidate or candidate in seen:
                continue
            seen.add(candidate)
            # Hide URLs and anchor-only fragments.
            if candidate.startswith(("http://", "https://")) or candidate.startswith("."):
                continue
            if "." not in candidate:
                continue
            # Try to resolve. If it's accepted by resolve_in_workspace,
            # it's a real candidate. Otherwise we move on - prevents the
            # repair from emitting a path the dispatcher would just error
            # on a moment later.
            try:
                resolve_in_workspace(workspace, candidate)
            except ValueError:
                continue
            return candidate
    return None


def prune_stale_tool_results(state, *, keep_recent=6, head_chars=240):
    """8.0.12: replace the bodies of older tool result messages with a
    short head + a pruned marker. Run at the top of every run_turn so
    each turn pays for the full bodies of only the most recent N tool
    results, not the entire session history.

    The model can re-call any tool to get the full result back. This
    is a CHEAP win on multi-task workflows: a session that ran
    `read_file` on a 500-line file 5 turns ago doesn't keep paying
    2k+ tokens for that content in every subsequent API call.

    Returns the number of messages that got pruned. 0 is the no-op."""
    tool_indices = [i for i, msg in enumerate(state.transcript)
                    if msg.get("role") == "tool"]
    if len(tool_indices) <= keep_recent:
        return 0
    pruned = 0
    for idx in tool_indices[:-keep_recent]:
        msg = state.transcript[idx]
        content = msg.get("content") or ""
        # Skip already-pruned entries (idempotent).
        if "[pruned: full result was" in content:
            continue
        if len(content) <= head_chars + 80:
            continue  # already small, no win
        head = content[:head_chars].rstrip()
        msg["content"] = (
            f"{head}\n... [pruned: full result was {len(content)} chars. "
            f"Re-call the tool if you need the rest.]"
        )
        pruned += 1
    return pruned


def maybe_compact_transcript(state):
    """When token usage crosses COMPACT_TRIGGER_RATIO of the context window,
    summarize the middle of the transcript into a single system note and
    shorten the conversation in place. Preserves the original system
    message and the most recent ~6 turns so the model keeps tight context
    on the in-flight task.

    Returns True when compaction ran. Falls through silently when the
    server can't summarize or the transcript is already short."""
    if not state.auto_compact:
        return False
    if not state.context_window or state.context_window <= 0:
        return False
    if state.approx_tokens < int(state.context_window * COMPACT_TRIGGER_RATIO):
        return False
    if len(state.transcript) < 8:
        return False

    keep_tail = 6
    if len(state.transcript) <= 1 + keep_tail:
        return False

    system_msg = state.transcript[0]
    tail = state.transcript[-keep_tail:]
    middle = state.transcript[1:-keep_tail]
    if not middle:
        return False

    # Render the middle as a transcript-style block for the summarizer.
    rendered = []
    for entry in middle:
        role = entry.get("role", "?")
        content = entry.get("content") or ""
        tcs = entry.get("tool_calls")
        if tcs:
            content = (content + "\n" if content else "") + "\n".join(
                f"[tool_call: {tc.get('function',{}).get('name','?')}"
                f"({tc.get('function',{}).get('arguments','')})]"
                for tc in tcs
            )
        if not content:
            continue
        rendered.append(f"{role}: {content[:2000]}")
    rendered_block = "\n\n".join(rendered)[:24000]

    summary_messages = [
        {"role": "system", "content":
            "You are a context compactor. Summarize the conversation so far "
            "in <= 250 words. Include: files created/modified with their "
            "purpose, key commands that worked, decisions made, open "
            "questions, and what's still pending. Be terse. Bullet points "
            "are fine. NO preamble, NO 'here is the summary' framing - "
            "start with the first bullet directly."},
        {"role": "user", "content":
            "Compact this conversation:\n\n" + rendered_block},
    ]
    summary = request_plain_completion(
        state.base_url, state.model, summary_messages, timeout=180)
    if not summary:
        return False

    summary_entry = {
        "role": "system",
        "content": (
            f"# Compacted context (turn #{state.compact_count + 1})\n\n"
            + summary.strip()
        ),
    }
    state.transcript = [system_msg, summary_entry] + tail
    state.compact_count += 1
    # Re-estimate tokens: cheap walk of the new transcript.
    state.approx_tokens = sum(
        max(1, len(e.get("content") or "") // 4) for e in state.transcript
    )
    return True


def verify_task_completions(tasks, workspace):
    """Walk the task list looking for `completed` entries whose subject
    names a file. If the named file doesn't exist on disk (or is zero
    bytes), flip the task back to `in_progress` and record the miss.

    Returns a list of human-readable verification failures, suitable for
    appending to the orchestrator's tool-result. Mutates `tasks` in place.

    Skipped entirely for subjects with no detectable path - we can't
    falsify "research X" or "design Y" claims, so we trust them."""
    failures = []
    for t in tasks:
        if not isinstance(t, dict):
            continue
        if t.get("status") != "completed":
            continue
        subject = t.get("subject") or ""
        candidate = _scan_for_path(subject, workspace)
        if not candidate:
            continue
        try:
            resolved = resolve_in_workspace(workspace, candidate)
        except ValueError:
            continue
        if not resolved.is_file():
            t["status"] = "in_progress"
            failures.append(
                f"`{subject}` claimed completed, but `{candidate}` does not exist"
            )
            continue
        try:
            size = resolved.stat().st_size
        except OSError:
            continue
        if size == 0:
            t["status"] = "in_progress"
            failures.append(
                f"`{subject}` claimed completed, but `{candidate}` is empty (0 bytes)"
            )
    return failures


def _scan_for_command(text):
    if not text:
        return None
    for pat in _COMMAND_PATTERNS:
        m = pat.search(text)
        if m:
            cand = m.group(1).strip()
            if cand and len(cand) < 400:
                return cand
    return None


def repair_args(state, name, args, narration):
    """Try to fill in the most common missing-argument cases by scanning
    the model's recent narration. Returns (repaired_args, note) where
    `note` is a human-readable summary suitable for the tool result."""
    fixed = dict(args) if isinstance(args, dict) else {}
    notes = []
    if name in ("write_file", "edit_file"):
        if not fixed.get("path"):
            guess = _scan_for_path(narration, state.workspace)
            if guess:
                fixed["path"] = guess
                notes.append("auto-repaired `path` = " + repr(guess)
                             + " from your narration")
    if name == "run_bash":
        if not fixed.get("command"):
            guess = _scan_for_command(narration)
            if guess:
                fixed["command"] = guess
                notes.append("auto-repaired `command` = " + repr(guess)
                             + " from your narration")
    if name == "edit_file":
        if not fixed.get("old_string") and "old_string" not in fixed:
            # Hard to repair from text alone - leave it. The model will
            # see the error and try again with concrete values.
            pass
    note = "  ".join(notes) if notes else None
    return fixed, note


# ---------- Continuation policy --------------------------------------------
#
# Local models routinely stop mid-task. The two failure modes we see:
#
#   1. Pending tasks remain, but the model ends a turn with no tool calls
#      ("Let me think about this..." -> empty response).
#   2. The model marks every task complete in one update_tasks call and
#      then *still* narrates more work ("Now I need to create the website")
#      without actually doing it - premature done.
#
# `should_auto_continue` decides whether to inject a synthetic user
# message before the REPL hands control back to the human. Each
# injection counts against state.max_continuations so a stuck model
# can't loop forever; if we exhaust the budget, the user gets a clear
# "orchestrator gave up after N attempts" message and a fresh prompt.

_PROMISE_PATTERNS = [
    re.compile(r"\b(?:I['']?ll|let me|I will|I need to|I['']?m going to|let's|now I['']?ll|now I need to|I should|next I['']?ll|next I need to)\b", re.I),
    re.compile(r"\b(?:let me create|let me write|let me build|let me make|let me start|let me try)\b", re.I),
    re.compile(r"\b(?:going to|about to|need to)\s+(?:create|write|build|make|add|implement|fix|update)\b", re.I),
]


def detect_lazy_promise(text):
    """Find a phrase that signals the model intends to act but is about to
    end its turn instead. Returns the matched fragment or None."""
    if not text:
        return None
    snippet = text[-2000:]  # only look at the tail; intros don't count
    for pat in _PROMISE_PATTERNS:
        m = pat.search(snippet)
        if m:
            # Pull a sentence-ish slice around the match for the
            # intervention message.
            start = max(0, m.start() - 20)
            end = min(len(snippet), m.end() + 80)
            return snippet[start:end].strip()
    return None


def first_pending_task(state):
    """The first task that is pending or in_progress, in display order.
    Returns None when nothing is pending (or no tasks exist)."""
    for t in state.sink.current:
        if t.get("status") in ("pending", "in_progress"):
            return t
    return None


def all_tasks_done(state):
    return bool(state.sink.current) and all(
        t.get("status") == "completed" for t in state.sink.current
    )


def should_auto_continue(state, last_text):
    """Return the synthetic user message to inject for the next turn, or
    None when it's the human's turn again. Order matters: we prefer the
    most concrete signal (pending tasks) over the softer one (premature
    done + promise narration)."""
    pending = first_pending_task(state)
    if pending:
        subj = pending.get("subject", "(no subject)")
        active = pending.get("activeForm") or subj
        return (
            "ORCHESTRATOR: pending tasks remain. The next task is: "
            + repr(subj) + " (" + active + "). "
            "Take concrete action on it RIGHT NOW using the tools - "
            "do not just describe what you would do, do not summarize, "
            "do not ask for confirmation. When the task is complete, "
            "call update_tasks to flip its status and move to the next one. "
            "Workspace root: " + str(state.workspace)
        )
    if all_tasks_done(state):
        promise = detect_lazy_promise(last_text)
        if promise:
            return (
                "ORCHESTRATOR: you marked every task complete, but your "
                "last message also said: " + repr(promise)
                + " - that is unfinished work that contradicts the "
                "completed status. Either call update_tasks to add a new "
                "task for what you described and execute it now, OR "
                "actually finish what you said before ending the turn. "
                "Use the tools - do not just narrate."
            )
    # 8.0.6: text-mode bail-out detection. Non-native-tool families
    # (Gemma, base Llama, Phi-3) sometimes burn a turn writing a long
    # prose plan and never emit a tool call. The plan-without-action
    # case isn't caught by the two checks above because there are no
    # tasks AND no first-person promises. Detect the pattern from
    # length + path/command mentions and nudge the model into emitting
    # exactly one tool call in the proper format.
    if (state.adapter
            and not state.adapter.native_tools
            and not state.last_turn_had_tool_calls
            and last_text
            and _looks_like_plan_without_action(last_text)):
        return (
            "ORCHESTRATOR: you wrote a plan but did not emit any tool "
            "call. Text-mode tool calls REQUIRE a fenced ```tool_call "
            "JSON block. Pick ONE concrete next step from your plan and "
            "emit it now, in this exact format:\n\n"
            "```tool_call\n"
            "{\"name\": \"<tool>\", \"arguments\": {<args>}}\n"
            "```\n\n"
            "No prose. No bullet lists. No 'Commands to Execute'. Just "
            "ONE fenced tool_call block. Stop after the closing ```. "
            "Workspace root: " + str(state.workspace)
        )
    return None


_PATH_HINT_RE = re.compile(
    r"(?:\.[A-Za-z0-9]{1,5}\b)|(?:/[A-Za-z0-9_.-]+){2,}|(?:`[^`\n]{2,}`)|"
    r"(?:\bnpm\b|\bcurl\b|\bgit\b|\bmkdir\b|\btouch\b|\bcd\b|\bnpx\b)",
    re.IGNORECASE,
)


def _looks_like_plan_without_action(text):
    """Heuristic: is this assistant text a multi-line plan that should
    have produced a tool call? True when the text is long (>200 chars)
    and contains either file path-like fragments or shell-command tokens
    in two or more places. Triggers the text-mode rescue continuation."""
    if not text or len(text) < 200:
        return False
    return len(_PATH_HINT_RE.findall(text)) >= 2


def _infer_tool_from_text(text, workspace):
    """8.0.6: heuristic - pick the most likely tool the model meant to
    call from its narration. Used by the grammar-forced rescue when a
    text-mode model has burned its turns on prose. Returns
    (tool_name, partial_args_dict). (None, {}) when nothing matches
    cleanly; the rescue gives up."""
    if not text:
        return None, {}
    lower = text.lower()
    path = _scan_for_path(text, workspace)
    write_hints = ("create file", "write file", "new file", "make a file",
                   "let me create", "let me write", "i'll create",
                   "i will create", "create the file", "creating ",
                   "scaffold", "generate code", "write the file")
    run_hints = ("run command", "execute the", "let me run", "i'll run",
                 "i will run", "execute this", "shell ", "npm install",
                 "npm run", "git init", "mkdir ", "touch ", "npx ")
    read_hints = ("read file", "let me read", "look at the file",
                  "check the contents", "read the file", "i'll read",
                  "i will read")
    list_hints = ("list directory", "list files", "list the contents",
                  "ls -", "what's in")
    if any(h in lower for h in write_hints):
        return "write_file", ({"path": path} if path else {})
    if any(h in lower for h in run_hints):
        m = re.search(r"`([^`\n]{2,400})`", text)
        cmd = m.group(1).strip() if m else ""
        return "run_bash", ({"command": cmd} if cmd else {})
    if any(h in lower for h in read_hints):
        return "read_file", ({"path": path} if path else {})
    if any(h in lower for h in list_hints):
        return "list_dir", {"path": "."}
    # Fallback: if we found ANY path candidate, default to write_file -
    # by far the most common rescue action when the model has narrated
    # a file plan.
    if path:
        return "write_file", {"path": path}
    return None, {}


def rescue_force_tool_call(state):
    """8.0.6: last-ditch tool emission for text-mode families. When the
    zero-progress streak hits the limit AND the family is non-native,
    we infer the most-likely tool from the model's last narration,
    force its arguments via grammar-constrained generation, dispatch
    the result, and append a synthetic system note so the model can
    pick up from there. Returns a short status string on success, None
    when no rescue was possible."""
    if not state.grammar_supported:
        return None
    last_assistant = ""
    for msg in reversed(state.transcript):
        if msg.get("role") == "assistant":
            last_assistant = msg.get("content", "") or ""
            break
    if not last_assistant.strip():
        return None
    tool_name, partial = _infer_tool_from_text(last_assistant, state.workspace)
    if not tool_name:
        return None
    schema = schema_params_for(tool_name)
    if not schema:
        return None
    try:
        forced = force_grammar_args(
            state.base_url, state.model, state.transcript,
            tool_name, schema, partial, last_assistant, state.workspace,
        )
    except Exception:
        forced = None
    if not forced or missing_required(tool_name, forced):
        return None
    # Dispatch through the normal path so permission gates, hooks, and
    # journaling all fire. We don't re-render the call line; this is an
    # orchestrator-internal action.
    try:
        result = _dispatch_tool(state, tool_name, forced, narration="")
    except Exception as e:
        return None
    # Plain-text system note - no tool_calls in the transcript so any
    # chat template (including Gemma's, which can't render OpenAI
    # tool_calls structures) shows it as a normal message.
    state.transcript.append({
        "role": "system",
        "content": (
            f"ORCHESTRATOR rescue: you narrated a plan but did not emit "
            f"a tool call. I ran `{tool_name}` on your behalf using "
            f"your narration as the source.\n\n"
            f"Arguments:\n{json.dumps(forced, indent=2)}\n\n"
            f"Result:\n{str(result)[:1200]}\n\n"
            f"Continue from here. Emit your NEXT step as a fenced "
            f"```tool_call block, NOT as prose."
        ),
    })
    return f"forced {tool_name} via grammar"


def schema_summary_for(name):
    """One-line argument summary for the named built-in tool. Used in the
    orchestrator intervention text so the model sees a concrete schema."""
    for spec in BUILTIN_TOOL_SCHEMAS:
        fn = spec.get("function") or {}
        if fn.get("name") == name:
            params = fn.get("parameters") or {}
            required = params.get("required") or []
            props = params.get("properties") or {}
            rows = []
            for key in required:
                kind = (props.get(key) or {}).get("type", "string")
                rows.append("  " + key + " (" + kind + ", required)")
            for key in (k for k in props if k not in required):
                kind = (props.get(key) or {}).get("type", "string")
                rows.append("  " + key + " (" + kind + ")")
            return name + "(\n" + "\n".join(rows) + "\n)"
    return name + "(...)"


def schema_params_for(name):
    """Return the raw JSON Schema parameter object for the named built-in
    tool, or None if not found. Used to feed `response_format` constraints
    to LM Studio's grammar-constrained generation."""
    for spec in BUILTIN_TOOL_SCHEMAS:
        fn = spec.get("function") or {}
        if fn.get("name") == name:
            return fn.get("parameters")
    return None


def required_args_for(name):
    params = schema_params_for(name) or {}
    return list(params.get("required") or [])


def missing_required(name, args):
    """Required field names from the schema that aren't set (or are None /
    empty-string) in `args`. Empty list when everything's present."""
    if not isinstance(args, dict):
        return required_args_for(name)
    missing = []
    for key in required_args_for(name):
        val = args.get(key)
        if val is None or val == "":
            missing.append(key)
    return missing


# =============================================================================
# Session state container
# =============================================================================

SYSTEM_PROMPT_BASE = """You are an interactive coding agent running in a
terminal, backed by a local LM Studio model. You have these tools:

- read_file(path) - read a UTF-8 file in the current workspace
- write_file(path, content) - create or overwrite a file
- edit_file(path, old_string, new_string) - surgical text edit
- multi_edit(path, edits) - apply N substring replacements to one file
  in a single call. Each edit is {old_string, new_string}. Prefer this
  to N separate edit_file calls.
- list_dir(path) - list directory entries
- glob(pattern, path?) - find files matching a glob (supports **)
- grep(pattern, path?, include?) - grep -rIn across the workspace
- find_todos(pattern?, path?) - find TODO/FIXME/XXX/HACK markers
- git_status / git_diff / git_log / git_blame / git_show - repo
  awareness as builtins (no shelling out to bash needed)
- browser_open(url) / browser_screenshot / browser_click(selector) /
  browser_type(selector, text) / browser_eval(script) / browser_text /
  browser_close - drive a headless Chromium when Playwright is
  installed in the local Python env
- lsp_diagnostics(path) / lsp_definition / lsp_references - real code
  intelligence when an LSP server is configured via --lsp
- ask_user(question, options) - block and ask the user a multi-choice
  question. Use when disambiguation matters more than a guess.
- schedule_wakeup(delay_seconds, prompt, reason?) - schedule a future
  re-entry of this agent. Use in --loop mode.
- background_bash(command, label?) + monitor(shell_id) + bash_output(shell_id)
  + kill_shell(shell_id) - run long-lived processes detached.
- notebook_read / notebook_edit / notebook_append - Jupyter .ipynb work.
- save_memory(name, body, kind?) - persist a cross-workspace memory.
- activate_skill(name) - load a skill from ~/.loom/skills/ for this turn.
- loop_complete(summary) - in --loop mode, stop the loop.
- run_bash(command, timeout_seconds?) - shell command, when enabled.
  Output streams live; long-running commands no longer appear silent
- update_tasks(tasks) - replace the visible task list. Each task has
  subject, activeForm (present-continuous), and status (pending,
  in_progress, completed, cancelled). Subjects that name a file are
  verified on disk - if the file isn't there, the orchestrator flips
  the task back to in_progress.
- spawn_agent(prompt, role?, system?) - delegate a focused subtask
- MCP tools when a `--mcp` server is configured. They appear with an
  `mcp__` name prefix.

Workflow:
1. For non-trivial requests, call update_tasks first with a plan.
2. Flip each task to in_progress before working on it, and to completed
   immediately when done. Keep at most one task in_progress at a time.
3. When the work is done, answer in plain text (no tool calls). That
   ends the loop; leftover tasks are auto-completed.

Paths must be relative to the current working directory. The runner
enforces that boundary.

Wrap reasoning in <think>...</think>. It's rendered dimmed so the user
can follow along without it cluttering the answer."""


class AgentState:
    def __init__(self, *, workspace, base_url, model, allow_bash, session_id,
                 yolo, theme_name, mcp_clients, wrap=True):
        self.workspace = workspace
        self.base_url = base_url
        self.model = model
        self.allow_bash = allow_bash
        self.session_id = session_id
        self.sink = TaskSink(session_id)
        self.yolo = yolo
        self.theme_name = theme_name
        self.mcp_clients = mcp_clients
        self.permissions = PermissionManager(yolo=yolo)
        self.transcript = []
        self.approx_tokens = 0
        self.started_at = time.time()
        self.context_files = []
        self.context_text = ""
        # Pre-flight workspace scan injected into the system prompt so the
        # model has a workspace map at turn-zero. Stored as (tree_text,
        # entry_count); count surfaces in the banner.
        self.workspace_tree = ""
        self.workspace_tree_count = 0
        self.system_prompt = SYSTEM_PROMPT_BASE
        self.system_override = None
        self.last_diff = None  # set by write_file / edit_file tool calls
        self.wrap = wrap
        # Rolling tool-call log for the loop-detection orchestrator. Each
        # entry: {name, args (canonical JSON), error (bool)}.
        self.tool_history = []
        # Model's context window in tokens, queried once at session start
        # via LM Studio's /api/v0/models. Used by the status footer.
        self.context_window = None
        # Whether the active LM Studio server accepts response_format /
        # json_schema. Probed once at session start; gates grammar-retry
        # fallback in the dispatcher.
        self.grammar_supported = False
        # Continuation policy: how many times the orchestrator will keep
        # re-prompting after a turn ends with work clearly unfinished.
        # Counts reset to 0 on every human-issued user message.
        self.continuation_count = 0
        self.max_continuations = 12
        self.last_turn_had_tool_calls = False
        self.auto_continue = True
        # 8.0.3 — zero-progress guard. Set True by _dispatch_tool when any
        # non-update_tasks tool succeeds OR when update_tasks completes a
        # task (status flips to "completed"). Reset to False at the top of
        # each run_turn. drive_user_message tracks consecutive False turns
        # and breaks the continuation loop after 2 unproductive rounds so
        # the model can't loop forever just narrating + calling
        # update_tasks({}) on repeat.
        self.progress_this_turn = False
        self.zero_progress_streak = 0
        self.max_zero_progress_streak = 2
        # 8.0.6 — text-mode rescue budget. Each human-issued turn allows
        # at most N grammar-forced tool rescues so a model that won't
        # cooperate doesn't loop the rescue mechanism. Reset in
        # drive_user_message alongside the streak counter.
        self.rescues_this_turn = 0
        self.max_rescues_per_turn = 2
        # 8.0.9 — per-completion token cap. Prevents runaway narration
        # on chatty models (Gemma especially), cutting wall-clock per
        # turn. Override via --max-tokens or LMSTUDIO_MAX_TOKENS env.
        self.max_tokens = 4096
        # 8.0.9 — early-stop streaming after a fenced tool_call closes.
        # Text-mode families typically finish "...```" and then keep
        # narrating; cutting the stream the moment the fence closes
        # saves the model from filler-prose tokens we'd discard anyway.
        # Only meaningful when adapter.native_tools is False.
        self.early_stop_text_tool_call = True
        # 8.0.10 — Claude Code-style mode cycle. Shift+Tab in the
        # BoxedLineEditor advances mode_index by one, wrapping at the
        # end of MODES. Each mode toggles a small bundle of behaviors:
        #   default     - permissions gate FS mutations + bash
        #   plan        - blocks every write tool + run_bash entirely
        #   auto-accept - permissions.yolo = True; no prompts
        # The current mode pill renders in the box top border so the
        # user sees what they're in before submitting.
        self.mode_index = 0
        # Auto-compaction. Triggered when approx_tokens / context_window
        # exceeds COMPACT_TRIGGER_RATIO. Counter visible in the footer.
        self.auto_compact = True
        self.compact_count = 0
        # Auto-test integration. When True, after every successful
        # write_file/edit_file/multi_edit to a path under tests/ or matching
        # a test-naming convention, run the detected test command and feed
        # the failure tail back as a synthetic tool result.
        self.auto_test = False
        # Speculative tool prefetch. Off by default; tracks the prefetch
        # cache (tool_name, canonical_args_json) -> (timestamp, result).
        self.prefetch_enabled = True
        self.prefetch_cache = {}
        self.prefetch_hits = 0
        self.prefetch_misses = 0
        # Filesystem mutation journal: each entry is
        # {action, path, prior, new, timestamp}. /undo replays the prior
        # content. Persisted to ~/.loom/journal/<session>.jsonl on every
        # mutation so a crash can be recovered.
        self.journal = []
        # Tool-result memory: cheap TF-IDF over the bodies of past
        # tool calls so the model can recall earlier reads without
        # re-fetching the file.
        self.memory = []
        # Per-workspace persistent knowledge file (.loom/project.json).
        # Loaded on session start, written back on /quit.
        self.project_knowledge = None
        self.project_knowledge_text = ""
        # Live preview server handle (HTTPServer + thread).
        self.preview = None
        # Persistent headless browser (BrowserSession). Lazy-launched on
        # first browser_open / browser_screenshot call.
        self.browser = None
        # Auto-screenshot on UI edits. When True, after every write/edit
        # to an HTML/CSS/JSX file the orchestrator spins up the preview,
        # screenshots the rendered page, OCRs it, and feeds the text back.
        self.auto_screenshot = False
        # Aggressive multi-step batching: after update_tasks emits N
        # file-create steps, the orchestrator executes each via grammar-
        # forced write_file calls in one batch without re-prompting.
        self.aggressive_batching = False
        # Auto-commit at task completion: when a task flips to completed,
        # if the workspace is a git repo, stage and commit with an
        # auto-generated message.
        self.auto_commit = False
        # LSP client (LSPClient instance). Started via --lsp / /lsp.
        self.lsp = None
        # Persona (optional). When set, prepended to the system prompt
        # alongside project context / workspace tree / project knowledge.
        self.persona_text = ""
        self.persona_source = ""
        # Constitution (hard guardrails). Same load semantics as persona but
        # also validated against every tool call before dispatch.
        self.constitution_text = ""
        self.constitution_rules = []
        # Per-session domain blocklist for web_fetch / web_search (suffix
        # match on hostname).
        self.web_blocklist = set()
        # Continuous file watching state. Keys are workspace-relative paths;
        # values are last-seen mtime + size. Updated by a background thread.
        self.watched_files = {}
        self.watcher_thread = None
        self.watcher_stop = threading.Event()
        self.external_change_notes = []
        # Workspace symbol index. {symbol: [(path, line, kind), ...]}.
        # Built lazily on the first symbol_search call.
        self.symbol_index = None
        # Cost meter: per-tool breakdown of elapsed_ms + estimated tokens.
        # Each entry: {calls, elapsed_ms, est_tokens, paths_read: Counter}.
        self.cost_breakdown = {}
        # Self-reflection state (end-of-turn judge prompt).
        self.self_reflect = False
        self.reflection_lessons = []
        # Plugin tools loaded from ~/.loom/tools/*.py.
        self.plugin_names = []
        # Drift warnings from project knowledge load.
        self.drift_warnings = []
        # Queued followups: synthetic user messages that the dispatcher
        # appends mid-turn (e.g. from `ship_it`) and which the outer
        # drive_user_message drains as fresh top-level turns. Avoids the
        # recursive run_turn hazard.
        self.queued_followups = []
        # 8.0.0 — hooks system. Loaded on session start from
        # ~/.loom/hooks/ and <workspace>/.loom/hooks/. Event name -> list
        # of script paths (workspace hooks first).
        self.hooks = {}
        # 8.0.0 — settings.json snapshot (for /settings inspection).
        self.settings = {}
        # 8.0.0 — active skills. Each entry: {"name", "system_text",
        # "tools_added": [tool names]}. The skill's system text is
        # prepended to system_message() while active.
        self.active_skills = []
        # 8.0.0 — background bash registry. shell_id -> {"proc", "log",
        # "command", "started_at", "label"}.
        self.bg_shells = {}
        # 8.0.0 — pending question awaiting an answer from the user.
        # When set, the next REPL turn prompts the user with the picker
        # before sending anything to the model.
        self.pending_question = None
        # 8.0.0 — user-level memory (cross-workspace). Loaded once at
        # session start from ~/.loom/memory/MEMORY.md.
        self.user_memory_text = ""
        # 8.0.0 — loop mode flags. The CLI re-enters drive_user_message
        # with the original prompt until the model calls loop_complete
        # (which flips this to True).
        self.loop_should_exit = False
        # 8.0.0 — slash command files discovered at SlashRouter init.
        self.slash_command_files = {}
        # Multi-model routing (planner/coder/explainer override the
        # default `model`). Empty string = use default.
        self.planner_model = ""
        self.coder_model = ""
        self.explainer_model = ""
        # 8.0.5 — model adapter. Detects the loaded model's family
        # (Qwen3, Gemma, Llama, DeepSeek, Phi, Mistral, etc.) and centralizes
        # per-family quirks: native vs text-mode tool calling, reasoning
        # content handling, system-prompt addenda, and whether to default
        # to the essential-tools-only subset. Instantiated lazily on first
        # use so AgentState can be built before we've talked to LM Studio.
        self.adapter = ModelAdapter(self.model)
        # 8.0.5 — essentials-only tool subset. Defaults from the adapter's
        # per-family hint; the n_ctx auto-retry in run_turn flips this to
        # True when the model's runtime context can't fit the full
        # schema. /tools full overrides back to False.
        self.essential_tools_only = self.adapter.default_essential_only

    @property
    def mode(self):
        """Current mode dict from MODES."""
        return MODES[self.mode_index % len(MODES)]

    def cycle_mode(self):
        """Advance to the next mode and apply side effects. Called from
        BoxedLineEditor on Shift+Tab. Returns the new mode dict."""
        self.mode_index = (self.mode_index + 1) % len(MODES)
        return self._apply_mode()

    def set_mode(self, name):
        """Jump to a specific mode by name without cycling through the
        intermediates. Useful for --bypass-bash startup flag and the
        /mode <name> slash command."""
        for i, m in enumerate(MODES):
            if m["name"] == name or m["label"].lower() == name.lower():
                self.mode_index = i
                return self._apply_mode()
        return self.mode

    def _apply_mode(self):
        """Apply side effects for the current mode_index. Resets
        permissions to a known baseline first, then layers on whatever
        the new mode wants. Appends a system note for the model."""
        new = self.mode
        # Reset baseline before each transition so we don't accumulate
        # state from prior modes (e.g. allowed_forever entries from
        # ACCEPT EDITS bleeding into a return to default).
        self.permissions.yolo = self.yolo  # restore launch-time yolo
        for tool_name in FS_MUTATING_TOOLS | {"run_bash"}:
            self.permissions.allowed_forever.discard(tool_name)
        # Re-apply launch-time --allow-bash auto-approve, if any.
        if self.allow_bash:
            self.permissions.allowed_forever.add("run_bash")
        # Layer on mode-specific effects.
        if new["name"] == "accept-edits":
            # Writes auto-approved; bash still gates unless --allow-bash.
            self.permissions.allowed_forever.update(FS_MUTATING_TOOLS)
        elif new["name"] == "bypass-permissions":
            # Full yolo: no prompts on anything. Also flip allow_bash on
            # so the run_bash dispatcher doesn't refuse with the
            # "bash disabled" early-return.
            self.permissions.yolo = True
            self.allow_bash = True
            self.permissions.allowed_forever.add("run_bash")
            self.permissions.allowed_forever.update(FS_MUTATING_TOOLS)
        # Append a system note so the model knows about the transition.
        # _dispatch_tool still hard-blocks plan-mode violations, but
        # telling the model upfront avoids wasted attempts.
        note = f"USER toggled mode → {new['label']}: {new['blurb']}."
        if new["name"] == "plan":
            note += (
                "\n\nYou are now in PLAN MODE. Read-only. Do NOT call "
                "write_file, edit_file, multi_edit, run_bash, "
                "git_commit, ship_it, or spawn_agent. Plan in prose; "
                "the user will toggle out of plan mode when ready to act."
            )
        elif new["name"] == "accept-edits":
            note += (
                "\n\nACCEPT EDITS mode: write_file / edit_file / "
                "multi_edit auto-approve without prompts. run_bash "
                "still requires user permission. Move quickly on file "
                "work; ask before running shell."
            )
        elif new["name"] == "bypass-permissions":
            note += (
                "\n\nBYPASS PERMISSIONS mode: no prompts on any tool, "
                "bash enabled. The user is trusting you to act without "
                "confirmation. Be careful with destructive operations."
            )
        self.transcript.append({"role": "system", "content": note})
        return new

    def system_message(self):
        body = self.system_override or self.system_prompt
        # 8.0.10: in plan mode, prepend a hard rule so the model knows
        # it's read-only this round.
        if self.mode["name"] == "plan":
            body = (
                "# PLAN MODE\n\n"
                "You are in PLAN MODE this turn. Do NOT call any tool that "
                "writes, edits, deletes, commits, runs shell, or spawns "
                "subagents. Allowed tools: read_file, list_dir, glob, "
                "grep, find_todos, git_status, git_diff, git_log, "
                "git_blame, git_show, ast_summary, symbol_search, "
                "browser_screenshot, web_search, web_fetch, update_tasks "
                "(for tracking only), recall, project_knowledge_*. Plan "
                "and propose changes in prose. The user will switch out "
                "of PLAN MODE when ready to act.\n\n"
            ) + body
        # 8.0.6: for non-native-tool families (Gemma, Phi-3, Llama 2),
        # PREPEND the text-mode instructions so they're the first thing
        # the model sees - small / instruction-tuned models otherwise
        # drift into long prose plans before they ever reach the tool
        # list further down. Native-tool families get no addendum so
        # this is a no-op for Qwen3 / DeepSeek / Llama 3.x / etc.
        if self.adapter:
            addendum = self.adapter.system_addendum()
            if addendum:
                body = addendum.strip() + "\n\n" + body
        extras = []
        if self.constitution_text:
            extras.append("# Constitution (HARD RULES — must obey)\n\n"
                          + self.constitution_text)
        if self.persona_text:
            extras.append(self.persona_text)
        if self.user_memory_text:
            extras.append(self.user_memory_text)
        for skill in self.active_skills:
            extras.append(f"# Skill: {skill['name']}\n\n"
                          + skill["system_text"])
        if self.context_text:
            extras.append(self.context_text)
        if self.workspace_tree:
            extras.append(self.workspace_tree)
        if self.project_knowledge_text:
            extras.append(self.project_knowledge_text)
        if extras:
            return body + "\n\n" + "\n\n".join(extras)
        return body

    def refresh_workspace_tree(self):
        try:
            tree, count = load_workspace_tree(self.workspace)
        except Exception:
            tree, count = "", 0
        self.workspace_tree = tree
        self.workspace_tree_count = count

    def reset_transcript(self):
        self.transcript = [{"role": "system", "content": self.system_message()}]

    def absorb_text(self, text):
        # Rough token approximation: 4 chars / token. Good enough for a
        # status footer indicator.
        if text:
            self.approx_tokens += max(1, len(text) // 4)


# =============================================================================
# Agent loop
# =============================================================================

def run_turn(state, user_message, *, json_emit=None):
    """Drive the streaming agent loop for one user message. Returns the
    final assistant text. Raises EscInterrupt if the user stops mid-turn."""
    # 8.0.3: reset the zero-progress flag at the top of every turn so the
    # orchestrator can detect rounds where the model did nothing
    # substantive (e.g. only narrated + called update_tasks({})).
    state.progress_this_turn = False
    if maybe_compact_transcript(state) and not json_emit:
        print(style(
            f"  ▸ context compacted (#{state.compact_count}); "
            f"transcript trimmed.", "tip"))
    elif json_emit and state.compact_count and len(state.transcript) <= 8:
        json_emit("compacted", count=state.compact_count)
    # 8.0.12: replace older tool-result bodies with one-line summaries
    # so each turn doesn't keep paying for 5-old read_file dumps. The
    # model can re-call any tool to fetch the full content back.
    pruned = prune_stale_tool_results(state)
    if pruned and not json_emit:
        print(style(f"  ▸ pruned {pruned} stale tool result(s)", "dim"))
    # Flush any external file-change notifications collected by the watcher.
    ext_note = flush_external_change_notes(state)
    if ext_note:
        state.transcript.append({"role": "system", "content": ext_note})
        if not json_emit:
            print(style("  ▸ file_watcher: external changes flagged", "tip"))
    # user-prompt-submit hook: can reject the prompt (block=True returns
    # empty without sending to the model) and/or inject a system note.
    blocked, hook_note = run_hooks(
        state, "user-prompt-submit",
        {"prompt": user_message, "workspace": str(state.workspace)},
        blocking=True,
    )
    if hook_note:
        state.transcript.append({"role": "system",
                                  "content": "HOOK user-prompt-submit:\n"
                                             + hook_note})
        if not json_emit:
            print(style(f"  ▸ hook user-prompt-submit: "
                        f"{hook_note[:200]}", "tip"))
    if blocked:
        if not json_emit:
            print(style("  ▸ user-prompt-submit hook rejected the prompt",
                        "warning"))
        return ""
    user_payload = expand_mentions(user_message, state.workspace)
    state.transcript.append({"role": "user", "content": user_payload})
    state.absorb_text(user_payload)
    if json_emit:
        json_emit("user", text=user_message)

    for turn_index in range(1, DEFAULT_MAX_TURNS + 1):
        streamer = ThinkStreamer(
            quiet=bool(json_emit),
            emit_event=(lambda kind, text: json_emit(kind, text=text)) if json_emit else None,
            wrap=state.wrap,
        )
        finished_tool_calls = []
        had_content = False
        error_message = None
        first_chunk_seen = False
        spinner = Spinner("thinking") if not json_emit else None
        if spinner:
            spinner.__enter__()
        if json_emit:
            json_emit("turn_started", index=turn_index)

        # Multi-model routing: only the first turn uses the routed model;
        # subsequent tool-call rounds stay on the same model so partial
        # tool-call state doesn't get confused between models.
        active_model = (
            pick_model_for_turn(state, user_message)
            if turn_index == 1 else state.model
        )

        # Speculative prefetch state for this turn.
        narration_so_far = ""
        prefetched_keys = set()

        with EscWatcher() as esc:
            essential_only = getattr(state, "essential_tools_only", False)
            # 8.0.9: cap output to state.max_tokens (default 4096) so a
            # runaway narration can't waste 60s on prose. Text-mode
            # families also get stop tokens at the end of a tool_call
            # fence - the moment the model closes the block we cut the
            # stream rather than letting it ramble.
            stop_seq = None
            if (state.adapter and not state.adapter.native_tools
                    and state.early_stop_text_tool_call):
                stop_seq = ["\n```\n", "</tool_call>"]
            stream = stream_completion(
                state.base_url, active_model,
                state.transcript,
                _all_tool_schemas(state, essential_only=essential_only),
                max_tokens=state.max_tokens,
                stop=stop_seq,
            )
            try:
                for kind, data in stream:
                    if esc.check():
                        raise EscInterrupt
                    if kind == "content":
                        if spinner and not first_chunk_seen:
                            spinner.stop()
                            spinner = None
                            sys.stdout.write("  ")
                        first_chunk_seen = True
                        had_content = True
                        streamer.feed(data)
                        narration_so_far += data
                        # Best-effort speculative prefetch: scan the live
                        # narration for file mentions; when a new file is
                        # named, fire off a read_file in the background and
                        # stash the result.
                        if (state.prefetch_enabled
                                and len(narration_so_far) % 64 == 0):
                            _kick_speculative_prefetch(
                                state, narration_so_far, prefetched_keys)
                    elif kind == "tool_call":
                        if spinner and not first_chunk_seen:
                            spinner.stop()
                            spinner = None
                        finished_tool_calls.append(data)
                    elif kind == "error":
                        if spinner:
                            spinner.stop()
                            spinner = None
                        error_message = data
                        break
                    elif kind == "done":
                        if spinner:
                            spinner.stop()
                            spinner = None
                        break
            finally:
                stream.close()
                if spinner:
                    spinner.stop()
        # Final scan in case the stream ended without crossing the periodic
        # mod-64 boundary.
        if state.prefetch_enabled:
            _kick_speculative_prefetch(state, narration_so_far, prefetched_keys)

        assistant_text = streamer.finish()
        state.absorb_text(assistant_text)
        if had_content and not assistant_text.endswith("\n") and not json_emit:
            print()
        if error_message:
            # Auto-recover from "n_keep > n_ctx" by retrying once with the
            # essentials-only tool set. The full 70-tool schema set is
            # ~5-7k tokens and a model loaded with a 4k context can't fit
            # it. Without this retry the user sees an error and gives up.
            if ("n_keep" in error_message and "n_ctx" in error_message
                    and not getattr(state, "essential_tools_only", False)):
                state.essential_tools_only = True
                if not json_emit:
                    print(style(
                        "  ⚠ context too small for full tool surface; "
                        "retrying with essentials only. Reload LM Studio "
                        "with a larger context (32k+) for the full toolkit.",
                        "warning"))
                else:
                    json_emit("tool_surface_reduced",
                              message="essentials-only due to small context")
                continue
            if json_emit:
                json_emit("error", message=error_message)
            else:
                print(style(f"  {GLYPH_ERR} {error_message}", "err"))
            return ""

        # 8.0.5: text-mode tool extraction. Some model families (Gemma,
        # base Llama-3, Phi-3) never populate the structured tool_calls
        # field - they emit the call as JSON inside the assistant text.
        # Even native-tool families occasionally fall back to text on
        # tricky prompts. The ModelAdapter parses both forms; we always
        # check when nothing native came through.
        if (not finished_tool_calls and state.adapter
                and assistant_text.strip()):
            schema_names = set(BUILTIN_TOOL_FUNCS.keys())
            for client in state.mcp_clients:
                for tool in client.tools:
                    schema_names.add(f"mcp__{tool['name']}")
            extracted = state.adapter.parse_tool_calls_from_text(
                assistant_text, schema_names)
            if extracted:
                finished_tool_calls = extracted
                if json_emit:
                    json_emit("tool_calls_extracted",
                              count=len(extracted),
                              family=state.adapter.family)
                else:
                    print(style(
                        f"  ▸ extracted {len(extracted)} tool call(s) "
                        f"from assistant text ({state.adapter.family} "
                        f"text-mode)", "tip"))

        assistant_entry = {"role": "assistant", "content": assistant_text}
        if finished_tool_calls:
            assistant_entry["tool_calls"] = [
                {"id": tc["id"], "type": "function",
                 "function": {"name": tc["name"], "arguments": tc["arguments"]}}
                for tc in finished_tool_calls
            ]
        state.transcript.append(assistant_entry)

        # Mermaid: if the assistant turn contained ```mermaid blocks, try
        # to render each one to a PNG (silent skip when mmdc not installed).
        rendered = render_mermaid_blocks(state, assistant_text)
        if rendered and not json_emit:
            head = style(GLYPH_TOOL, "tool")
            print(f"  {head} {style('mermaid', 'key')} "
                  f"{style(', '.join(rendered), 'dim')}")

        if not finished_tool_calls:
            # Don't auto-mark-complete here - the continuation policy may
            # want to push the model to actually do the work.
            state.last_turn_had_tool_calls = False
            if not json_emit:
                draw_task_list(state.sink.current)
            if json_emit:
                json_emit("completed", text=assistant_text)
            return assistant_text
        state.last_turn_had_tool_calls = True

        if not json_emit:
            print()
        # Partition tool calls into safe (parallel) vs dangerous (serial).
        # Safe set is whitelist-only; everything else stays serial so
        # permission prompts don't stack and writes happen in order.
        parsed_calls = []
        for call in finished_tool_calls:
            name = call["name"]
            try:
                args = json.loads(call["arguments"] or "{}")
            except json.JSONDecodeError:
                args = {}
            parsed_calls.append((call, name, args))

        # Render call lines up-front in original order so the user sees
        # what's about to run even though execution interleaves.
        if not json_emit:
            for _, name, args in parsed_calls:
                _render_tool_call_line(name, args)

        if json_emit:
            for _, name, args in parsed_calls:
                json_emit("tool_call", name=name, arguments=args)

        results_in_order = [None] * len(parsed_calls)
        # Run safe calls in parallel.
        safe_indices = [i for i, (_, n, _) in enumerate(parsed_calls)
                        if n in SAFE_PARALLEL_TOOLS]
        if len(safe_indices) > 1:
            import concurrent.futures
            with concurrent.futures.ThreadPoolExecutor(
                    max_workers=min(4, len(safe_indices))) as pool:
                future_to_idx = {
                    pool.submit(_dispatch_tool, state, parsed_calls[i][1],
                                parsed_calls[i][2], narration=assistant_text):
                    i for i in safe_indices
                }
                for fut in concurrent.futures.as_completed(future_to_idx):
                    i = future_to_idx[fut]
                    try:
                        results_in_order[i] = fut.result()
                    except Exception as e:
                        results_in_order[i] = f"Error: {e}"
        else:
            for i in safe_indices:
                _, n, a = parsed_calls[i]
                try:
                    results_in_order[i] = _dispatch_tool(
                        state, n, a, narration=assistant_text)
                except Exception as e:
                    results_in_order[i] = f"Error: {e}"

        # Dangerous calls run sequentially, in original order.
        for i, (_, n, a) in enumerate(parsed_calls):
            if results_in_order[i] is not None:
                continue  # already done in safe batch
            try:
                results_in_order[i] = _dispatch_tool(
                    state, n, a, narration=assistant_text)
            except Exception as e:
                results_in_order[i] = f"Error: {e}"

        # Commit results to transcript + UI in original order.
        for (call, name, args), result_text in zip(parsed_calls,
                                                   results_in_order):
            state.absorb_text(result_text)
            if json_emit:
                json_emit("tool_result", name=name, text=result_text)
            state.transcript.append({"role": "tool",
                                     "tool_call_id": call["id"],
                                     "content": result_text})
            if not json_emit:
                if name == "update_tasks":
                    draw_task_list(state.sink.current)
                elif name in FS_MUTATING_TOOLS and state.last_diff:
                    path, old, new = state.last_diff
                    draw_diff(path, old, new)
                    state.last_diff = None

        # Collect what was mutated this turn, for the auto-test /
        # auto-screenshot / auto-commit hooks below.
        mutated_paths = [
            args.get("path", "")
            for (_, name, args) in parsed_calls
            if name in FS_MUTATING_TOOLS
        ]

        # Auto-test hook: if anything mutated a known test-related file,
        # run the detected framework once at the end of the turn and
        # surface the failure tail as a synthetic tool result.
        if state.auto_test and mutated_paths:
            runner = detect_test_runner(state.workspace)
            if runner and any(path_matches_test(p, runner["file_globs"])
                              for p in mutated_paths):
                note = run_auto_test(state)
                if note:
                    if not json_emit:
                        head = style(GLYPH_TOOL, "tool")
                        print(f"  {head} {style('auto_test', 'key')} "
                              f"{style(runner['name'], 'dim')}")
                        print(style(textwrap_short(note, 200), "dim"))
                    state.transcript.append({
                        "role": "system",
                        "content": "ORCHESTRATOR auto-test: " + note,
                    })

        # Auto-screenshot hook: if anything mutated a UI file, render +
        # screenshot via the headless browser and feed the OCR back.
        if state.auto_screenshot and mutated_paths:
            shot_note = maybe_auto_screenshot(state, mutated_paths)
            if shot_note:
                if not json_emit:
                    head = style(GLYPH_TOOL, "tool")
                    print(f"  {head} {style('auto_screenshot', 'key')}")
                state.transcript.append({
                    "role": "system",
                    "content": shot_note,
                })

        # Auto-commit hook: if a task just flipped to completed AND
        # auto_commit is on, stage+commit the journaled changes.
        if state.auto_commit:
            just_completed = [
                t for t in state.sink.current
                if t.get("status") == "completed"
            ]
            commit_note = maybe_auto_commit(state, just_completed)
            if commit_note and not json_emit:
                head = style(GLYPH_TOOL, "tool")
                print(f"  {head} {style('auto_commit', 'key')} "
                      f"{style(commit_note, 'dim')}")

        # Aggressive batching: if the model just emitted update_tasks with
        # multiple file-create steps still pending, execute them in batch
        # via grammar-forced write_file. Saves N round trips.
        if (state.aggressive_batching
                and any(n == "update_tasks" for _, n, _ in parsed_calls)):
            batch = aggressive_batch_steps(state, assistant_text, json_emit)
            if batch:
                summary = "\n".join(
                    f"  - task #{r['index']}: " + r["path"]
                    + (" ✓" if r["ok"] else f" ✗ {r['message']}")
                    for r in batch
                )
                if not json_emit:
                    head = style(GLYPH_TOOL, "tool")
                    print(f"  {head} {style('aggressive_batch', 'key')} "
                          f"({len(batch)} steps)")
                    print(style(summary, "dim"))
                state.transcript.append({
                    "role": "system",
                    "content": ("ORCHESTRATOR aggressive_batch: ran "
                                f"{len(batch)} step(s) ahead.\n" + summary),
                })

        if not json_emit:
            print()

    if json_emit:
        json_emit("error", message=f"max_turns={DEFAULT_MAX_TURNS} hit")
    else:
        print(style(f"  (stopped: hit max_turns={DEFAULT_MAX_TURNS})", "err"))
    return ""


def drive_user_message(state, user_message, *, json_emit=None):
    """Run a user-issued message through the agent loop, then keep
    re-driving the model with synthetic continuation prompts whenever the
    orchestrator detects an unfinished turn. Each continuation counts
    against state.max_continuations; the budget resets per human input.

    This is the layer that stops a 35B local model from giving up after
    one turn: pending tasks AND post-completion promise narration both
    force another round. Returns the final assistant text."""
    state.continuation_count = 0
    state.zero_progress_streak = 0
    state.rescues_this_turn = 0
    final_text = run_turn(state, user_message, json_emit=json_emit)

    if not state.auto_continue:
        if not state.last_turn_had_tool_calls:
            state.sink.mark_remaining_complete()
        return final_text

    stopped_for_zero_progress = False
    while state.continuation_count < state.max_continuations:
        followup = should_auto_continue(state, final_text)
        if not followup:
            break
        # 8.0.3: zero-progress guard. The PRIOR run_turn just finished, so
        # state.progress_this_turn reflects what that round actually did.
        # If consecutive rounds make no progress (model only narrates, or
        # spams update_tasks({}) with no status flip and no tool calls),
        # break out and hand control back to the user instead of looping
        # to max_continuations.
        if state.progress_this_turn:
            state.zero_progress_streak = 0
        else:
            state.zero_progress_streak += 1
        if state.zero_progress_streak >= state.max_zero_progress_streak:
            # 8.0.6: before giving up, try one last grammar-forced rescue
            # for text-mode families. If we can infer a tool from the
            # model's last narration, run it via grammar-constrained
            # generation and let the loop continue from the new state.
            rescued = False
            if (state.adapter and not state.adapter.native_tools
                    and state.grammar_supported
                    and state.rescues_this_turn < state.max_rescues_per_turn):
                rescue_note = rescue_force_tool_call(state)
                if rescue_note:
                    state.rescues_this_turn += 1
                    if json_emit:
                        json_emit("orchestrator_rescue", action=rescue_note)
                    else:
                        print()
                        print(style(
                            f"  ▸ orchestrator rescue: {rescue_note}",
                            "tip"))
                    state.zero_progress_streak = 0
                    state.progress_this_turn = True
                    rescued = True
            if not rescued:
                stopped_for_zero_progress = True
                if json_emit:
                    json_emit("orchestrator_stopped",
                              attempts=state.continuation_count,
                              reason="zero_progress")
                else:
                    print()
                    print(style(
                        f"  orchestrator stopped after "
                        f"{state.zero_progress_streak} unproductive "
                        f"continuation(s) - the model kept narrating "
                        f"without using tools. Control returned to you.",
                        "warning"))
                break
        state.continuation_count += 1
        if json_emit:
            json_emit("auto_continue",
                      attempt=state.continuation_count,
                      message=followup)
        else:
            print()
            print(style(
                f"  ▸ orchestrator continuation #{state.continuation_count} "
                f"of {state.max_continuations}", "tip"))
            reason = followup.split("\n", 1)[0]
            if len(reason) > 90:
                reason = reason[:90] + "…"
            print(style("    " + reason, "dim"))
            print()
        final_text = run_turn(state, followup, json_emit=json_emit)

    if (not stopped_for_zero_progress
            and state.continuation_count >= state.max_continuations):
        if json_emit:
            json_emit("orchestrator_stopped",
                      attempts=state.continuation_count)
        else:
            print()
            print(style(
                f"  orchestrator stopped after {state.max_continuations} "
                "continuations - control returned to you.", "warning"))

    # Once the orchestrator gives up, anything still pending/in_progress
    # gets flipped to completed so the visible task list isn't stuck.
    state.sink.mark_remaining_complete()
    # Drain any followups queued by tool handlers mid-turn (e.g. ship_it
    # queues a scaffold + commit follow-up to avoid recursive run_turn).
    try:
        drain_queued_followups(state, json_emit=json_emit)
    except Exception as e:
        if not json_emit:
            print(style(f"  followup drain failed: {e}", "warning"))
    # Self-reflection at the very end of the human-issued turn (after all
    # continuations have run). Saves the lesson into project_knowledge so
    # future sessions benefit.
    if state.self_reflect:
        try:
            reflect_on_turn(state)
        except Exception:
            pass
    return final_text


# Smallest viable tool set when the model's actual runtime context is too
# tight to fit the full 70+ schemas. Surface-level "essentials" only.
ESSENTIAL_TOOL_NAMES = {
    "read_file", "write_file", "edit_file", "multi_edit",
    "list_dir", "glob", "grep", "find_todos",
    "update_tasks", "run_bash", "spawn_agent",
    "git_status", "git_diff",
    "ask_user", "save_memory",
}


def _all_tool_schemas(state, *, essential_only=False):
    if essential_only:
        schemas = [s for s in BUILTIN_TOOL_SCHEMAS
                   if (s.get("function") or {}).get("name") in ESSENTIAL_TOOL_NAMES]
    else:
        schemas = list(BUILTIN_TOOL_SCHEMAS)
    schemas.extend(build_mcp_tool_schemas(state.mcp_clients))
    return schemas


def _render_tool_call_line(name, args):
    preview = json.dumps(args, separators=(", ", ": "))
    width = box_width()
    if len(preview) > width - 14:
        preview = preview[: width - 15] + "…"
    head = style(GLYPH_TOOL, "tool") + " " + style(name, "key")
    print(f"  {head} {style(preview, 'dim')}")


def _dispatch_tool(state, name, args, *, narration=""):
    """Run a tool through the orchestrator pipeline:

      1. Loop detection - if this would be the third identical failed
         attempt in a row, return an intervention message instead.
      2. Argument repair - fill obvious missing fields (path, command)
         by scanning the model's recent narration.
      3. Permission gate - prompts y/n/a for dangerous tools.
      4. Dispatch.

    Every call (including interventions) is appended to state.tool_history
    so subsequent calls can detect the loop pattern."""

    args_in = args if isinstance(args, dict) else {}
    canonical_in = _canonical(args_in)

    # pre-tool-use hook. Can reject before any orchestrator logic runs.
    blocked, hook_note = run_hooks(
        state, "pre-tool-use",
        {"name": name, "args": args_in},
        blocking=True,
    )
    if hook_note:
        # Surface in scrollback (not in tool result; that goes to model).
        _render_tool_result_summary(name, f"hook: {hook_note[:160]}", True)
    if blocked:
        state.tool_history.append({
            "name": name, "args": canonical_in, "error": True,
        })
        return f"Hook pre-tool-use rejected `{name}`:\n{hook_note}"

    # Constitution hard guardrail. Refuse BEFORE any other logic so the
    # model can't talk itself out of the rule via continuation/repair.
    if state.constitution_rules:
        violation = constitution_violation(state, name, args_in)
        if violation:
            _render_tool_result_summary(name, f"constitution: {violation}",
                                        False)
            state.tool_history.append({
                "name": name, "args": canonical_in, "error": True,
            })
            return ("ORCHESTRATOR constitution: refused. " + violation
                    + "\n\nThe workspace constitution forbids this. "
                    "Re-think your approach within the rules; do not retry "
                    "this exact call.")

    if name in BUILTIN_TOOL_FUNCS and detect_repeat_failure(
            state.tool_history, name, canonical_in):
        intervention = build_intervention_message(
            name, args_in, schema_summary_for(name))
        if name in ("write_file", "edit_file", "read_file", "list_dir"):
            # Include the workspace root so the model can pick a concrete
            # relative path without re-scanning scrollback. Paths may
            # contain spaces (we tilde-expand internally, so anything
            # under the workspace is fair game).
            intervention += (
                "\n\nWorkspace root (relative paths resolve from here): "
                + str(state.workspace)
                + "\n"
                + "If the directory you want to write into doesn't exist "
                "yet, write_file will create it automatically."
            )
        _render_tool_result_summary(name, "orchestrator intervened (loop)", False)
        state.tool_history.append({
            "name": name, "args": canonical_in, "error": False,
        })
        return intervention

    repaired, repair_note = repair_args(state, name, args_in, narration)
    if repair_note:
        args_in = repaired

    # Grammar-constrained retry: when required args are STILL missing after
    # narration repair, ask the server for a strictly-schema-conforming JSON
    # object. The server-side decoder refuses to emit JSON that violates the
    # schema, so a non-None return is guaranteed to have every required
    # field. Skipped silently when the server doesn't support
    # response_format (probed at session start).
    if (state.grammar_supported and name in BUILTIN_TOOL_FUNCS
            and name != "update_tasks"):
        missing_before = missing_required(name, args_in)
        if missing_before:
            schema = schema_params_for(name)
            forced = force_grammar_args(
                state.base_url, state.model, state.transcript,
                name, schema, args_in, narration, state.workspace,
            ) if schema else None
            if forced and not missing_required(name, forced):
                merged = dict(args_in)
                merged.update(forced)
                args_in = merged
                grammar_note = ("grammar-filled "
                                + ", ".join("`" + k + "`" for k in missing_before))
                repair_note = (repair_note + "  " + grammar_note
                               if repair_note else grammar_note)

    # Fail-fast: after repair + grammar, if required args are still missing
    # AND the tool is a builtin, return a clean error with the schema
    # summary instead of letting the tool function raise KeyError into a
    # Python traceback that the model can't easily fix.
    if name in BUILTIN_TOOL_FUNCS and name != "update_tasks":
        still_missing = missing_required(name, args_in)
        if still_missing:
            schema_text = schema_summary_for(name)
            state.tool_history.append({
                "name": name, "args": _canonical(args_in), "error": True,
            })
            return (f"Error: `{name}` is missing required argument(s) "
                    f"{still_missing}. Schema:\n{schema_text}\n"
                    f"Re-emit the call with every required field filled in.")

    # Speculative cache lookup (only safe, read-only tools land here).
    cache_key = (name, _canonical(args_in))
    if name in SAFE_PARALLEL_TOOLS and state.prefetch_enabled:
        hit = state.prefetch_cache.get(cache_key)
        if hit and time.time() - hit["ts"] < 30:
            state.prefetch_hits += 1
            _render_tool_result_summary(name,
                                        "[prefetch hit] " + str(hit["result"]),
                                        True)
            state.tool_history.append({
                "name": name, "args": canonical_in, "error": False,
            })
            memory_record(state, name, args_in, str(hit["result"]))
            return hit["result"]

    try:
        # 8.0.10: plan mode hard-block. Catches any write/edit/bash/spawn
        # call regardless of permissions. Returns a clean error string
        # so the model sees what's blocked and why.
        if (state.mode["name"] == "plan"
                and name in PLAN_MODE_BLOCKED):
            state.tool_history.append({
                "name": name, "args": _canonical(args_in), "error": True,
            })
            return (
                f"Error: `{name}` is blocked - PLAN MODE is active. "
                "This turn is read-only. Continue planning, then Shift+Tab "
                "out of PLAN MODE before taking action. Allowed: read_file, "
                "list_dir, glob, grep, find_todos, git_status/diff/log, "
                "update_tasks."
            )
        if name == "update_tasks":
            # 8.0.3: refuse calls that omit `tasks` entirely. Pre-8.0.3 a
            # bare update_tasks({}) call would silently clear the visible
            # task list and the orchestrator would loop forever because the
            # model thought it had "checked in" while making zero progress.
            if not isinstance(args_in, dict) or "tasks" not in args_in:
                state.tool_history.append({
                    "name": name, "args": _canonical(args_in), "error": True,
                })
                return (
                    "Error: update_tasks requires a `tasks` array. Example: "
                    "update_tasks({\"tasks\": [{\"subject\": \"create app.py\", "
                    "\"activeForm\": \"Creating app.py\", \"status\": "
                    "\"pending\"}]}). The existing task list was NOT modified. "
                    "If you meant to act on the next task, use write_file or "
                    "edit_file instead - do not re-call update_tasks."
                )
            raw_tasks = args_in.get("tasks")
            if not isinstance(raw_tasks, list):
                state.tool_history.append({
                    "name": name, "args": _canonical(args_in), "error": True,
                })
                return (
                    "Error: update_tasks `tasks` must be an array. "
                    "Existing task list was NOT modified."
                )
            # 8.0.3/8.0.4: progress detection. We compare the model's
            # CLAIMED completions in `raw_tasks` against the prior list
            # using multiset semantics (collections.Counter) so duplicate
            # subjects don't collide. We snapshot the claim BEFORE calling
            # verify_task_completions, because verify mutates `raw_tasks`
            # in place (flipping failed completions back to in_progress),
            # which would otherwise erase the model's intent before we
            # could measure it. Final gate: only credit progress when
            # verify reports zero failures - if the model lied about a
            # completion, do not count the round as progress, otherwise
            # the zero-progress guard never trips on a model that
            # repeatedly bogus-completes tasks.
            prior_completed = Counter(
                (t.get("subject") or "")
                for t in (state.sink.current or [])
                if t.get("status") == "completed"
            )
            claimed_completed = Counter(
                (t.get("subject") or "")
                for t in raw_tasks
                if isinstance(t, dict) and t.get("status") == "completed"
            )
            failures = verify_task_completions(raw_tasks, state.workspace)
            count = state.sink.replace(raw_tasks)
            if (claimed_completed - prior_completed) and not failures:
                state.progress_this_turn = True
            result = f"Task list updated ({count} task{'' if count == 1 else 's'})."
            if failures:
                lines = "\n  - ".join(failures)
                result += (
                    "\n\nORCHESTRATOR verification: the following tasks were "
                    "flipped back to `in_progress` because their claimed "
                    "artifact is missing on disk:\n  - " + lines
                    + "\n\nFinish them now using `write_file` with the real "
                    "content. Do NOT just call update_tasks again."
                )
            state.tool_history.append({
                "name": name, "args": _canonical(args_in), "error": False,
            })
            return result
        if name.startswith("mcp__"):
            result = call_mcp_tool(state.mcp_clients, name, args_in)
            state.tool_history.append({
                "name": name, "args": _canonical(args_in), "error": False,
            })
            state.progress_this_turn = True
            return result
        if name == "run_bash" and not state.allow_bash:
            state.tool_history.append({
                "name": name, "args": canonical_in, "error": True,
            })
            return "Error: run_bash disabled. Use --allow-bash or /bash on."
        gate_set = DANGEROUS_TOOLS | DANGEROUS_TOOLS_EXTRA
        if name in gate_set and not state.permissions.gate(name, args_in):
            state.tool_history.append({
                "name": name, "args": _canonical(args_in), "error": True,
            })
            return f"Error: user denied {name}."
        func = BUILTIN_TOOL_FUNCS.get(name)
        if not func:
            state.tool_history.append({
                "name": name, "args": canonical_in, "error": True,
            })
            return f"Error: unknown tool {name}"
        _start = time.time()
        result = func(state, args_in)
        elapsed_ms = int((time.time() - _start) * 1000)
        cost_meter_record(state, name, elapsed_ms, args_in, result)
        _render_tool_result_summary(name, result, True)
        state.tool_history.append({
            "name": name, "args": _canonical(args_in), "error": False,
            "elapsed_ms": elapsed_ms,
        })
        # 8.0.3: every successful non-update_tasks tool counts as real
        # progress for the zero-progress guard. update_tasks has its own
        # path above (counts only on a real status flip).
        state.progress_this_turn = True
        memory_record(state, name, args_in, str(result))
        # post-tool-use hook. Stdout becomes a system note appended after
        # the tool result, so the model sees structured observations.
        _, hook_note = run_hooks(
            state, "post-tool-use",
            {"name": name, "args": args_in, "result": str(result)[:4000],
             "error": False},
        )
        if hook_note:
            result = (str(result) + "\n\n[hook post-tool-use]:\n"
                      + hook_note)
        if name in SAFE_PARALLEL_TOOLS and state.prefetch_enabled:
            state.prefetch_cache[cache_key] = {"ts": time.time(),
                                               "result": result}
            if len(state.prefetch_cache) > 128:
                # Trim oldest 32 entries.
                oldest = sorted(state.prefetch_cache.items(),
                                key=lambda kv: kv[1]["ts"])[:32]
                for k, _ in oldest:
                    state.prefetch_cache.pop(k, None)
        if repair_note:
            return result + "\n\n[orchestrator: " + repair_note + "]"
        return result
    except Exception as e:
        _render_tool_result_summary(name, str(e), False)
        state.tool_history.append({
            "name": name, "args": _canonical(args_in), "error": True,
        })
        # on-error hook (informational; can't unblock the failure).
        _, hook_note = run_hooks(
            state, "on-error",
            {"name": name, "args": args_in, "error": str(e)},
        )
        msg = "Error: " + str(e)
        if repair_note:
            msg += ("\n\n[orchestrator: " + repair_note
                    + " - but the tool still failed, so the inferred value "
                      "may be wrong]")
        if hook_note:
            msg += "\n\n[hook on-error]:\n" + hook_note
        return msg


def _render_tool_result_summary(name, result, ok):
    if not isinstance(result, str):
        result = str(result)
    first = result.splitlines()[0] if result else "(no output)"
    width = box_width()
    if len(first) > width - 6:
        first = first[: width - 7] + "…"
    glyph = GLYPH_OK if ok else GLYPH_ERR
    role = "ok" if ok else "err"
    if name != "update_tasks":  # update_tasks renders its own box
        print(f"    {style(glyph, role)} {style(first, 'dim')}")


# =============================================================================
# Slash commands
# =============================================================================

class SlashRouter:
    def __init__(self, state):
        self.state = state
        self.commands = {
            "/help":    self.cmd_help,
            "/quit":    self.cmd_quit,
            "/exit":    self.cmd_quit,
            "/clear":   self.cmd_clear,
            "/model":   self.cmd_model,
            "/bash":    self.cmd_bash,
            "/cwd":     self.cmd_cwd,
            "/cost":    self.cmd_cost,
            "/tasks":   self.cmd_tasks,
            "/save":    self.cmd_save,
            "/resume":  self.cmd_resume,
            "/sessions": self.cmd_sessions,
            "/system":  self.cmd_system,
            "/sh":      self.cmd_sh,
            "/yolo":    self.cmd_yolo,
            "/theme":   self.cmd_theme,
            "/wrap":    self.cmd_wrap,
            "/auto":    self.cmd_auto,
            "/compact": self.cmd_compact,
            "/undo":    self.cmd_undo,
            "/journal": self.cmd_journal,
            "/diff":    self.cmd_diff,
            "/test":    self.cmd_test,
            "/recall":  self.cmd_recall,
            "/preview": self.cmd_preview,
            "/branch":  self.cmd_branch,
            "/branches": self.cmd_branches,
            "/checkout": self.cmd_checkout,
            "/merge":   self.cmd_merge,
            "/router":  self.cmd_router,
            "/prefetch": self.cmd_prefetch,
            "/screenshot": self.cmd_screenshot,
            "/batch":   self.cmd_batch,
            "/autocommit": self.cmd_autocommit,
            "/persona": self.cmd_persona,
            "/lsp":     self.cmd_lsp,
            "/watch":   self.cmd_watch,
            "/reflect": self.cmd_reflect,
            "/plugins": self.cmd_plugins,
            "/constitution": self.cmd_constitution,
            "/ship":    self.cmd_ship,
            "/web":     self.cmd_web,
            "/blocklist": self.cmd_blocklist,
            "/hooks":   self.cmd_hooks,
            "/wake":    self.cmd_wake,
            "/settings": self.cmd_settings,
            "/bg":      self.cmd_bg,
            "/mon":     self.cmd_mon,
            "/kill":    self.cmd_kill,
            "/nb":      self.cmd_nb,
            "/skill":   self.cmd_skill,
            "/memory":  self.cmd_memory,
            "/model-info": self.cmd_model_info,
            "/tools":   self.cmd_tools,
            "/autoscale": self.cmd_autoscale,
            "/mode":    self.cmd_mode,
            "/models":  self.cmd_models,
            "/load":    self.cmd_load,
            "/unload":  self.cmd_unload,
        }

    def names(self):
        names = set(self.commands.keys())
        names.update(f"/{n}" for n in self.state.slash_command_files)
        return sorted(names)

    def dispatch(self, line):
        head, _, rest = line.partition(" ")
        handler = self.commands.get(head)
        if handler:
            return handler(rest.strip())
        # Fall through to discovered slash command files
        # (~/.loom/commands/<name>.md and workspace overrides).
        cmd_name = head.lstrip("/")
        meta = self.state.slash_command_files.get(cmd_name)
        if meta:
            body = meta["body"].replace("$ARGS", rest.strip())
            if meta.get("model"):
                # Per-command model override for this turn only.
                prev = self.state.model
                self.state.model = meta["model"]
                try:
                    drive_user_message(self.state, body)
                finally:
                    self.state.model = prev
            else:
                drive_user_message(self.state, body)
            return "continue"
        print(style(f"  unknown command: {head}", "warning"))
        print(style(f"  type /help for the list", "dim"))
        return "continue"

    # --- handlers ---
    def cmd_help(self, _):
        draw_tips()
        print(style(" Slash commands", "tip"))
        for name in self.names():
            print(f"   {style(name, 'key')}")
        print()
        return "continue"

    def cmd_quit(self, _):
        return "exit"

    def cmd_clear(self, _):
        self.state.reset_transcript()
        self.state.approx_tokens = 0
        print(style("  session cleared.", "ok"))
        return "continue"

    def cmd_model(self, rest):
        if not rest:
            try:
                loaded = fetch_loaded_models(self.state.base_url)
            except RuntimeError as e:
                print(style(f"  {e}", "err"))
                return "continue"
            if not loaded:
                print(style("  no models loaded.", "warning"))
                return "continue"
            print(style("  Loaded models:", "key"))
            for m in loaded:
                marker = "*" if m == self.state.model else " "
                print(f"   {marker} {m}")
            print(style(f"  current: {self.state.model}", "dim"))
            return "continue"
        self.state.model = rest
        # 8.0.5: rebuild the adapter for the new model so capabilities
        # are correct after a /model switch.
        self.state.adapter = ModelAdapter(rest)
        self.state.essential_tools_only = self.state.adapter.default_essential_only
        print(style(f"  model set to {rest}", "ok"))
        print(style(f"  family detected: {self.state.adapter.family} "
                    f"(native_tools={self.state.adapter.native_tools})", "dim"))
        return "continue"

    def cmd_model_info(self, _):
        """Show what the adapter detected about the currently loaded model
        so the user can verify capabilities before debugging."""
        a = self.state.adapter
        print(style("  Model adapter", "key"))
        print(f"   model:           {a.model_id}")
        print(f"   family:          {a.family}")
        print(f"   native tools:    {'yes' if a.native_tools else 'no'}")
        print(f"   text fallback:   on (always)")
        print(f"   reasoning field: "
              f"{'yes' if a.uses_reasoning else 'no'}")
        print(f"   essential-only:  "
              f"{'on' if self.state.essential_tools_only else 'off'}")
        print(f"   grammar:         "
              f"{'on' if self.state.grammar_supported else 'off'}")
        print(f"   context window:  "
              f"{self.state.context_window or 'unknown'}")
        if not a.native_tools:
            print()
            print(style(
                "  This family does not emit native tool_calls. Tool "
                "invocations are extracted from JSON in the assistant "
                "response text. Performance is acceptable for write_file "
                "/ edit_file workloads but multi-tool turns may be slower.",
                "dim"))
        return "continue"

    def cmd_models(self, _):
        """List all local LLMs on disk. Marks loaded ones, shows params
        size, context cap, and tool-use status. Useful before /load."""
        try:
            loaded = set(fetch_loaded_models(self.state.base_url))
        except Exception:
            loaded = set()
        available = fetch_available_models(local_only=True,
                                            tool_use_only=False)
        if not available:
            print(style("  no local models found on disk.", "warning"))
            print(style("  download one via the LM Studio app.", "dim"))
            return "continue"
        print(style("  Local LLMs on disk:", "key"))
        # Group by tool-use status; tool-use first.
        tool_use = [m for m in available if m["tool_use"]]
        no_tu = [m for m in available if not m["tool_use"]]
        for header, group in (("  tool-use trained:", tool_use),
                                ("  no tool-use (use sparingly):", no_tu)):
            if not group:
                continue
            print(style(header, "dim"))
            for m in sorted(group, key=lambda x: x.get("paramsB") or 999):
                marker = "*" if m["key"] in loaded else " "
                sz = (f"{m['paramsB']}B"
                      if m.get("paramsB") else m.get("params_raw", "?"))
                ctx = m.get("context") or 0
                ctx_str = (f"{ctx//1024}k ctx" if ctx >= 1024
                           else f"{ctx} ctx")
                bytes_gb = (m.get("size_bytes") or 0) / 1e9
                print(f"   {marker} {style(m['key'], 'value'):40s} "
                      f"{style(sz, 'tip'):8s} "
                      f"{style(ctx_str, 'dim'):12s} "
                      f"{style(f'{bytes_gb:.1f} GB', 'dim')}")
        print()
        print(style("  /load <key>   load a model (auto unloads "
                    "the current one)", "dim"))
        print(style("  /unload <key> unload a specific model", "dim"))
        return "continue"

    def cmd_load(self, rest):
        """Load a model via the lms CLI. Equivalent to running
        `lms load <id> -y --parallel 1 -c <ctx>` from the shell."""
        rest = rest.strip()
        if not rest:
            print(style("  usage: /load <model-key> [context]", "dim"))
            print(style("  e.g.   /load jan-v1-4b 16384", "dim"))
            return "continue"
        parts = rest.split()
        model_key = parts[0]
        ctx = 16384
        if len(parts) > 1:
            try:
                ctx = int(parts[1])
            except ValueError:
                print(style(f"  invalid context: {parts[1]}", "err"))
                return "continue"
        lms_cmd = _locate_lms_cli()
        if not lms_cmd:
            print(style("  lms CLI not found", "err"))
            return "continue"
        print(style(f"  loading {model_key} (ctx={ctx}, parallel=1)…",
                    "tip"))
        try:
            proc = subprocess.run(
                [lms_cmd, "load", model_key, "-y",
                 "--parallel", "1", "-c", str(ctx), "--gpu", "max"],
                capture_output=True, timeout=180,
            )
        except subprocess.TimeoutExpired:
            print(style("  lms load timed out", "err"))
            return "continue"
        if proc.returncode != 0:
            err = (proc.stderr or b"").decode("utf-8", "replace")[:200]
            print(style(f"  lms load failed: {err}", "err"))
            return "continue"
        # Switch the active model + rebuild adapter for the new family.
        self.state.model = model_key
        self.state.adapter = ModelAdapter(model_key)
        self.state.essential_tools_only = (
            self.state.adapter.default_essential_only)
        self.state.context_window = fetch_model_context_window(
            self.state.base_url, model_key)
        print(style(
            f"  loaded {model_key} · family={self.state.adapter.family} "
            f"· {self.state.context_window or '?'}-tok context", "ok"))
        return "continue"

    def cmd_unload(self, rest):
        """Unload a specific model (or the current one if no arg)."""
        rest = rest.strip()
        target = rest or self.state.model
        if not target:
            print(style("  usage: /unload <model-key>", "dim"))
            return "continue"
        lms_cmd = _locate_lms_cli()
        if not lms_cmd:
            print(style("  lms CLI not found", "err"))
            return "continue"
        try:
            proc = subprocess.run([lms_cmd, "unload", target],
                                   capture_output=True, timeout=30)
        except subprocess.TimeoutExpired:
            print(style("  unload timed out", "err"))
            return "continue"
        if proc.returncode != 0:
            err = (proc.stderr or b"").decode("utf-8", "replace")[:200]
            print(style(f"  unload failed: {err}", "err"))
            return "continue"
        print(style(f"  unloaded {target}", "ok"))
        return "continue"

    def cmd_mode(self, rest):
        """Show the active mode or switch to one by name. Same cycle as
        Shift+Tab but typed: /mode (show), /mode plan, /mode default,
        /mode auto-accept."""
        rest = rest.strip().lower()
        if not rest:
            cur = self.state.mode
            print(style(f"  mode: {cur['label']}", "key"))
            print(style(f"  {cur['blurb']}", "dim"))
            print()
            for i, m in enumerate(MODES):
                marker = "*" if i == self.state.mode_index else " "
                print(f"   {marker} {style(m['label'], m['color'])} "
                      f"{style('— ' + m['blurb'], 'dim')}")
            print()
            print(style("  /mode <name> to switch · "
                        "Shift+Tab to cycle inline", "dim"))
            return "continue"
        names = [m["name"] for m in MODES]
        targets = {n: i for i, n in enumerate(names)}
        targets.update({m["label"].lower(): i for i, m in enumerate(MODES)})
        if rest not in targets:
            print(style(f"  unknown mode: {rest}", "warning"))
            print(style(f"  available: {', '.join(names)}", "dim"))
            return "continue"
        # Roll the index until we reach the target so cycle_mode() side
        # effects all fire in order. (Simpler than duplicating the
        # transition logic here.)
        while self.state.mode_index != targets[rest]:
            self.state.cycle_mode()
        cur = self.state.mode
        print(style(f"  mode: {cur['label']} — {cur['blurb']}",
                    cur["color"]))
        return "continue"

    def cmd_autoscale(self, rest):
        """Manually trigger context auto-scale, or query current state."""
        rest = rest.strip()
        info = fetch_model_info(self.state.base_url, self.state.model)
        if not info:
            print(style("  could not query /api/v0/models", "warning"))
            return "continue"
        loaded = info.get("loaded_context_length")
        cap = info.get("max_context_length")
        print(style(f"  model:     {self.state.model}", "key"))
        print(style(f"  loaded:    {loaded}", "value"))
        print(style(f"  cap:       {cap}", "dim"))
        if not rest:
            print(style(
                "  usage: /autoscale <target>  - bump context to <target>\n"
                "         /autoscale max       - bump to model cap\n"
                "         /autoscale 32768     - bump to 32k", "dim"))
            return "continue"
        if rest == "max":
            target = cap
        else:
            try:
                target = int(rest)
            except ValueError:
                print(style(f"  invalid target: {rest}", "err"))
                return "continue"
        if not isinstance(target, int) or target <= 0:
            print(style("  invalid target", "err"))
            return "continue"
        ok, msg, new_loaded = auto_scale_context(
            self.state.base_url, self.state.model,
            target_minimum=target, max_target=target,
        )
        if ok:
            print(style(f"  {msg}", "ok"))
            if new_loaded:
                self.state.context_window = new_loaded
        else:
            print(style(f"  {msg}", "err"))
        return "continue"

    def cmd_tools(self, rest):
        """Switch between the essentials-only tool subset (15 tools) and
        the full surface (70+). The adapter chooses the default at session
        start; this is the manual override."""
        opt = rest.strip().lower()
        if opt in ("full", "off", "all"):
            self.state.essential_tools_only = False
            print(style("  full tool surface enabled "
                        "(70+ tools)", "ok"))
        elif opt in ("essential", "essentials", "on", "min"):
            self.state.essential_tools_only = True
            print(style("  essentials-only tool surface "
                        "(15 tools)", "ok"))
        else:
            current = ("essentials" if self.state.essential_tools_only
                       else "full")
            print(style(f"  tool surface: {current}", "key"))
            print(style(
                "  /tools full  - all 70+ builtins (needs ~32k context)\n"
                "  /tools essentials - 15-tool subset for tight contexts",
                "dim"))
        return "continue"

    def cmd_bash(self, rest):
        if rest in ("on", "yes", "true"):
            self.state.allow_bash = True
        elif rest in ("off", "no", "false"):
            self.state.allow_bash = False
        else:
            self.state.allow_bash = not self.state.allow_bash
        print(style(f"  run_bash {'enabled' if self.state.allow_bash else 'disabled'}", "ok"))
        return "continue"

    def cmd_cwd(self, rest):
        if not rest:
            print(style(f"  workspace: {self.state.workspace}", "key"))
            return "continue"
        path = Path(rest).expanduser().resolve()
        if not path.is_dir():
            print(style(f"  not a directory: {path}", "err"))
            return "continue"
        self.state.workspace = path
        self.state.context_text, self.state.context_files = load_project_context(path)
        self.state.refresh_workspace_tree()
        self.state.project_knowledge_text, self.state.project_knowledge = (
            load_project_knowledge(path)
        )
        self.state.persona_text, self.state.persona_source = load_persona(path)
        load_permission_grants(self.state)
        self.state.reset_transcript()
        print(style(f"  workspace -> {path}", "ok"))
        if self.state.context_files:
            print(style(f"  loaded context: {', '.join(self.state.context_files)}", "dim"))
        if self.state.workspace_tree_count:
            print(style(
                f"  workspace tree: {self.state.workspace_tree_count} entries",
                "dim"))
        return "continue"

    def cmd_cost(self, _):
        elapsed = int(time.time() - self.state.started_at)
        rate = self.state.approx_tokens / elapsed if elapsed > 0 else 0
        print(f"  {style('tokens (approx)', 'key')}  {self.state.approx_tokens:,}")
        if self.state.context_window:
            pct = self.state.approx_tokens * 100 / self.state.context_window
            print(f"  {style('window', 'key')}          "
                  f"{self.state.approx_tokens:,}/"
                  f"{self.state.context_window:,} ({pct:.0f}%)")
        print(f"  {style('elapsed', 'key')}         {elapsed}s")
        print(f"  {style('rate', 'key')}            {rate:.1f} tok/s (rough)")
        if self.state.prefetch_hits or self.state.prefetch_misses:
            print(f"  {style('prefetch', 'key')}        "
                  f"hits={self.state.prefetch_hits} "
                  f"misses={self.state.prefetch_misses}")
        if self.state.cost_breakdown:
            print()
            print(style("  Per-tool breakdown:", "key"))
            print(render_cost_breakdown(self.state))
        return "continue"

    def cmd_tasks(self, _):
        if not self.state.sink.current:
            print(style("  no tasks yet.", "dim"))
        else:
            draw_task_list(self.state.sink.current)
        return "continue"

    def cmd_save(self, rest):
        name = rest or None
        try:
            path = save_session(self.state, name)
            print(style(f"  saved -> {path}", "ok"))
        except OSError as e:
            print(style(f"  save failed: {e}", "err"))
        return "continue"

    def cmd_resume(self, rest):
        try:
            payload, name = load_session(rest or "latest")
        except FileNotFoundError as e:
            print(style(f"  {e}", "err"))
            return "continue"
        self.state.transcript = payload.get("transcript", [])
        self.state.sink.current = payload.get("tasks", [])
        if "model" in payload:
            self.state.model = payload["model"]
        if "workspace" in payload:
            ws = Path(payload["workspace"])
            if ws.is_dir():
                self.state.workspace = ws
        print(style(f"  resumed session {name}", "ok"))
        print(style(f"  {len(self.state.transcript)} messages, "
                    f"{len(self.state.sink.current)} tasks", "dim"))
        return "continue"

    def cmd_sessions(self, _):
        sessions = list_sessions()
        if not sessions:
            print(style("  no saved sessions.", "dim"))
            return "continue"
        for path in sessions[:20]:
            mtime = datetime.fromtimestamp(path.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
            print(f"   {style(path.stem, 'key')}  {style(mtime, 'dim')}")
        return "continue"

    def cmd_system(self, rest):
        if not rest:
            print(style("  current system prompt:", "key"))
            print(style(textwrap_short(self.state.system_message(), 400), "dim"))
            return "continue"
        self.state.system_override = rest
        self.state.reset_transcript()
        print(style("  system prompt updated.", "ok"))
        return "continue"

    def cmd_sh(self, rest):
        if not rest:
            print(style("  usage: /sh <command>", "dim"))
            return "continue"
        proc = subprocess.run(["/bin/zsh", "-lic", rest],
                              cwd=str(self.state.workspace),
                              capture_output=True, text=True)
        if proc.stdout:
            print(proc.stdout, end="")
        if proc.stderr:
            print(style(proc.stderr, "err"), end="")
        if proc.returncode != 0:
            print(style(f"  [exit {proc.returncode}]", "err"))
        return "continue"

    def cmd_yolo(self, rest):
        if rest in ("on", "yes"):
            self.state.permissions.yolo = True
        elif rest in ("off", "no"):
            self.state.permissions.yolo = False
        else:
            self.state.permissions.yolo = not self.state.permissions.yolo
        print(style(f"  yolo {'ON' if self.state.permissions.yolo else 'off'}",
                    "warning" if self.state.permissions.yolo else "ok"))
        return "continue"

    def cmd_theme(self, rest):
        if not rest:
            print(style(f"  current: {self.state.theme_name}", "key"))
            print(style(f"  options: {', '.join(_THEMES.keys())}", "dim"))
            return "continue"
        if rest not in _THEMES:
            print(style(f"  unknown theme: {rest}", "err"))
            return "continue"
        set_theme(rest)
        self.state.theme_name = rest
        print(style(f"  theme -> {rest}", "ok"))
        return "continue"

    def cmd_wrap(self, rest):
        if rest in ("on", "yes", "true"):
            self.state.wrap = True
        elif rest in ("off", "no", "false"):
            self.state.wrap = False
        else:
            self.state.wrap = not self.state.wrap
        print(style(f"  word wrap {'on' if self.state.wrap else 'off'}", "ok"))
        return "continue"

    def cmd_auto(self, rest):
        """Toggle the orchestrator's continuation policy. With auto on
        (the default), the agent loop re-prompts itself whenever a turn
        ends with pending tasks or premature 'done' + lingering promises.
        Off makes it behave like a pure one-shot Claude-Code-style loop."""
        if rest in ("on", "yes", "true"):
            self.state.auto_continue = True
        elif rest in ("off", "no", "false"):
            self.state.auto_continue = False
        elif rest.isdigit():
            self.state.max_continuations = max(0, int(rest))
            self.state.auto_continue = True
            print(style(f"  auto-continue budget set to "
                        f"{self.state.max_continuations}", "ok"))
            return "continue"
        else:
            self.state.auto_continue = not self.state.auto_continue
        msg = ("on" if self.state.auto_continue else "off")
        print(style(f"  auto-continue {msg}  (budget "
                    f"{self.state.max_continuations} per user turn)", "ok"))
        return "continue"

    def cmd_compact(self, rest):
        if rest == "now":
            ok = maybe_compact_transcript(self.state) or _force_compact(self.state)
            print(style("  compacted." if ok else "  compaction did not run.",
                        "ok" if ok else "warning"))
            return "continue"
        if rest in ("on", "off"):
            self.state.auto_compact = rest == "on"
        else:
            self.state.auto_compact = not self.state.auto_compact
        msg = "on" if self.state.auto_compact else "off"
        print(style(f"  auto-compact {msg}  (count: "
                    f"{self.state.compact_count})", "ok"))
        return "continue"

    def cmd_undo(self, rest):
        if not self.state.journal:
            print(style("  journal empty.", "dim"))
            return "continue"
        if rest == "all":
            n = restore_all_journal(self.state)
            print(style(f"  restored {n} file{'' if n == 1 else 's'}.", "ok"))
            return "continue"
        entry = restore_last_journal(self.state)
        if entry:
            print(style(f"  undid {entry['action']} on {entry['path']}", "ok"))
        else:
            print(style("  nothing to undo.", "dim"))
        return "continue"

    def cmd_journal(self, _):
        if not self.state.journal:
            print(style("  no fs mutations this session.", "dim"))
            return "continue"
        for i, entry in enumerate(self.state.journal):
            prior_lines = entry["prior"].count("\n")
            new_lines = entry["new"].count("\n")
            delta = new_lines - prior_lines
            sign = "+" if delta >= 0 else ""
            print(f"   {style(str(i+1).rjust(3), 'dim')}  "
                  f"{style(entry['action'].ljust(11), 'key')}"
                  f"{style(entry['path'], 'value')}  "
                  f"{style(f'({sign}{delta} lines)', 'dim')}")
        return "continue"

    def cmd_diff(self, rest):
        if rest in ("", "session"):
            for entry in self.state.journal:
                draw_diff(entry["path"], entry["prior"], entry["new"])
            return "continue"
        print(style("  usage: /diff [session]", "dim"))
        return "continue"

    def cmd_test(self, rest):
        if rest in ("on", "yes", "true"):
            self.state.auto_test = True
        elif rest in ("off", "no", "false"):
            self.state.auto_test = False
        else:
            self.state.auto_test = not self.state.auto_test
        msg = "on" if self.state.auto_test else "off"
        runner = detect_test_runner(self.state.workspace)
        runner_s = runner["name"] if runner else "no runner detected"
        print(style(f"  auto-test {msg}  ({runner_s})", "ok"))
        return "continue"

    def cmd_recall(self, rest):
        if not rest:
            print(style("  usage: /recall <query>", "dim"))
            return "continue"
        hits = memory_recall(self.state.memory, rest, limit=3)
        if not hits:
            print(style("  no memory hits.", "dim"))
            return "continue"
        for h in hits:
            head = f"{h['tool']} {h.get('args_preview','')}"
            print(style("  " + head, "key"))
            snippet = h["body"].strip()[:400]
            print(style("    " + snippet.replace("\n", "\n    "), "dim"))
        return "continue"

    def cmd_preview(self, rest):
        if rest in ("off", "stop"):
            preview_stop(self.state)
            return "continue"
        if rest in ("", "on", "start"):
            url = preview_start(self.state)
            if url:
                print(style(f"  preview -> {url}", "ok"))
            else:
                print(style("  preview: nothing to serve in workspace.", "dim"))
            return "continue"
        if rest == "url":
            if self.state.preview:
                print(style(f"  {self.state.preview['url']}", "ok"))
            else:
                print(style("  preview not running.", "dim"))
            return "continue"
        print(style("  usage: /preview [on|off|url]", "dim"))
        return "continue"

    def cmd_branch(self, rest):
        if not rest:
            print(style("  usage: /branch <name>", "dim"))
            return "continue"
        path = branch_save(self.state, rest)
        print(style(f"  branched -> {path}", "ok"))
        return "continue"

    def cmd_branches(self, _):
        items = branch_list()
        if not items:
            print(style("  no branches.", "dim"))
            return "continue"
        for p in items:
            try:
                meta = json.loads(p.read_text(encoding="utf-8"))
                tokens = meta.get("approx_tokens", "?")
                tasks = len(meta.get("tasks", []))
                print(f"   {style(p.stem, 'key')}  "
                      f"{style(f'{tokens} tok, {tasks} tasks', 'dim')}")
            except Exception:
                print(f"   {style(p.stem, 'key')}")
        return "continue"

    def cmd_checkout(self, rest):
        if not rest:
            print(style("  usage: /checkout <name>", "dim"))
            return "continue"
        ok = branch_checkout(self.state, rest)
        if ok:
            print(style(f"  checked out {rest}", "ok"))
        else:
            print(style(f"  no such branch: {rest}", "err"))
        return "continue"

    def cmd_merge(self, rest):
        if not rest:
            print(style("  usage: /merge <branch>", "dim"))
            return "continue"
        note = branch_merge(self.state, rest)
        if note:
            print(style(f"  merged {rest} as context note.", "ok"))
        else:
            print(style(f"  no such branch: {rest}", "err"))
        return "continue"

    def cmd_router(self, rest):
        parts = rest.split()
        if not parts:
            print(style(
                f"  router  planner={self.state.planner_model or '-'}  "
                f"coder={self.state.coder_model or '-'}  "
                f"explainer={self.state.explainer_model or '-'}", "key"))
            return "continue"
        if len(parts) != 2 or parts[0] not in ("planner", "coder",
                                               "explainer", "off"):
            print(style("  usage: /router <planner|coder|explainer> <model>",
                        "dim"))
            print(style("         /router off (disable all overrides)",
                        "dim"))
            return "continue"
        if parts[0] == "off":
            self.state.planner_model = ""
            self.state.coder_model = ""
            self.state.explainer_model = ""
            print(style("  router off.", "ok"))
            return "continue"
        setattr(self.state, f"{parts[0]}_model", parts[1])
        print(style(f"  router.{parts[0]} = {parts[1]}", "ok"))
        return "continue"

    def cmd_prefetch(self, rest):
        if rest in ("on", "yes", "true"):
            self.state.prefetch_enabled = True
        elif rest in ("off", "no", "false"):
            self.state.prefetch_enabled = False
        else:
            self.state.prefetch_enabled = not self.state.prefetch_enabled
        msg = "on" if self.state.prefetch_enabled else "off"
        print(style(f"  speculative prefetch {msg}  "
                    f"(hits: {self.state.prefetch_hits}, "
                    f"misses: {self.state.prefetch_misses})", "ok"))
        return "continue"

    def cmd_screenshot(self, rest):
        if rest in ("on", "yes", "true"):
            self.state.auto_screenshot = True
        elif rest in ("off", "no", "false"):
            self.state.auto_screenshot = False
        else:
            self.state.auto_screenshot = not self.state.auto_screenshot
        msg = "on" if self.state.auto_screenshot else "off"
        print(style(f"  auto-screenshot {msg}", "ok"))
        return "continue"

    def cmd_batch(self, rest):
        if rest in ("on", "yes", "true"):
            self.state.aggressive_batching = True
        elif rest in ("off", "no", "false"):
            self.state.aggressive_batching = False
        else:
            self.state.aggressive_batching = not self.state.aggressive_batching
        msg = "on" if self.state.aggressive_batching else "off"
        print(style(f"  aggressive batching {msg}  "
                    "(requires grammar support)", "ok"))
        return "continue"

    def cmd_autocommit(self, rest):
        if rest in ("on", "yes", "true"):
            self.state.auto_commit = True
        elif rest in ("off", "no", "false"):
            self.state.auto_commit = False
        else:
            self.state.auto_commit = not self.state.auto_commit
        msg = "on" if self.state.auto_commit else "off"
        print(style(f"  auto-commit {msg}", "ok"))
        return "continue"

    def cmd_persona(self, rest):
        if not rest:
            print(style(f"  current persona: "
                        f"{self.state.persona_source or '(none)'}", "key"))
            return "continue"
        text, source = load_persona(self.state.workspace, rest)
        if not text:
            print(style(f"  no persona named {rest!r} at "
                        f"{PERSONA_ROOT}/{rest}.md", "warning"))
            return "continue"
        self.state.persona_text = text
        self.state.persona_source = source
        self.state.reset_transcript()
        print(style(f"  persona -> {source}", "ok"))
        return "continue"

    def cmd_watch(self, rest):
        if rest in ("on", "yes", "true"):
            start_file_watcher(self.state)
        elif rest in ("off", "no", "false"):
            stop_file_watcher(self.state)
        else:
            if self.state.watcher_thread:
                stop_file_watcher(self.state)
            else:
                start_file_watcher(self.state)
        msg = "on" if self.state.watcher_thread else "off"
        print(style(f"  file watcher {msg}  "
                    f"(tracking {len(self.state.watched_files)} files)",
                    "ok"))
        return "continue"

    def cmd_reflect(self, rest):
        if rest in ("on", "yes", "true"):
            self.state.self_reflect = True
        elif rest in ("off", "no", "false"):
            self.state.self_reflect = False
        else:
            self.state.self_reflect = not self.state.self_reflect
        msg = "on" if self.state.self_reflect else "off"
        print(style(f"  self-reflect {msg}", "ok"))
        return "continue"

    def cmd_plugins(self, _):
        if not self.state.plugin_names:
            print(style("  no plugins loaded.", "dim"))
            return "continue"
        for name in self.state.plugin_names:
            print(f"   {style(name, 'key')}")
        return "continue"

    def cmd_constitution(self, rest):
        if rest == "reload":
            self.state.constitution_text, self.state.constitution_rules = (
                load_constitution(self.state.workspace))
            self.state.reset_transcript()
            print(style(
                f"  constitution reloaded "
                f"({len(self.state.constitution_rules)} rules)", "ok"))
            return "continue"
        if not self.state.constitution_rules:
            print(style("  no constitution loaded. Create "
                        ".loom/constitution.md and `/constitution reload`.",
                        "dim"))
            return "continue"
        print(style(f"  {len(self.state.constitution_rules)} rules:", "key"))
        for r in self.state.constitution_rules:
            print(f"   - {r}")
        return "continue"

    def cmd_ship(self, rest):
        if not rest:
            print(style("  usage: /ship <spec>", "dim"))
            return "continue"
        result = tool_ship_it(self.state, {"spec": rest})
        print(result)
        return "continue"

    def cmd_web(self, rest):
        if not rest:
            print(style("  usage: /web <query>", "dim"))
            return "continue"
        print(tool_web_search(self.state, {"query": rest, "limit": 5}))
        return "continue"

    def cmd_hooks(self, rest):
        if rest == "reload":
            self.state.hooks = discover_hooks(self.state.workspace)
            print(style(f"  hooks reloaded ({sum(len(v) for v in self.state.hooks.values())} scripts)", "ok"))
            return "continue"
        if not self.state.hooks:
            print(style("  no hooks installed. Drop scripts in ~/.loom/hooks/<event>.", "dim"))
            return "continue"
        for event, scripts in self.state.hooks.items():
            print(f"  {style(event, 'key')}")
            for s in scripts:
                print(f"    {style(s, 'dim')}")
        return "continue"

    def cmd_wake(self, rest):
        if not WAKEUP_ROOT.is_dir():
            print(style("  no wakeups queued.", "dim"))
            return "continue"
        records = []
        for path in sorted(WAKEUP_ROOT.glob("*.json")):
            try:
                rec = json.loads(path.read_text(encoding="utf-8"))
                records.append((path, rec))
            except (OSError, json.JSONDecodeError):
                continue
        if not records:
            print(style("  no wakeups queued.", "dim"))
            return "continue"
        for path, rec in records:
            wake_at = rec.get("wake_at", 0)
            delta = wake_at - time.time()
            when = (f"in {int(delta)}s" if delta > 0
                    else f"OVERDUE by {-int(delta)}s")
            print(f"  {style(rec.get('id', '?'), 'key')}  {when}  "
                  f"{style((rec.get('reason') or '')[:80], 'dim')}")
        return "continue"

    def cmd_settings(self, rest):
        if rest == "reload":
            self.state.settings = load_workspace_settings(self.state.workspace)
            if self.state.settings:
                apply_settings_to_state(self.state, self.state.settings)
            print(style("  settings reloaded.", "ok"))
            return "continue"
        if not self.state.settings:
            print(style("  no .loom/settings.json found.", "dim"))
            return "continue"
        print(json.dumps(self.state.settings, indent=2))
        return "continue"

    def cmd_bg(self, rest):
        if not rest:
            if not self.state.bg_shells:
                print(style("  no background shells.", "dim"))
                return "continue"
            for sid, entry in self.state.bg_shells.items():
                status = ("running" if entry["proc"].poll() is None
                          else f"exited rc={entry['proc'].returncode}")
                print(f"  {style(sid, 'key')}  {status}  "
                      f"{style(entry['command'][:80], 'dim')}")
            return "continue"
        print(tool_background_bash(self.state, {"command": rest}))
        return "continue"

    def cmd_mon(self, rest):
        if not rest:
            print(style("  usage: /mon <shell_id>", "dim"))
            return "continue"
        print(tool_monitor(self.state, {"shell_id": rest, "lines": 30}))
        return "continue"

    def cmd_kill(self, rest):
        if not rest:
            print(style("  usage: /kill <shell_id>", "dim"))
            return "continue"
        print(tool_kill_shell(self.state, {"shell_id": rest}))
        return "continue"

    def cmd_nb(self, rest):
        if not rest:
            print(style("  usage: /nb <path.ipynb>", "dim"))
            return "continue"
        print(tool_notebook_read(self.state, {"path": rest}))
        return "continue"

    def cmd_skill(self, rest):
        if not rest:
            skills = discover_skills()
            if not skills:
                print(style("  no skills installed.", "dim"))
            else:
                active = {s["name"] for s in self.state.active_skills}
                for name in sorted(skills):
                    marker = "*" if name in active else " "
                    print(f"   {marker} {style(name, 'key')}")
            return "continue"
        print(activate_skill(self.state, rest))
        return "continue"

    def cmd_memory(self, rest):
        index = USER_MEMORY_ROOT / "MEMORY.md"
        if not rest:
            if not index.is_file():
                print(style("  no user memory yet.", "dim"))
                return "continue"
            print(index.read_text(encoding="utf-8")[:4000])
            return "continue"
        if rest == "reload":
            self.state.user_memory_text = load_user_memory()
            self.state.reset_transcript()
            print(style("  memory reloaded.", "ok"))
            return "continue"
        print(style("  usage: /memory [reload]", "dim"))
        return "continue"

    def cmd_blocklist(self, rest):
        if not rest:
            print(style(f"  web_blocklist: "
                        f"{sorted(self.state.web_blocklist) or '(empty)'}",
                        "key"))
            return "continue"
        if rest.startswith("-"):
            host = rest[1:].strip()
            self.state.web_blocklist.discard(host)
            print(style(f"  removed {host}", "ok"))
        else:
            self.state.web_blocklist.add(rest.strip())
            print(style(f"  added {rest.strip()}", "ok"))
        return "continue"

    def cmd_lsp(self, rest):
        if rest in ("off", "stop"):
            if self.state.lsp:
                self.state.lsp.shutdown()
                self.state.lsp = None
                print(style("  lsp stopped.", "ok"))
            return "continue"
        if not rest:
            print(style(
                f"  lsp: {'running' if self.state.lsp else 'not running'}",
                "key"))
            return "continue"
        if self.state.lsp:
            self.state.lsp.shutdown()
        try:
            self.state.lsp = LSPClient(rest, self.state.workspace)
            print(style(f"  lsp started: {rest}", "ok"))
        except Exception as e:
            print(style(f"  lsp failed to start: {e}", "err"))
        return "continue"


def textwrap_short(s, n):
    s = s.replace("\n", " ")
    if len(s) > n:
        return s[: n - 1] + "…"
    return s


# =============================================================================
# JSON event emitter (for --json mode)
# =============================================================================

def make_json_emitter():
    def emit(event_type, **fields):
        record = {"type": event_type, "ts": _now_iso(), **fields}
        sys.stdout.write(json.dumps(record) + "\n")
        sys.stdout.flush()
    return emit


# =============================================================================
# History
# =============================================================================

def _load_history():
    if not _HAS_READLINE:
        return
    try:
        HISTORY_FILE.parent.mkdir(parents=True, exist_ok=True)
        readline.read_history_file(str(HISTORY_FILE))
    except (FileNotFoundError, OSError):
        pass
    try:
        readline.set_history_length(1000)
    except Exception:
        pass


def _save_history():
    if not _HAS_READLINE:
        return
    try:
        HISTORY_FILE.parent.mkdir(parents=True, exist_ok=True)
        readline.write_history_file(str(HISTORY_FILE))
    except OSError:
        pass


# =============================================================================
# Entrypoint
# =============================================================================

def main():
    parser = argparse.ArgumentParser(prog="lmstudio",
        description="Interactive agent CLI backed by LM Studio.")
    parser.add_argument("prompt", nargs="*", help="One-shot prompt. Omit for REPL.")
    parser.add_argument("--base-url", default=os.environ.get("LMSTUDIO_BASE_URL", DEFAULT_BASE_URL))
    parser.add_argument("--model", default=os.environ.get("LMSTUDIO_MODEL", ""))
    parser.add_argument("--max-turns", type=int, default=DEFAULT_MAX_TURNS)
    parser.add_argument("--workspace", default=os.getcwd())
    parser.add_argument("--allow-bash", action="store_true",
        default=os.environ.get("LMSTUDIO_BASH", "0") == "1",
        help="Enable the run_bash tool AND auto-approve every invocation "
             "for this session. Use /bash on (or LMSTUDIO_BASH=1) if you "
             "want the tool enabled but still prompted per call.")
    parser.add_argument("--bypass-bash", "--bypass-permissions",
        action="store_true", dest="bypass_bash",
        default=os.environ.get("LMSTUDIO_BYPASS_BASH", "0") == "1",
        help="Start in BYPASS PERMISSIONS mode: implies --yolo + "
             "--allow-bash and skips every permission prompt. "
             "Equivalent to pressing Shift+Tab three times after "
             "launch. Use only when you trust the model end-to-end.")
    parser.add_argument("--yolo", action="store_true",
        default=os.environ.get("LMSTUDIO_YOLO", "0") == "1",
        help="Disable permission prompts for write_file / edit_file / run_bash.")
    parser.add_argument("--resume", nargs="?", const="latest",
        help="Resume a saved session (most recent if no name given).")
    parser.add_argument("--theme", default=os.environ.get("LMSTUDIO_THEME", "default"),
        choices=list(_THEMES.keys()))
    parser.add_argument("--no-banner", action="store_true")
    parser.add_argument("--no-context", action="store_true",
        help="Skip auto-loading CLAUDE.md / AGENTS.md / GUIDE.md / README.md.")
    parser.add_argument("--system", help="Override the system prompt for this session.")
    parser.add_argument("--mcp", action="append", default=[],
        help="Shell command line that spawns a stdio MCP server. Repeatable.")
    parser.add_argument("--no-wrap", action="store_true",
        help="Disable word-boundary wrapping of model output; let the "
             "terminal hard-wrap at the right edge instead.")
    parser.add_argument("--json", action="store_true",
        help="Emit one JSON event per line instead of styled output. "
             "Implies --no-banner.")
    parser.add_argument("--planner-model", dest="planner_model",
        default=os.environ.get("LMSTUDIO_PLANNER_MODEL", ""),
        help="Override model for plan-y turns (small/fast).")
    parser.add_argument("--coder-model", dest="coder_model",
        default=os.environ.get("LMSTUDIO_CODER_MODEL", ""),
        help="Override model for code-touching turns.")
    parser.add_argument("--explainer-model", dest="explainer_model",
        default=os.environ.get("LMSTUDIO_EXPLAINER_MODEL", ""),
        help="Override model for explanation/summarization turns.")
    parser.add_argument("--no-prefetch", action="store_true",
        help="Disable speculative tool prefetch.")
    parser.add_argument("--auto-test", action="store_true",
        default=os.environ.get("LMSTUDIO_AUTO_TEST", "0") == "1",
        help="After every fs mutation to a test file, run the detected "
             "framework and feed failures back to the model.")
    parser.add_argument("--auto-screenshot", action="store_true",
        default=os.environ.get("LMSTUDIO_AUTO_SCREENSHOT", "0") == "1",
        help="After every UI fs mutation, screenshot the rendered page via "
             "headless Playwright and OCR the result back to the model.")
    parser.add_argument("--auto-commit", action="store_true",
        default=os.environ.get("LMSTUDIO_AUTO_COMMIT", "0") == "1",
        help="When a task flips to completed, auto-commit the journaled "
             "changes (workspace must be a git repo).")
    parser.add_argument("--batch", action="store_true",
        default=os.environ.get("LMSTUDIO_BATCH", "0") == "1",
        help="Aggressive multi-step batching: after update_tasks emits N "
             "file-create tasks, execute each via grammar-forced "
             "write_file without re-prompting.")
    parser.add_argument("--persona", default=os.environ.get("LMSTUDIO_PERSONA", ""),
        help="Load a named persona from ~/.loom/personas/<name>.md. "
             ".loom/persona.md in the workspace always wins.")
    parser.add_argument("--lsp", default=os.environ.get("LMSTUDIO_LSP", ""),
        help="Shell command line for a stdio LSP server (typescript-"
             "language-server, sourcekit-lsp, pyright, etc.).")
    parser.add_argument("--watch", action="store_true",
        default=os.environ.get("LMSTUDIO_WATCH", "0") == "1",
        help="Run a background workspace watcher; external file changes "
             "are surfaced to the model on the next turn.")
    parser.add_argument("--reflect", action="store_true",
        default=os.environ.get("LMSTUDIO_REFLECT", "0") == "1",
        help="At the end of each human-issued turn, send a judge prompt to "
             "score the turn and save a lesson to project knowledge.")
    parser.add_argument("--no-plugins", action="store_true",
        help="Skip auto-loading ~/.loom/tools/*.py plugins.")
    parser.add_argument("--no-autoscale", action="store_true",
        default=os.environ.get("LMSTUDIO_NO_AUTOSCALE", "0") == "1",
        help="Skip the session-start auto-scale of the model's loaded "
             "context length. By default if the loaded context is below "
             "--autoscale-min, we reload via the `lms` CLI with a "
             "larger context up to --autoscale-max or the model's cap.")
    parser.add_argument("--autoscale-min", type=int,
        default=int(os.environ.get("LMSTUDIO_AUTOSCALE_MIN", "16384")),
        help="Minimum loaded_context_length to accept without reloading. "
             "Default 16384. The autoscale also force-reloads when the "
             "current parallel slot count > 1 and the model cap allows "
             "a much bigger context, since dropping parallel from 4 to 1 "
             "frees 75%% of the KV cache.")
    parser.add_argument("--autoscale-max", type=int,
        default=int(os.environ.get("LMSTUDIO_AUTOSCALE_MAX", "65536")),
        help="Hard cap on the autoscale target. Reload picks "
             "min(autoscale_max, model_cap). If that OOMs, the ladder "
             "steps down 75%% / 50%% / 33%% / 25%% until LM Studio "
             "accepts. Default 65536 (64k) is achievable for most "
             "models on most hardware when parallel=1.")
    parser.add_argument("--max-tokens", type=int,
        default=int(os.environ.get("LMSTUDIO_MAX_TOKENS", "4096")),
        help="Per-turn output token cap. Prevents Gemma-style runaway "
             "prose. Default 4096 - plenty for a single tool call + "
             "preface, hard cap on a 10k-token essay. 0 to disable.")
    parser.add_argument("--no-autoload", action="store_true",
        default=os.environ.get("LMSTUDIO_NO_AUTOLOAD", "0") == "1",
        help="When no model is loaded, error out instead of auto-loading "
             "the smallest tool-use model on disk.")
    parser.add_argument("--default-size", type=int,
        default=int(os.environ.get("LMSTUDIO_DEFAULT_SIZE", "7")),
        help="Preferred parameter count (in billions) for the auto-load "
             "pick. Default 7 - capable enough for non-trivial coding "
             "work while staying fast. Picker also biases toward "
             "coder-strong families (qwen, deepseek, codestral) at "
             "any size.")
    parser.add_argument("--default-size-max", type=int,
        default=int(os.environ.get("LMSTUDIO_DEFAULT_SIZE_MAX", "12")),
        help="Hard upper bound on auto-load size in billions. Default 12 "
             "lets a 9B qwen-coder beat a 7B gemma when both are on disk. "
             "Larger models skipped to keep startup fast.")
    parser.add_argument("--no-auto-route", action="store_true",
        default=os.environ.get("LMSTUDIO_NO_AUTO_ROUTE", "0") == "1",
        help="Skip the session-start auto-route. Without this flag, even "
             "if a model is already loaded, the CLI may swap to a stronger "
             "coder-class model when one is on disk. Pass an explicit "
             "--model X to lock in a choice regardless.")
    parser.add_argument("--dual-load", action="store_true",
        default=os.environ.get("LMSTUDIO_DUAL_LOAD", "1") == "1",
        help="At session start, load BOTH a small fast planner model AND "
             "a stronger coder model simultaneously. Per-turn routing "
             "then picks the right one based on intent: coder for "
             "write/build/scaffold turns, planner for narration / Q&A. "
             "Default on. Falls back to single-load if the second "
             "model OOMs.")
    parser.add_argument("--no-dual-load", dest="dual_load",
        action="store_false",
        help="Disable dual-loading. Single model only.")
    parser.add_argument("--planner-size", type=int,
        default=int(os.environ.get("LMSTUDIO_PLANNER_SIZE", "4")),
        help="Preferred planner model size (B params). Default 4.")
    parser.add_argument("--coder-size", type=int,
        default=int(os.environ.get("LMSTUDIO_CODER_SIZE", "9")),
        help="Preferred coder model size (B params). Default 9 - "
             "qwen3.5-9b class fits the typical Mac with plenty of "
             "RAM headroom alongside a 4B planner.")
    parser.add_argument("--loop", action="store_true",
        help="Autonomous-loop mode. After each turn, re-enter the session "
             "until the model calls `loop_complete`.")
    parser.add_argument("--check-wakeups", action="store_true",
        help="Scan ~/.loom/wakeups/ for due wakeups and fire them, then "
             "exit. Wire this into cron/launchd.")
    parser.add_argument("--resume-wakeup", default="",
        help="Internal flag used by the wakeup runner. Loads the wakeup "
             "record at the given path and runs its prompt.")
    parser.add_argument("--no-hooks", action="store_true",
        help="Skip discovering / running hooks.")
    parser.add_argument("--no-settings", action="store_true",
        help="Skip loading <workspace>/.loom/settings.json.")
    args = parser.parse_args()

    # 8.0.0 — top-level helper modes that exit before normal session start.
    if args.check_wakeups:
        n = check_and_run_wakeups()
        print(f"fired {n} wakeup(s)")
        sys.exit(0)
    if args.resume_wakeup:
        try:
            rec = json.loads(Path(args.resume_wakeup).read_text(encoding="utf-8"))
            args.workspace = rec.get("workspace", args.workspace)
            args.model = rec.get("model", args.model) or args.model
            args.base_url = rec.get("base_url", args.base_url) or args.base_url
            # Inject the saved prompt as a one-shot positional arg.
            args.prompt = [rec.get("prompt", "")]
            # Best-effort: remove the wakeup file so it doesn't fire again.
            Path(args.resume_wakeup).unlink(missing_ok=True)
        except (OSError, json.JSONDecodeError) as e:
            print(f"--resume-wakeup error: {e}", file=sys.stderr)
            sys.exit(2)

    set_theme(args.theme)
    configure_styling(use_color=(sys.stdout.isatty()
                                 and "NO_COLOR" not in os.environ
                                 and args.theme != "mono"
                                 and not args.json))

    # 8.0.14: friendly install / server check BEFORE any model probing.
    # When LM Studio isn't installed, the user gets a clean message with
    # the download URL instead of a Python URLError. When it's installed
    # but the server is cold, they get start-the-server instructions.
    install_status = detect_lmstudio_installation(args.base_url)
    if not install_status["server_reachable"]:
        print_lmstudio_missing_help(install_status, args.base_url)
        sys.exit(2)

    if not args.model:
        try:
            loaded = fetch_loaded_models(args.base_url)
        except RuntimeError as e:
            print(style(f"error: {e}", "err"), file=sys.stderr)
            sys.exit(2)
        # 8.0.17: compute the optimal model FROM DISK once, then use it
        # as the auto-route target regardless of what's currently
        # loaded. Without this step, a user who already had a tiny 4B
        # loaded (perhaps from a prior auto-load) stayed on that model
        # forever even when their 9B qwen-coder was sitting on disk
        # unused. Auto-route forces the upgrade so coding tasks aren't
        # silently bottlenecked by a generalist 4B.
        optimal_from_disk = None
        if not args.no_auto_route:
            try:
                _available = fetch_available_models()
            except Exception:
                _available = []
            if _available:
                optimal_from_disk = pick_default_model(
                    _available,
                    prefer_b=args.default_size,
                    max_b=args.default_size_max,
                )

        # 8.0.19: dual-load. If the user wants Claude-style per-turn
        # routing (small fast model for narration, big model for
        # coding work), load BOTH at session start. Falls through to
        # the single-model auto-route paths below on any failure.
        if args.dual_load and not args.no_auto_route:
            if not args.no_banner and not args.json:
                print(style(
                    f"  ▸ dual-loading planner ({args.planner_size}B) + "
                    f"coder ({args.coder_size}B) for per-turn routing…",
                    "tip"))
            planner, coder, dual_msg = auto_load_dual_models(
                args.base_url,
                planner_b=args.planner_size,
                coder_b=args.coder_size,
                max_b=args.default_size_max,
            )
            if coder:
                args.model = coder
                # Stash for state hookup after AgentState exists.
                args._dual_loaded_coder = coder
                args._dual_loaded_planner = planner
                if not args.no_banner and not args.json:
                    print(style(f"  ▸ {dual_msg}", "ok"))
                # Skip the rest of the single-load branches.
                loaded = [coder]
                optimal_from_disk = coder
            else:
                if not args.no_banner and not args.json:
                    print(style(
                        f"  ▸ dual-load failed: {dual_msg}; falling back "
                        f"to single-model auto-route", "warning"))
                # Fall through to the normal single-load logic below.

        if len(loaded) == 1:
            # A model is loaded. Auto-route may want to swap it for a
            # stronger pick. Only swap when:
            #   - auto-route is enabled (not --no-auto-route)
            #   - the optimal pick differs from what's loaded
            #   - the optimal pick is genuinely loadable (we're not
            #     about to OOM the user on the swap)
            if (optimal_from_disk
                    and optimal_from_disk != loaded[0]
                    and not args.no_auto_route):
                if not args.no_banner and not args.json:
                    print(style(
                        f"  ▸ auto-route: {loaded[0]} loaded; "
                        f"{optimal_from_disk} is a stronger pick. "
                        f"Swapping…", "tip"))
                chosen, msg = auto_load_default_model(
                    args.base_url,
                    prefer_b=args.default_size,
                    max_b=args.default_size_max,
                )
                if chosen:
                    args.model = chosen
                    if not args.no_banner and not args.json:
                        print(style(f"  ▸ {msg}", "ok"))
                else:
                    # Swap failed - fall back to whatever's loaded.
                    args.model = loaded[0]
                    if not args.no_banner and not args.json:
                        print(style(
                            f"  ▸ swap to {optimal_from_disk} failed "
                            f"({msg}); staying on {loaded[0]}",
                            "warning"))
            else:
                args.model = loaded[0]
        elif len(loaded) == 0:
            # 8.0.13: auto-load the smallest tool-use model on disk
            # rather than erroring out. The Mac running this CLI almost
            # always has at least one 3-7B GGUF cached; loading it lets
            # the user start a session without first reaching for the
            # LM Studio app.
            if args.no_autoload:
                print(style("error: no model loaded and --no-autoload set.",
                            "err"), file=sys.stderr)
                sys.exit(2)
            if not args.no_banner and not args.json:
                print(style("  ▸ no model loaded - picking a default…",
                            "tip"))
            chosen, msg = auto_load_default_model(
                args.base_url,
                prefer_b=args.default_size,
                max_b=args.default_size_max,
            )
            if not chosen:
                print(style(f"error: auto-load failed: {msg}", "err"),
                      file=sys.stderr)
                print(style(
                    "  Try: `lms load <model> -y --parallel 1` manually, "
                    "or download a small 3-7B GGUF via the LM Studio "
                    "app and re-run.", "dim"), file=sys.stderr)
                sys.exit(2)
            args.model = chosen
            if not args.no_banner and not args.json:
                print(style(f"  ▸ {msg}", "ok"))
        else:
            # Multiple models loaded. If the optimal pick is one of them,
            # use that. Otherwise let the user disambiguate.
            if optimal_from_disk and optimal_from_disk in loaded:
                args.model = optimal_from_disk
                if not args.no_banner and not args.json:
                    print(style(
                        f"  ▸ auto-route: picked {optimal_from_disk} "
                        f"from {len(loaded)} loaded models", "tip"))
            else:
                print(style(
                    "error: multiple models loaded. Pass --model or "
                    "set LMSTUDIO_MODEL to one of:", "err"),
                    file=sys.stderr)
                for m in loaded:
                    print(f"  {m}", file=sys.stderr)
                sys.exit(2)

    workspace = Path(args.workspace).resolve()
    if not workspace.is_dir():
        print(style(f"error: workspace is not a directory: {workspace}", "err"),
              file=sys.stderr)
        sys.exit(2)

    session_id = uuid.uuid4().hex[:8]
    mcp_clients = []
    for cmd in args.mcp:
        client = MCPClient(cmd)
        try:
            client.start()
        except Exception as e:
            print(style(f"warning: MCP server failed to start ({cmd}): {e}",
                        "warning"), file=sys.stderr)
            continue
        mcp_clients.append(client)

    state = AgentState(
        workspace=workspace, base_url=args.base_url, model=args.model,
        allow_bash=args.allow_bash, session_id=session_id,
        yolo=args.yolo, theme_name=args.theme, mcp_clients=mcp_clients,
        wrap=not args.no_wrap,
    )
    # 8.0.7: auto-scale the model's loaded context BEFORE we measure it,
    # so a model loaded with 4k of context (LM Studio's tiny JIT default
    # for some Gemma / Phi / Llama 3 builds) gets bumped via the `lms`
    # CLI. The full tool schema set is ~5k tokens; system prompt +
    # workspace tree + first user message usually push past 4k before
    # the model emits a token. When LM Studio refuses the target with
    # an OOM, auto_scale_context steps down through 75% / 50% / 33% /
    # 25% candidates until either a load succeeds or the model's memory
    # footprint just won't shrink further (very large models on
    # memory-constrained systems). Skip with --no-autoscale.
    if not args.no_autoscale:
        ok, msg, new_ctx = auto_scale_context(
            args.base_url, args.model,
            target_minimum=args.autoscale_min,
            max_target=args.autoscale_max,
        )
        if not args.no_banner and not args.json:
            if ok and new_ctx and "bumped" in msg:
                print(style(f"  ▸ autoscale: {msg}", "tip"))
            elif ok:
                print(style(f"  ▸ autoscale: {msg}", "dim"))
            else:
                # Non-fatal: continue with whatever context LM Studio
                # has loaded. Make sure the user knows they may need a
                # smaller model if tool calls fail.
                print(style(f"  ▸ autoscale could not bump context: {msg}",
                            "dim"))
                if new_ctx and new_ctx < 8192:
                    print(style(
                        f"  ▸ running on {new_ctx}-token context - the "
                        f"agent will trim tools and may struggle on "
                        f"complex prompts. Consider a smaller model "
                        f"or `lms load <model> -c 8192` manually.",
                        "warning"))
    state.context_window = fetch_model_context_window(args.base_url, args.model)
    state.grammar_supported = probe_grammar_support(args.base_url, state.model)
    # 8.0.9 — apply CLI overrides.
    if args.max_tokens and args.max_tokens > 0:
        state.max_tokens = args.max_tokens
    # 8.0.11 — --bypass-bash launches directly into BYPASS PERMISSIONS
    # mode. We do this BEFORE the transcript is built (reset_transcript
    # happens below) so the synthetic mode note lands at the right
    # position in the transcript and the system prompt's PLAN MODE
    # check doesn't fire.
    if args.bypass_bash:
        state.allow_bash = True
        state.set_mode("bypass-permissions")
    # 8.0.9 — auto-assign multi-model routing when the user has multiple
    # models loaded. The smallest loaded model becomes the planner
    # (cheap triage / plan generation); the user's --model stays the
    # coder. Explicit --planner-model etc. CLI flags override. Skip
    # when only one model is loaded or when /v0/models can't enumerate
    # them.
    if not args.planner_model and not args.coder_model:
        try:
            loaded_ids = fetch_loaded_models(args.base_url)
        except Exception:
            loaded_ids = []
        if len(loaded_ids) > 1:
            sized = [(model_id, _estimate_model_billions(model_id) or 999)
                     for model_id in loaded_ids]
            sized.sort(key=lambda t: t[1])
            smallest = sized[0][0]
            if smallest != args.model:
                state.planner_model = smallest
                if not args.no_banner and not args.json:
                    print(style(
                        f"  ▸ auto-routing: planner={smallest} "
                        f"(smallest loaded model)", "tip"))
    # Tool-surface fits: when the model's reported context is tight (under
    # ~16k tokens), the full 70-tool schema set alone is bigger than the
    # prompt budget. LM Studio rejects with "n_keep > n_ctx" and we'd just
    # silently hang. Trim the optional/specialty tools down to keep the
    # base agent loop usable. The user can re-enable everything by
    # loading the model with a larger context.
    if state.context_window and state.context_window < 16000:
        # Keep the essentials; drop the long-tail tools.
        keep = {
            # Core file ops
            "read_file", "write_file", "edit_file", "multi_edit",
            "list_dir", "glob", "grep", "find_todos",
            # Tasks + bash + delegation
            "update_tasks", "run_bash", "spawn_agent",
            # Git read-only (commonly useful even on small contexts)
            "git_status", "git_diff",
            # Browser screenshot path (one tool, gracefully skipped if no playwright)
            "browser_screenshot",
        }
        trimmed_schemas = []
        trimmed_funcs = {}
        for spec in BUILTIN_TOOL_SCHEMAS:
            name = spec.get("function", {}).get("name")
            if name in keep:
                trimmed_schemas.append(spec)
        for name, fn in BUILTIN_TOOL_FUNCS.items():
            if name in keep or name.startswith("mcp__"):
                trimmed_funcs[name] = fn
        BUILTIN_TOOL_SCHEMAS[:] = trimmed_schemas
        BUILTIN_TOOL_FUNCS.clear()
        BUILTIN_TOOL_FUNCS.update(trimmed_funcs)
        print(style(
            f"  ⚠ model context is small ({state.context_window} tok); "
            f"trimmed tool surface to {len(trimmed_schemas)} essentials. "
            "Reload LM Studio with a larger context (32k+) to enable the "
            "full toolkit.", "warning"), file=sys.stderr)
    # --allow-bash from the CLI is meant as "I trust the agent to run bash
    # for this session" - enable the tool AND skip the per-call prompt.
    # /bash on inside the REPL keeps the prompt because that's a softer,
    # mid-session toggle.
    if args.allow_bash:
        state.permissions.allowed_forever.add("run_bash")
    if args.system:
        state.system_override = args.system
    if not args.no_context:
        state.context_text, state.context_files = load_project_context(workspace)
        state.refresh_workspace_tree()
        state.project_knowledge_text, state.project_knowledge = (
            load_project_knowledge(workspace)
        )
        # Persona load (workspace persona wins over --persona name).
        state.persona_text, state.persona_source = load_persona(
            workspace, args.persona or None)
        # Constitution load (workspace hard-rule file).
        state.constitution_text, state.constitution_rules = load_constitution(
            workspace)
        # Drift detection against the loaded project knowledge.
        detect_drift(state)
        # 8.0.0 — user-level cross-workspace memory.
        state.user_memory_text = load_user_memory()
    # Cross-session permission learning.
    load_permission_grants(state)
    # 8.0.0 — settings.json apply (CLI args have already populated state).
    if not args.no_settings:
        state.settings = load_workspace_settings(workspace)
        if state.settings:
            apply_settings_to_state(state, state.settings)
    # 8.0.0 — hooks discovery.
    if not args.no_hooks:
        state.hooks = discover_hooks(workspace)
    # Plugin auto-import.
    if not args.no_plugins:
        load_plugins(state)
    # File watcher.
    if args.watch:
        start_file_watcher(state)
    # Self-reflection.
    if args.reflect:
        state.self_reflect = True
    # 8.0.0 — session-start hook (stdout becomes a system note).
    _, hook_note = run_hooks(
        state, "session-start",
        {"workspace": str(workspace), "session_id": session_id,
         "model": state.model},
    )
    if hook_note:
        state.context_text = (
            (state.context_text + "\n\n" if state.context_text else "")
            + "# session-start hook\n" + hook_note)
    # Multi-model routing config from CLI flags.
    state.planner_model = args.planner_model or ""
    state.coder_model = args.coder_model or ""
    state.explainer_model = args.explainer_model or ""
    # 8.0.19: if dual-load succeeded, override the routing slots so
    # pick_model_for_turn has the right targets. Explicit --planner-model
    # / --coder-model flags still win because they were set above.
    dual_planner = getattr(args, "_dual_loaded_planner", None)
    dual_coder = getattr(args, "_dual_loaded_coder", None)
    if dual_planner and not state.planner_model:
        state.planner_model = dual_planner
    if dual_coder and not state.coder_model:
        state.coder_model = dual_coder
    if args.no_prefetch:
        state.prefetch_enabled = False
    if args.auto_test:
        state.auto_test = True
    if args.auto_screenshot:
        state.auto_screenshot = True
    if args.auto_commit:
        state.auto_commit = True
    if args.batch:
        state.aggressive_batching = True
    if args.lsp:
        try:
            state.lsp = LSPClient(args.lsp, workspace)
        except Exception as e:
            print(style(f"warning: LSP failed to start ({args.lsp}): {e}",
                        "warning"), file=sys.stderr)
    state.reset_transcript()

    if args.resume:
        try:
            payload, name = load_session(args.resume)
            state.transcript = payload.get("transcript", []) or state.transcript
            state.sink.current = payload.get("tasks", [])
            if "model" in payload and not os.environ.get("LMSTUDIO_MODEL"):
                state.model = payload["model"]
            if not args.no_banner and not args.json:
                print(style(f"resumed {name}: {len(state.transcript)} messages",
                            "ok"))
        except FileNotFoundError as e:
            print(style(f"error: {e}", "err"), file=sys.stderr)
            sys.exit(2)

    router = SlashRouter(state)
    # 8.0.0 — discover slash command files (.md becomes /command).
    state.slash_command_files = discover_slash_command_files(workspace)
    json_emit = make_json_emitter() if args.json else None
    if json_emit:
        json_emit("session_started",
                  session_id=session_id, model=state.model,
                  workspace=str(workspace))

    if not args.no_banner and not args.json:
        draw_banner(state.model, workspace, state.allow_bash, session_id,
                    state.theme_name, state.context_files,
                    tree_count=state.workspace_tree_count,
                    grammar_supported=state.grammar_supported,
                    adapter=state.adapter)
        draw_banner_extra(state)
        draw_tips()

    _load_history()
    if not args.json:
        install_completer(workspace, router.names())

    # SIGWINCH: redraw the prompt area cleanly on terminal resize between
    # turns. We can't redraw mid-input safely without raw-mode line editing,
    # so this just flags a state we can act on after the current input.
    def _on_resize(signum, frame):
        try:
            sys.stdout.flush()
        except Exception:
            pass
    try:
        signal.signal(signal.SIGWINCH, _on_resize)
    except (ValueError, AttributeError):
        pass

    one_shot = " ".join(args.prompt).strip()
    if one_shot:
        if not args.json:
            top, lead, bot = draw_prompt_box()
            draw_status_footer(state)
            print(top)
            print(f"{lead}{one_shot}")
            close_prompt_box(one_shot)
            print(bot)
            print()
        # 8.0.0 — --loop re-drives the same prompt until the model calls
        # loop_complete (which sets state.loop_should_exit). One-shot
        # without --loop runs exactly once.
        iterations = 0
        max_iterations = 100  # hard ceiling; loop_complete should fire first
        while True:
            try:
                drive_user_message(state, one_shot, json_emit=json_emit)
            except (KeyboardInterrupt, EscInterrupt):
                if json_emit:
                    json_emit("interrupted")
                else:
                    print(style("\n  (interrupted)", "warning"))
                break
            if not args.loop or state.loop_should_exit:
                break
            iterations += 1
            if iterations >= max_iterations:
                if not args.json:
                    print(style(
                        f"  loop: hit max iterations ({max_iterations}); "
                        "exiting.", "warning"))
                break
            time.sleep(1.0)
        _shutdown(state, json_emit)
        return

    if args.json:
        # JSON mode without a one-shot prompt reads newline-delimited
        # prompts from stdin and emits structured events per turn.
        for raw in sys.stdin:
            user_in = raw.strip()
            if not user_in or user_in in ("/quit", "/exit"):
                break
            try:
                drive_user_message(state, user_in, json_emit=json_emit)
            except (KeyboardInterrupt, EscInterrupt):
                json_emit("interrupted")
            except Exception as e:
                json_emit("error", message=str(e))
        _shutdown(state, json_emit)
        return

    while True:
        draw_status_footer(state)
        editor = BoxedLineEditor(history=BoxedLineEditor.load_history(),
                                  state=state)
        try:
            user_in = editor.read().strip()
        except EOFError:
            break
        except KeyboardInterrupt:
            continue
        except EscInterrupt:
            continue
        if not user_in:
            continue
        if user_in.startswith("/"):
            outcome = router.dispatch(user_in)
            if outcome == "exit":
                break
            continue
        BoxedLineEditor.append_history(user_in)
        print()
        try:
            drive_user_message(state, user_in)
        except (KeyboardInterrupt, EscInterrupt):
            print(style("\n  (interrupted)", "warning"))
        except Exception as e:
            print(style(f"  {GLYPH_ERR} error: {e}", "err"), file=sys.stderr)
        print()

    _shutdown(state, json_emit)


def _shutdown(state, json_emit):
    _save_history()
    for client in state.mcp_clients:
        client.stop()
    try:
        save_project_knowledge(state)
    except Exception:
        pass
    if state.preview:
        try:
            state.preview["server"].shutdown()
            state.preview["server"].server_close()
        except Exception:
            pass
        state.preview = None
    if state.browser:
        try:
            state.browser.close()
        except Exception:
            pass
        state.browser = None
    if state.lsp:
        try:
            state.lsp.shutdown()
        except Exception:
            pass
        state.lsp = None
    try:
        save_permission_grants(state)
    except Exception:
        pass
    try:
        stop_file_watcher(state)
    except Exception:
        pass
    # 8.0.0 — clean up any background shells.
    for shell_id, entry in list(state.bg_shells.items()):
        try:
            if entry["proc"].poll() is None:
                entry["proc"].terminate()
            entry["log_fd"].close()
        except Exception:
            pass
    # 8.0.0 — session-end hook.
    try:
        run_hooks(state, "session-end",
                  {"session_id": state.session_id,
                   "elapsed_seconds": int(time.time() - state.started_at)})
    except Exception:
        pass
    if json_emit:
        json_emit("session_ended")


if __name__ == "__main__":
    main()
