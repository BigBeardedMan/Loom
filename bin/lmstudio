# Module-level bounded thread pool for prefetch tasks. Each streaming
# narration burst can match the path regex many times; without a pool, we
# spawned an unbounded number of raw daemon threads. The executor caps
# concurrency at 4, recycles workers, and lets the OS scheduler do less.
import concurrent.futures as _futures
_PREFETCH_POOL = _futures.ThreadPoolExecutor(
    max_workers=4, thread_name_prefix="lmstudio-prefetch")


def _kick_speculative_prefetch(state, narration, already_prefetched):
    """Look at the streamed narration so far and prefetch likely tool
    results into state.prefetch_cache. Only safe, read-only operations are
    fetched. Called periodically from the streaming loop in run_turn."""
    if not state.prefetch_enabled:
        return
    if len(state.prefetch_cache) > 64:
        return  # don't thrash the cache
    candidate = _scan_for_path(narration, state.workspace)
    if not candidate:
        return
    key = ("read_file", _canonical({"path": candidate}))
    if key in already_prefetched or key in state.prefetch_cache:
        return
    already_prefetched.add(key)
    try:
        target = resolve_in_workspace(state.workspace, candidate)
    except ValueError:
        return
    if not target.is_file():
        state.prefetch_misses += 1
        return

    def _do():
        try:
            text = target.read_text(encoding="utf-8", errors="replace")
        except OSError:
            return
        if len(text) > 32000:
            text = text[:32000] + "\n\n...(truncated at 32000 chars)"
        state.prefetch_cache[key] = {"ts": time.time(), "result": text}
    try:
        _PREFETCH_POOL.submit(_do)
    except RuntimeError:
        # Pool was shut down (interpreter teardown); skip silently.
        pass


def restore_last_journal(state):
    """Pop the last journal entry and restore its prior content to disk.
    Refuses if the file's been touched externally since (size + mtime
    sanity check). Returns the entry on success, None otherwise."""
    if not state.journal:
        return None
    entry = state.journal[-1]
    try:
        target = resolve_in_workspace(state.workspace, entry["path"])
    except ValueError:
        return None
    if entry["prior"]:
        try:
            target.parent.mkdir(parents=True, exist_ok=True)
            target.write_text(entry["prior"], encoding="utf-8")
        except OSError:
            return None
    else:
        try:
            target.unlink(missing_ok=True)
        except OSError:
            return None
    state.journal.pop()
    return entry


def restore_all_journal(state):
    n = 0
    while state.journal:
        if not restore_last_journal(state):
            break
        n += 1
    return n


def _force_compact(state):
    """Bypass the threshold check and compact unconditionally. Used by
    /compact now."""
    prev_window = state.context_window
    state.context_window = max(state.approx_tokens * 2, 1)
    state.approx_tokens = state.context_window  # force ratio to 1.0
    ran = maybe_compact_transcript(state)
    state.context_window = prev_window
    return ran


# ---------- Memory / TF-IDF recall -----------------------------------------

_MEMORY_TOKEN_RE = re.compile(r"[A-Za-z_][A-Za-z0-9_]{2,}|[A-Za-z]{4,}")


def _tokenize_memory(text):
    if not text:
        return []
    return [t.lower() for t in _MEMORY_TOKEN_RE.findall(text)][:400]


def memory_record(state, tool, args, body):
    """Append a tool result into the session memory bag. Stored fields:
    `tool`, `args_preview`, `tokens` (Counter), `body`. Body is bounded to
    keep memory cheap."""
    if not body or len(body) < 30:
        return
    if tool in ("update_tasks",):  # state-y, not informational
        return
    import collections
    tokens = collections.Counter(_tokenize_memory(body))
    args_preview = json.dumps(args, separators=(",", ":"))[:120] if args else ""
    state.memory.append({
        "tool": tool,
        "args_preview": args_preview,
        "tokens": tokens,
        "body": body[:8000],
    })
    if len(state.memory) > 200:
        state.memory.pop(0)


def memory_recall(memory, query, limit=3):
    if not memory:
        return []
    query_tokens = _tokenize_memory(query)
    if not query_tokens:
        return []
    scored = []
    for entry in memory:
        score = sum(entry["tokens"].get(tok, 0) for tok in query_tokens)
        if score:
            scored.append((score, entry))
    scored.sort(key=lambda x: -x[0])
    return [e for _, e in scored[:limit]]


# ---------- Auto-test integration ------------------------------------------

def detect_test_runner(workspace):
    """Inspect the workspace for a known test framework. Returns a dict
    {name, command, file_globs} or None when no runner is obvious."""
    ws = Path(workspace)
    if (ws / "pyproject.toml").is_file() or (ws / "pytest.ini").is_file():
        return {"name": "pytest", "command": "pytest -x --no-header",
                "file_globs": ("test_*.py", "*_test.py")}
    if (ws / "package.json").is_file():
        try:
            data = json.loads((ws / "package.json").read_text(encoding="utf-8"))
            if (data.get("scripts") or {}).get("test"):
                return {"name": "npm", "command": "npm test --silent",
                        "file_globs": ("*.test.ts", "*.test.tsx",
                                       "*.test.js", "*.spec.ts", "*.spec.js")}
        except (OSError, json.JSONDecodeError):
            pass
    if (ws / "Package.swift").is_file():
        return {"name": "swift", "command": "swift test --quiet",
                "file_globs": ("*Tests.swift",)}
    if (ws / "Cargo.toml").is_file():
        return {"name": "cargo", "command": "cargo test --quiet",
                "file_globs": ("*.rs",)}
    if (ws / "go.mod").is_file():
        return {"name": "go", "command": "go test ./...",
                "file_globs": ("*_test.go",)}
    return None


def path_matches_test(rel_path, globs):
    name = Path(rel_path).name
    for g in globs:
        if Path(name).match(g):
            return True
    if "/tests/" in "/" + rel_path.replace("\\", "/") + "/":
        return True
    return False


def run_auto_test(state):
    """Execute the detected test command in the workspace. Returns a
    short result string suitable for surfacing as a synthetic tool
    result. Returns None when no runner is detected."""
    runner = detect_test_runner(state.workspace)
    if not runner:
        return None
    try:
        proc = subprocess.run(
            ["/bin/zsh", "-lc", runner["command"]],
            cwd=str(state.workspace),
            capture_output=True, text=True, timeout=300,
            start_new_session=True,
        )
    except (subprocess.TimeoutExpired, OSError) as e:
        return f"auto-test ({runner['name']}) failed to launch: {e}"
    out = proc.stdout + proc.stderr
    if proc.returncode == 0:
        return f"auto-test ({runner['name']}) passed."
    tail = "\n".join(out.splitlines()[-30:])[-4000:]
    return (f"auto-test ({runner['name']}) FAILED (exit {proc.returncode}). "
            f"Last lines:\n{tail}")


# ---------- Live preview server --------------------------------------------

def preview_start(state):
    """If the workspace looks servable, spin up an http.server in a thread
    and stash the handle on state.preview. Returns the URL string or None
    when nothing servable is present."""
    if state.preview:
        return state.preview["url"]
    ws = state.workspace
    has_index = (ws / "index.html").is_file()
    has_html_anywhere = any(ws.glob("*.html"))
    if not (has_index or has_html_anywhere):
        return None
    import http.server, socketserver, threading, socket
    # Find a free port.
    sock = socket.socket()
    sock.bind(("127.0.0.1", 0))
    port = sock.getsockname()[1]
    sock.close()

    handler_factory = lambda *a, **kw: http.server.SimpleHTTPRequestHandler(
        *a, directory=str(ws), **kw)
    server = socketserver.ThreadingTCPServer(("127.0.0.1", port),
                                             handler_factory)
    server.daemon_threads = True
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()
    url = f"http://127.0.0.1:{port}/"
    state.preview = {"server": server, "thread": thread, "url": url}
    return url


def preview_stop(state):
    if not state.preview:
        print(style("  preview not running.", "dim"))
        return
    state.preview["server"].shutdown()
    state.preview["server"].server_close()
    state.preview = None
    print(style("  preview stopped.", "ok"))


# ---------- Conversation branching -----------------------------------------

def branch_save(state, name):
    BRANCH_ROOT.mkdir(parents=True, exist_ok=True)
    path = BRANCH_ROOT / f"{name}.json"
    payload = {
        "saved_at": _now_iso(),
        "name": name,
        "model": state.model,
        "workspace": str(state.workspace),
        "transcript": state.transcript,
        "tasks": state.sink.current,
        "journal": state.journal,
        "approx_tokens": state.approx_tokens,
    }
    path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
    return path


def branch_list():
    if not BRANCH_ROOT.exists():
        return []
    return sorted(BRANCH_ROOT.glob("*.json"),
                  key=lambda p: p.stat().st_mtime, reverse=True)


def branch_checkout(state, name):
    path = BRANCH_ROOT / f"{name}.json"
    if not path.is_file():
        return False
    payload = json.loads(path.read_text(encoding="utf-8"))
    state.transcript = payload.get("transcript", [])
    state.sink.current = payload.get("tasks", [])
    state.journal = payload.get("journal", [])
    state.approx_tokens = payload.get("approx_tokens", 0)
    return True


def branch_merge(state, name):
    path = BRANCH_ROOT / f"{name}.json"
    if not path.is_file():
        return None
    payload = json.loads(path.read_text(encoding="utf-8"))
    transcript = payload.get("transcript", [])
    # Pull the last assistant message from the other branch as a note.
    last_asst = ""
    for entry in reversed(transcript):
        if entry.get("role") == "assistant" and entry.get("content"):
            last_asst = entry["content"]
            break
    note = (f"# Notes merged from branch `{name}`\n\n"
            f"## Last assistant message on that branch\n{last_asst[:4000]}\n\n"
            f"## Task list on that branch\n"
            + json.dumps(payload.get("tasks", []), indent=2)[:4000])
    state.transcript.append({"role": "system", "content": note})
    return note


# ---------- Multi-model routing --------------------------------------------

def pick_model_for_turn(state, user_message=None):
    """Decide which model to use for this turn. The model picks are:
    - planner: when there's a pending task OR the message looks plan-y
      ("plan", "create tasks", "what should we do")
    - explainer: when there are no pending tasks and no fs mutations
      requested ("explain", "why", "summarize")
    - coder: anything else (the default for code-touching work)

    Routes only when the corresponding override is set; otherwise stays
    on state.model."""
    plan_words = ("plan", "create tasks", "what should we", "outline",
                  "design", "architecture")
    explain_words = ("explain", "why", "how does", "summarize", "describe")
    msg = (user_message or "").lower()
    if any(w in msg for w in plan_words) and state.planner_model:
        return state.planner_model
    if any(w in msg for w in explain_words) and state.explainer_model:
        return state.explainer_model
    if state.coder_model:
        return state.coder_model
    return state.model


# ---------- Project knowledge layer ----------------------------------------

def load_project_knowledge(workspace):
    """Return (knowledge_text, data_dict) where text is markdown suitable
    for the system prompt, and dict is the underlying record."""
    path = Path(workspace) / PROJECT_KNOWLEDGE_FILENAME
    if not path.is_file():
        return "", None
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return "", None
    parts = ["# Project Knowledge (.loom/project.json)"]
    if data.get("summary"):
        parts.append("## Last session summary\n" + data["summary"])
    if data.get("build_commands"):
        parts.append("## Build commands that worked\n- "
                     + "\n- ".join(data["build_commands"][-10:]))
    if data.get("test_commands"):
        parts.append("## Test commands that worked\n- "
                     + "\n- ".join(data["test_commands"][-10:]))
    if data.get("fixes"):
        rows = [f"- {f['error']} -> {f['fix']}"
                for f in data["fixes"][-10:]]
        parts.append("## Errors seen + fixes\n" + "\n".join(rows))
    return "\n\n".join(parts), data


def save_project_knowledge(state):
    """Merge what we learned this session into .loom/project.json so the
    next session inherits it. Silent on error (don't block /quit)."""
    if not state.project_knowledge:
        state.project_knowledge = {}
    data = state.project_knowledge
    # Capture successful bash commands we used during the session.
    bash_used = []
    for entry in state.tool_history:
        if entry.get("name") == "run_bash" and not entry.get("error"):
            try:
                args = json.loads(entry.get("args") or "{}")
                cmd = args.get("command", "")
                if cmd and len(cmd) < 200:
                    bash_used.append(cmd)
            except (ValueError, json.JSONDecodeError):
                continue
    if bash_used:
        data.setdefault("build_commands", [])
        for cmd in bash_used:
            if cmd not in data["build_commands"]:
                data["build_commands"].append(cmd)
        data["build_commands"] = data["build_commands"][-40:]
    # Best-effort summary capture from the last assistant message.
    last_asst = next(
        (e for e in reversed(state.transcript) if e.get("role") == "assistant"),
        None,
    )
    if last_asst and last_asst.get("content"):
        data["summary"] = last_asst["content"][:2000]
    data["last_updated"] = _now_iso()
    target = state.workspace / PROJECT_KNOWLEDGE_FILENAME
    try:
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(json.dumps(data, indent=2), encoding="utf-8")
    except OSError:
        pass


# =============================================================================
# 6.0.0 / 7.0.0 — file watcher, cost meter, plugins, self-reflect, drift,
# mermaid, constitution, ship_it
# =============================================================================

def start_file_watcher(state):
    """Background thread that polls the workspace for external edits.

    Two-phase polling so large workspaces stay cheap:
      - Every 2s: stat() only files already in `state.watched_files`. Fast
        regardless of total file count; catches mtime/size changes on the
        hot working set immediately.
      - Every 30s: full rglob to discover newly added files. Slower, but
        infrequent enough to be tolerable on 50k+ file repos.

    Detected changes append a one-line note to `state.external_change_notes`.
    `flush_external_change_notes` drains them into a system message at the
    start of the next turn."""
    if state.watcher_thread is not None:
        return
    state.watcher_stop.clear()

    def _full_snapshot():
        snap = {}
        for path in state.workspace.rglob("*"):
            if any(part in WORKSPACE_TREE_IGNORE or part.startswith(".")
                   for part in path.parts):
                continue
            try:
                if path.is_file():
                    st = path.stat()
                    try:
                        rel = str(path.relative_to(state.workspace))
                    except ValueError:
                        continue
                    snap[rel] = (st.st_mtime, st.st_size)
            except OSError:
                continue
            if len(snap) > 4000:
                break
        return snap

    def _fast_snapshot(known):
        """Stat the known set only. Returns the same shape as the full
        snapshot. Files that vanished are NOT present in the result."""
        snap = {}
        for rel in known:
            path = state.workspace / rel
            try:
                st = path.stat()
            except (OSError, ValueError):
                continue
            snap[rel] = (st.st_mtime, st.st_size)
        return snap

    state.watched_files = _full_snapshot()

    def _record_changes(current, allow_added=True):
        for rel, (mtime, size) in current.items():
            prev = state.watched_files.get(rel)
            if prev is None:
                if allow_added:
                    state.external_change_notes.append(
                        f"ADDED externally: {rel} ({size} bytes)")
            elif prev != (mtime, size):
                state.external_change_notes.append(
                    f"CHANGED externally: {rel} "
                    f"({prev[1]} -> {size} bytes)")
        for rel in list(state.watched_files):
            if rel not in current:
                state.external_change_notes.append(
                    f"DELETED externally: {rel}")
        if len(state.external_change_notes) > 50:
            state.external_change_notes = state.external_change_notes[-50:]

    def _loop():
        last_full = time.time()
        full_interval = 30.0
        while not state.watcher_stop.wait(2.0):
            try:
                if time.time() - last_full >= full_interval:
                    current = _full_snapshot()
                    last_full = time.time()
                    _record_changes(current, allow_added=True)
                    state.watched_files = current
                else:
                    current = _fast_snapshot(state.watched_files.keys())
                    # Detect deletions explicitly in fast mode (a key in
                    # watched_files that no longer stat()'s lands here).
                    seen_deletes = [
                        rel for rel in state.watched_files
                        if rel not in current
                    ]
                    for rel in seen_deletes:
                        state.external_change_notes.append(
                            f"DELETED externally: {rel}")
                    # Detect mtime/size changes.
                    for rel, val in current.items():
                        prev = state.watched_files.get(rel)
                        if prev and prev != val:
                            state.external_change_notes.append(
                                f"CHANGED externally: {rel} "
                                f"({prev[1]} -> {val[1]} bytes)")
                    # Merge into the canonical snapshot.
                    for rel in seen_deletes:
                        state.watched_files.pop(rel, None)
                    state.watched_files.update(current)
                    if len(state.external_change_notes) > 50:
                        state.external_change_notes = (
                            state.external_change_notes[-50:])
            except Exception:
                continue

    state.watcher_thread = threading.Thread(target=_loop, daemon=True)
    state.watcher_thread.start()


def stop_file_watcher(state):
    if state.watcher_thread is None:
        return
    state.watcher_stop.set()
    state.watcher_thread = None


def flush_external_change_notes(state):
    """Pull any pending external-change notes out of the watcher buffer
    and return them as a system message body (or empty string)."""
    if not state.external_change_notes:
        return ""
    notes = list(state.external_change_notes)
    state.external_change_notes.clear()
    return ("ORCHESTRATOR file_watcher: files were modified outside this "
            "session since the last turn. Re-read them before editing.\n  - "
            + "\n  - ".join(notes[:30]))


def cost_meter_record(state, name, elapsed_ms, args, result):
    bucket = state.cost_breakdown.setdefault(name, {
        "calls": 0, "elapsed_ms": 0, "est_tokens": 0,
        "paths_read": {},
    })
    bucket["calls"] += 1
    bucket["elapsed_ms"] += int(elapsed_ms)
    bucket["est_tokens"] += max(1, len(str(result)) // 4)
    if name in ("read_file", "glob", "grep", "list_dir"):
        path = (args or {}).get("path") or (args or {}).get("pattern") or ""
        if path:
            bucket["paths_read"][path] = bucket["paths_read"].get(path, 0) + 1


def render_cost_breakdown(state):
    """Markdown summary of state.cost_breakdown ordered by elapsed."""
    if not state.cost_breakdown:
        return "(no tool calls yet)"
    rows = sorted(state.cost_breakdown.items(),
                  key=lambda kv: -kv[1]["elapsed_ms"])[:8]
    lines = ["| tool | calls | elapsed_ms | ~tokens |",
             "| --- | --- | --- | --- |"]
    for name, b in rows:
        lines.append(f"| {name} | {b['calls']} | {b['elapsed_ms']} | "
                     f"{b['est_tokens']} |")
    # Top paths read.
    all_paths = {}
    for b in state.cost_breakdown.values():
        for p, c in b["paths_read"].items():
            all_paths[p] = all_paths.get(p, 0) + c
    if all_paths:
        top = sorted(all_paths.items(), key=lambda kv: -kv[1])[:5]
        lines.append("\nTop file paths read:")
        for p, c in top:
            lines.append(f"  {c}x {p}")
    return "\n".join(lines)


def load_plugins(state):
    """Auto-import every *.py file under ~/.loom/tools/ and merge its
    `LMSTUDIO_TOOLS` list into BUILTIN_TOOL_SCHEMAS + BUILTIN_TOOL_FUNCS.

    Each entry should be {"schema": <function schema dict>, "func": <fn>}.
    Errors during import are recorded but never fatal."""
    plugin_root = Path.home() / ".loom" / "tools"
    if not plugin_root.is_dir():
        return
    import importlib.util
    for path in sorted(plugin_root.glob("*.py")):
        try:
            spec = importlib.util.spec_from_file_location(
                f"lmstudio_plugin_{path.stem}", path)
            if spec is None or spec.loader is None:
                continue
            module = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(module)
        except Exception as e:
            print(style(f"warning: plugin {path.name} failed to load: {e}",
                        "warning"), file=sys.stderr)
            continue
        tools = getattr(module, "LMSTUDIO_TOOLS", None) or []
        for entry in tools:
            schema = entry.get("schema")
            func = entry.get("func")
            if not schema or not callable(func):
                continue
            name = schema.get("function", {}).get("name")
            if not name:
                continue
            BUILTIN_TOOL_SCHEMAS.append(schema)
            BUILTIN_TOOL_FUNCS[name] = func
            state.plugin_names.append(name)


def detect_drift(state):
    """Compare project_knowledge's recorded build_commands to current state.
    Anything that references a file/script no longer in the workspace is
    flagged as stale. Surfaced in the banner."""
    if not state.project_knowledge:
        return
    warnings = []
    for cmd in (state.project_knowledge.get("build_commands") or [])[-20:]:
        # Look for `./script`, `python file.py`, `node file.js` style refs.
        m = re.search(r"(?:^|\s)([\w./-]+\.(?:py|js|ts|sh|rb))\b", cmd)
        if not m:
            continue
        ref = m.group(1)
        if ref.startswith("./"):
            ref = ref[2:]
        candidate = state.workspace / ref
        if not candidate.is_file():
            warnings.append(f"build cmd references missing file: {ref}  ({cmd[:80]})")
    state.drift_warnings = warnings[:8]


def reflect_on_turn(state):
    """Send the last turn to the model as a small judge prompt; capture
    the score + one-line lesson, append to project_knowledge['lessons']."""
    if not state.self_reflect:
        return
    # Grab the most recent user / assistant pair.
    last_user = next(
        (e for e in reversed(state.transcript) if e.get("role") == "user"),
        None,
    )
    last_asst = next(
        (e for e in reversed(state.transcript) if e.get("role") == "assistant"),
        None,
    )
    if not (last_user and last_asst):
        return
    messages = [
        {"role": "system", "content":
            "You are an evaluator. Score the assistant's turn on a 1-10 "
            "scale: did it address the user's request, use the right "
            "tools, avoid wasted turns? Then on a second line write a "
            "ONE-sentence lesson for future turns. Just the score and the "
            "lesson, nothing else."},
        {"role": "user", "content":
            "USER:\n" + (last_user.get("content") or "")[:1500]
            + "\n\nASSISTANT:\n" + (last_asst.get("content") or "")[:2000]},
    ]
    reply = request_plain_completion(
        state.base_url, state.model, messages, timeout=60)
    if not reply:
        return
    if not state.project_knowledge:
        state.project_knowledge = {}
    lessons = state.project_knowledge.setdefault("lessons", [])
    lessons.append({"ts": _now_iso(), "judgement": reply.strip()[:400]})
    state.project_knowledge["lessons"] = lessons[-40:]


def render_mermaid_blocks(state, text):
    """Find ```mermaid fenced blocks in the model's text and pipe each
    through mmdc (if installed) to render a PNG into diagrams/. Returns
    the list of rendered paths."""
    if "```mermaid" not in text:
        return []
    rendered = []
    fence_re = re.compile(r"```mermaid\n(.*?)```", re.S)
    diagrams_dir = state.workspace / "diagrams"
    for binary in ("/opt/homebrew/bin/mmdc", "/usr/local/bin/mmdc",
                   "/usr/bin/mmdc"):
        if Path(binary).is_file():
            mmdc = binary
            break
    else:
        return []
    diagrams_dir.mkdir(parents=True, exist_ok=True)
    for i, m in enumerate(fence_re.finditer(text)):
        source = m.group(1)
        ts = int(time.time())
        out_path = diagrams_dir / f"mermaid-{ts}-{i}.png"
        with tempfile.NamedTemporaryFile("w", suffix=".mmd", delete=False,
                                          encoding="utf-8") as f:
            f.write(source)
            src_path = Path(f.name)
        try:
            proc = subprocess.run(
                [mmdc, "-i", str(src_path), "-o", str(out_path),
                 "-b", "transparent"],
                capture_output=True, timeout=30,
            )
            if proc.returncode == 0:
                rendered.append(str(out_path.relative_to(state.workspace)))
        except (FileNotFoundError, subprocess.TimeoutExpired):
            continue
        finally:
            src_path.unlink(missing_ok=True)
    return rendered


# tempfile already imported at module top? Check.
# We rely on the top-of-file imports; tempfile is brought in lazily where
# needed elsewhere. Import it here for render_mermaid_blocks.
import tempfile


def load_constitution(workspace):
    """Read .loom/constitution.md from the workspace. Parse into a list of
    rules (one per non-blank, non-comment line). Returns (text, rules)."""
    path = Path(workspace) / ".loom" / "constitution.md"
    if not path.is_file():
        return "", []
    try:
        text = path.read_text(encoding="utf-8").strip()
    except OSError:
        return "", []
    rules = []
    for line in text.splitlines():
        s = line.strip()
        if not s or s.startswith("#"):
            continue
        # Strip leading list markers.
        s = re.sub(r"^[-*]\s+", "", s)
        rules.append(s)
    return text, rules


_CONSTITUTION_MECHANICAL = [
    (re.compile(r"(rm\s+-rf|rm\s+-fr)", re.I), "rm -rf"),
    (re.compile(r"git\s+push\s+--force|git\s+push\s+-f\b"), "git push --force"),
    (re.compile(r"DROP\s+DATABASE", re.I), "DROP DATABASE"),
    (re.compile(r"DROP\s+TABLE", re.I), "DROP TABLE"),
    (re.compile(r"TRUNCATE\s+TABLE", re.I), "TRUNCATE TABLE"),
]


def constitution_violation(state, name, args):
    """Return a human-readable reason string if the proposed tool call
    violates a constitution rule; None when ok."""
    if not state.constitution_rules:
        return None
    payload = json.dumps(args, indent=2) if args else "{}"
    haystack = f"{name} {payload}".lower()
    # Cheap mechanical scan first.
    for pat, label in _CONSTITUTION_MECHANICAL:
        for rule in state.constitution_rules:
            if label.lower() in rule.lower() and pat.search(payload + " " + haystack):
                return (f"rule violated: {rule!r} (matched pattern "
                        f"{label!r})")
    # Heuristic phrase match: rule mentions a tool name -> compare.
    for rule in state.constitution_rules:
        rl = rule.lower()
        if name in rl and ("never" in rl or "do not" in rl or "don't" in rl
                            or "refuse" in rl):
            # Look for an argument mentioned in the rule.
            for word in re.findall(r"`([^`]+)`|\"([^\"]+)\"|'([^']+)'", rule):
                token = next((g for g in word if g), "")
                if token and token.lower() in payload.lower():
                    return f"rule violated: {rule!r}"
    return None


def tool_ship_it(state, args):
    """End-to-end pipeline, refactored to avoid recursive run_turn calls.

    Instead of invoking another `run_turn` from inside a tool handler
    (which nested transcripts and confused the continuation policy), this
    queues a synthetic user message into `state.queued_followups`. The
    outer `drive_user_message` drains the queue when the current human-
    issued turn finishes, so the follow-up arrives as a fresh top-level
    turn with all the usual orchestrator hooks intact.

    The follow-up message instructs the model to scaffold under
    aggressive_batching (which we flip on for one round), then run
    auto-test + auto-commit + gh_create_pr."""
    spec = args["spec"]
    target = args.get("target", "")
    state.queued_followups.append({
        "kind": "ship_it",
        "spec": spec,
        "target": target,
        "enable_batch": True,
        "auto_commit": True,
        "open_pr": True,
    })
    rows = [
        "# ship_it queued",
        f"spec: {spec[:200]}",
        "The orchestrator will scaffold, test, commit, and open a draft "
        "PR in a follow-up turn (no recursion).",
    ]
    if target:
        rows.append(f"deploy target: {target} (manual step; not invoked)")
    return "\n".join(rows)


def drain_queued_followups(state, json_emit=None):
    """Pulled by drive_user_message after the human turn completes. Each
    queued followup turns into a synthetic user message + side effects."""
    while state.queued_followups:
        followup = state.queued_followups.pop(0)
        if followup.get("kind") == "ship_it":
            prev_batch = state.aggressive_batching
            if followup.get("enable_batch"):
                state.aggressive_batching = True
            try:
                run_turn(state,
                         "Plan and scaffold this spec via update_tasks + "
                         "file-create steps, then run any auto-test the "
                         f"orchestrator detects:\n\n{followup['spec']}",
                         json_emit=json_emit)
            finally:
                state.aggressive_batching = prev_batch
            if followup.get("auto_commit"):
                completed = [t for t in state.sink.current
                             if t.get("status") == "completed"]
                maybe_auto_commit(state, completed)
            if (followup.get("open_pr")
                    and (state.workspace / ".git").exists()):
                try:
                    pr = _gh(["pr", "create", "--draft",
                              "--title", followup["spec"][:60],
                              "--body", followup["spec"]
                              + "\n\nGenerated via ship_it."], timeout=60)
                    state.transcript.append({
                        "role": "system",
                        "content": f"ORCHESTRATOR ship_it: PR -> {pr[:240]}",
                    })
                except Exception:
                    pass


BUILTIN_TOOL_FUNCS["ship_it"] = tool_ship_it


# =============================================================================
# 8.0.0 — Hooks (event scripts)
# =============================================================================
#
# Drop a shell script (or any executable) into ~/.loom/hooks/<event> or
# <workspace>/.loom/hooks/<event> and it runs at the named event. Stdin
# gets a JSON payload; stdout becomes a synthetic system note; a non-zero
# exit code blocks the action (where applicable).

HOOK_EVENTS = {
    "user-prompt-submit", "pre-tool-use", "post-tool-use",
    "session-start", "session-end", "on-error",
}


def discover_hooks(workspace):
    """Build {event: [script_path, ...]} from ~/.loom/hooks/ and
    <workspace>/.loom/hooks/. Workspace scripts run BEFORE user-level
    scripts so a project can override a global hook by setting a higher-
    priority effect."""
    found = {}
    for root in ((Path(workspace) / ".loom" / "hooks"),
                 (Path.home() / ".loom" / "hooks")):
        if not root.is_dir():
            continue
        for event in HOOK_EVENTS:
            script = root / event
            if script.is_file() and os.access(script, os.X_OK):
                found.setdefault(event, []).append(str(script))
    return found


def run_hooks(state, event, payload, *, blocking=False):
    """Run every script registered for `event`. Stdin is the JSON payload.
    Returns (blocked, notes) where `blocked` is True iff `blocking` and a
    script exited non-zero, and `notes` is the concatenated stdout text
    (suitable for use as a system note)."""
    scripts = state.hooks.get(event) or []
    notes = []
    for path in scripts:
        try:
            proc = subprocess.run(
                [path], input=json.dumps(payload),
                capture_output=True, text=True, timeout=15,
            )
        except (FileNotFoundError, subprocess.TimeoutExpired) as e:
            notes.append(f"[hook {event}: {path} error: {e}]")
            continue
        if proc.stdout.strip():
            notes.append(proc.stdout.strip())
        if blocking and proc.returncode != 0:
            return True, "\n".join(notes + [
                f"[hook {event}: {path} returned exit {proc.returncode}]"])
    return False, "\n".join(notes)


# =============================================================================
# 8.0.0 — ask_user (interactive multiple-choice picker)
# =============================================================================

def _render_picker(question, options, header=None):
    """Raw-mode arrow-key multiple-choice picker. Returns the selected
    option dict (with an extra "label_index" key) or None on cancel.

    Falls back to a numbered prompt when stdin isn't a TTY."""
    if not sys.stdin.isatty():
        # Headless fallback: print the question + numbered options, read
        # a single line from stdin, return the matching option (or None).
        if header:
            print(style(header, "key"))
        print(question)
        for i, opt in enumerate(options, 1):
            label = opt.get("label", "?")
            desc = opt.get("description", "")
            print(f"  {i}. {label}" + (f"  — {desc}" if desc else ""))
        try:
            line = input("> ").strip()
        except EOFError:
            return None
        if line.isdigit():
            idx = int(line) - 1
            if 0 <= idx < len(options):
                return {**options[idx], "label_index": idx}
        return None

    import termios, tty
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    selected = 0
    try:
        tty.setcbreak(fd)
        while True:
            sys.stdout.write("\x1b[?25l")  # hide cursor
            if header:
                print(style(header, "key"))
            print(style(question, "headline"))
            for i, opt in enumerate(options):
                marker = style(" ➤ ", "tool") if i == selected else "   "
                label = opt.get("label", "?")
                desc = opt.get("description", "")
                row = marker + style(label, "value" if i == selected else "dim")
                if desc:
                    row += style(f"  — {desc}", "dim")
                print(row)
            sys.stdout.write("  (↑/↓ to move, Enter to select, Esc to cancel)\n")
            sys.stdout.flush()
            ch = sys.stdin.read(1)
            if ch == "\x1b":
                nxt = sys.stdin.read(1)
                if nxt == "[":
                    nxt2 = sys.stdin.read(1)
                    if nxt2 == "A":  # up
                        selected = (selected - 1) % len(options)
                    elif nxt2 == "B":  # down
                        selected = (selected + 1) % len(options)
                    sys.stdout.write("\x1b[?25h")
                    # Redraw: clear screen above us. Rough approach: just
                    # reprint after clearing prior lines.
                    sys.stdout.write("\x1b[K\x1b[" + str(len(options) + 3) + "A")
                    sys.stdout.flush()
                    continue
                else:
                    sys.stdout.write("\x1b[?25h\n")
                    return None
            elif ch in ("\r", "\n"):
                sys.stdout.write("\x1b[?25h\n")
                return {**options[selected], "label_index": selected}
            elif ch == "\x03":  # Ctrl-C
                sys.stdout.write("\x1b[?25h\n")
                raise KeyboardInterrupt
            # Other keys ignored; just redraw to the same selected option.
            sys.stdout.write("\x1b[?25h")
            sys.stdout.write("\x1b[K\x1b[" + str(len(options) + 3) + "A")
            sys.stdout.flush()
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
        sys.stdout.write("\x1b[?25h")
        sys.stdout.flush()


def tool_ask_user(state, args):
    """Prompt the human with a multi-choice picker and return their pick.
    The tool result is JSON the model can read directly."""
    question = args["question"]
    options = args.get("options") or []
    if not isinstance(options, list) or not options:
        return "ask_user: `options` must be a non-empty array"
    # Always offer an "Other" escape hatch.
    enriched = list(options)
    if not any(o.get("label") == "Other" for o in enriched):
        enriched.append({"label": "Other",
                          "description": "Provide a custom answer"})
    header = args.get("header") or "lmstudio asks"
    try:
        chosen = _render_picker(question, enriched, header=header)
    except KeyboardInterrupt:
        return json.dumps({"cancelled": True})
    if not chosen:
        return json.dumps({"cancelled": True})
    notes = ""
    if chosen.get("label") == "Other":
        try:
            notes = input("Your answer: ").strip()
        except EOFError:
            notes = ""
    return json.dumps({"selected": chosen.get("label"),
                       "index": chosen.get("label_index"),
                       "notes": notes})


# =============================================================================
# 8.0.0 — schedule_wakeup + loop_complete + --check-wakeups
# =============================================================================

WAKEUP_ROOT = Path.home() / ".loom" / "wakeups"


def tool_schedule_wakeup(state, args):
    """Persist a wakeup record. The CLI does NOT block waiting; an
    external scheduler (cron / launchd / `lmstudio --check-wakeups`)
    fires re-entry at the appointed time. Returns the path of the
    persisted record so the user can inspect it."""
    delay = max(60, min(int(args.get("delay_seconds", 600)), 86400))
    prompt = args["prompt"]
    reason = args.get("reason", "")
    wake_at = time.time() + delay
    WAKEUP_ROOT.mkdir(parents=True, exist_ok=True)
    wid = uuid.uuid4().hex[:10]
    record = {
        "id": wid,
        "wake_at": wake_at,
        "wake_at_iso": _now_iso(),
        "delay_seconds": delay,
        "prompt": prompt,
        "reason": reason,
        "workspace": str(state.workspace),
        "base_url": state.base_url,
        "model": state.model,
    }
    path = WAKEUP_ROOT / f"{wid}.json"
    path.write_text(json.dumps(record, indent=2), encoding="utf-8")
    return (f"scheduled wakeup id={wid} at +{delay}s ({reason or 'no reason'})\n"
            f"path: {path}")


def tool_loop_complete(state, args):
    """Signal that the autonomous loop should stop. Sets a flag the
    --loop top-level reads when deciding whether to re-enter. Effectively
    a 'we're done; don't wake me again' switch the model can pull."""
    summary = args.get("summary", "loop done")
    state.loop_should_exit = True
    return f"loop_complete: {summary}"


def check_and_run_wakeups(base_workspace=None):
    """CLI entry point for `lmstudio --check-wakeups`. Scans WAKEUP_ROOT
    and runs any whose `wake_at` is in the past. Each fires a subprocess
    `lmstudio --resume-wakeup <path>` so they're isolated from each
    other. Returns the count fired."""
    if not WAKEUP_ROOT.is_dir():
        return 0
    fired = 0
    now = time.time()
    for path in sorted(WAKEUP_ROOT.glob("*.json")):
        try:
            rec = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            continue
        if rec.get("wake_at", 0) > now:
            continue
        try:
            subprocess.Popen([
                sys.argv[0], "--resume-wakeup", str(path), "--no-banner",
            ], start_new_session=True)
            fired += 1
        except Exception:
            continue
    return fired


# =============================================================================
# 8.0.0 — Settings file (.loom/settings.json)
# =============================================================================

def load_workspace_settings(workspace):
    """Load and lightly validate <workspace>/.loom/settings.json. Returns
    a dict (possibly empty). `${ENV:NAME}` and `${KEYCHAIN:service}`
    placeholders in any string value are expanded in-place."""
    path = Path(workspace) / ".loom" / "settings.json"
    if not path.is_file():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    return _expand_setting_values(data)


_ENV_RE = re.compile(r"\$\{ENV:([A-Z_][A-Z0-9_]*)\}")
_KEYCHAIN_RE = re.compile(r"\$\{KEYCHAIN:([^\}]+)\}")


def _expand_setting_values(obj):
    if isinstance(obj, dict):
        return {k: _expand_setting_values(v) for k, v in obj.items()}
    if isinstance(obj, list):
        return [_expand_setting_values(v) for v in obj]
    if isinstance(obj, str):
        def env_repl(m):
            return os.environ.get(m.group(1), "")
        def kc_repl(m):
            service = m.group(1)
            try:
                proc = subprocess.run(
                    ["/usr/bin/security", "find-generic-password",
                     "-s", service, "-w"],
                    capture_output=True, text=True, timeout=10,
                )
                return proc.stdout.strip() if proc.returncode == 0 else ""
            except (FileNotFoundError, subprocess.TimeoutExpired):
                return ""
        return _KEYCHAIN_RE.sub(kc_repl, _ENV_RE.sub(env_repl, obj))
    return obj


def apply_settings_to_state(state, settings):
    """Merge a loaded settings dict into state. CLI args have ALREADY been
    applied at this point, so settings should NOT override explicit user
    flags — call this BEFORE the explicit-flag block in main()."""
    if "model" in settings and not os.environ.get("LMSTUDIO_MODEL"):
        state.model = settings["model"]
    if "theme" in settings:
        state.theme_name = settings["theme"]
    if settings.get("allow_bash") is True:
        state.allow_bash = True
        state.permissions.allowed_forever.add("run_bash")
    for key in ("auto_test", "auto_compact", "auto_screenshot",
                "auto_commit", "aggressive_batching", "self_reflect"):
        if key in settings:
            setattr(state, key, bool(settings[key]))
    if "max_continuations" in settings:
        try:
            state.max_continuations = int(settings["max_continuations"])
        except (TypeError, ValueError):
            pass
    router = settings.get("router") or {}
    if isinstance(router, dict):
        state.planner_model = router.get("planner", state.planner_model)
        state.coder_model = router.get("coder", state.coder_model)
        state.explainer_model = router.get("explainer",
                                            state.explainer_model)
    disabled = settings.get("tools_disabled") or []
    if isinstance(disabled, list):
        for name in disabled:
            BUILTIN_TOOL_FUNCS.pop(name, None)
            # Schema removal: leave schemas listed (the model sees them)
            # so the dispatcher can fail-fast with "tool disabled" rather
            # than the model hallucinating a different name.
    for k, v in (settings.get("env") or {}).items():
        if isinstance(v, str):
            os.environ[k] = v


# =============================================================================
# 8.0.0 — Background bash trio
# =============================================================================

BG_SHELL_ROOT = Path.home() / ".loom" / "shells"


def tool_background_bash(state, args):
    """Spawn a detached shell. Output streams to ~/.loom/shells/<id>.log.
    Returns a shell_id the model can later pass to monitor / kill_shell /
    bash_output."""
    command = args["command"]
    label = args.get("label", "")
    BG_SHELL_ROOT.mkdir(parents=True, exist_ok=True)
    shell_id = uuid.uuid4().hex[:8]
    log_path = BG_SHELL_ROOT / f"{shell_id}.log"
    log_fd = open(log_path, "wb")
    proc = subprocess.Popen(
        ["/bin/zsh", "-lc", command],
        cwd=str(state.workspace),
        stdout=log_fd, stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    state.bg_shells[shell_id] = {
        "proc": proc,
        "log": log_path,
        "log_fd": log_fd,
        "command": command,
        "label": label,
        "started_at": time.time(),
    }
    return (f"background shell started\nid: {shell_id}\n"
            f"label: {label or '(none)'}\nlog: {log_path}\n"
            f"pid: {proc.pid}")


def tool_monitor(state, args):
    """Read or follow a background shell's log."""
    shell_id = args["shell_id"]
    entry = state.bg_shells.get(shell_id)
    if not entry:
        return f"monitor: no such shell_id {shell_id!r}"
    log = entry["log"]
    follow = bool(args.get("follow", False))
    until = args.get("until")
    max_lines = max(1, min(int(args.get("lines", 200)), 2000))
    timeout = max(1, min(int(args.get("timeout", 30)), 300))
    deadline = time.time() + timeout
    try:
        lines = log.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        lines = []
    if not follow:
        recent = lines[-max_lines:]
        return f"shell {shell_id} (last {len(recent)} lines):\n" + \
               "\n".join(recent)
    # Follow mode: re-read until new lines arrive or until/timeout.
    start_count = len(lines)
    while time.time() < deadline:
        try:
            current = log.read_text(encoding="utf-8", errors="replace").splitlines()
        except OSError:
            current = []
        new = current[start_count:]
        if new:
            joined = "\n".join(new[-max_lines:])
            if until and re.search(until, joined):
                return f"shell {shell_id} matched {until!r}:\n{joined}"
            return f"shell {shell_id} (+{len(new)} new lines):\n{joined}"
        # Has the process exited?
        if entry["proc"].poll() is not None:
            tail = "\n".join(current[-max_lines:])
            return (f"shell {shell_id} exited rc={entry['proc'].returncode}\n"
                    f"last {min(len(current), max_lines)} lines:\n{tail}")
        time.sleep(0.5)
    return f"monitor: no new output in {timeout}s for shell {shell_id}"


def tool_bash_output(state, args):
    """Incremental read of a shell's log. `since_line` is a 0-indexed
    line number; returns everything from there onward, capped."""
    shell_id = args["shell_id"]
    entry = state.bg_shells.get(shell_id)
    if not entry:
        return f"bash_output: no such shell_id {shell_id!r}"
    since = max(0, int(args.get("since_line", 0)))
    try:
        lines = entry["log"].read_text(encoding="utf-8",
                                       errors="replace").splitlines()
    except OSError:
        return "bash_output: log unavailable"
    cap = max(1, min(int(args.get("max_lines", 500)), 5000))
    return f"shell {shell_id} lines [{since}:{since+cap}]\n" + \
           "\n".join(lines[since:since + cap])


def tool_kill_shell(state, args):
    """Terminate a background shell. SIGTERM first, then SIGKILL after a
    short grace period."""
    shell_id = args["shell_id"]
    entry = state.bg_shells.get(shell_id)
    if not entry:
        return f"kill_shell: no such shell_id {shell_id!r}"
    proc = entry["proc"]
    if proc.poll() is not None:
        return f"shell {shell_id} already exited rc={proc.returncode}"
    proc.terminate()
    try:
        proc.wait(timeout=5)
    except subprocess.TimeoutExpired:
        proc.kill()
        try:
            proc.wait(timeout=3)
        except subprocess.TimeoutExpired:
            return f"kill_shell: SIGKILL didn't take (shell {shell_id})"
    try:
        entry["log_fd"].close()
    except OSError:
        pass
    return f"shell {shell_id} terminated"


# =============================================================================
# 8.0.0 — Notebook tools (Jupyter .ipynb)
# =============================================================================

def _load_notebook(workspace, rel_path):
    path = resolve_in_workspace(workspace, rel_path)
    if not path.is_file():
        raise FileNotFoundError(f"notebook not found: {rel_path}")
    return path, json.loads(path.read_text(encoding="utf-8"))


def tool_notebook_read(state, args):
    path, nb = _load_notebook(state.workspace, args["path"])
    cells = nb.get("cells") or []
    if "cell_index" in args:
        idx = int(args["cell_index"])
        if not 0 <= idx < len(cells):
            return f"notebook_read: cell {idx} out of range (have {len(cells)})"
        cell = cells[idx]
        src = "".join(cell.get("source", [])) if isinstance(cell.get("source"), list) else (cell.get("source") or "")
        return f"# cell {idx} ({cell.get('cell_type', '?')})\n{src}"
    rows = [f"# notebook: {args['path']}  ({len(cells)} cells)"]
    for i, cell in enumerate(cells):
        src = "".join(cell.get("source", [])) if isinstance(cell.get("source"), list) else (cell.get("source") or "")
        src = src.strip()
        preview = src[:120] + ("…" if len(src) > 120 else "")
        rows.append(f"  {i}. [{cell.get('cell_type', '?')}] {preview}")
    return "\n".join(rows)


def tool_notebook_edit(state, args):
    path, nb = _load_notebook(state.workspace, args["path"])
    cells = nb.get("cells") or []
    idx = int(args["cell_index"])
    if not 0 <= idx < len(cells):
        return f"notebook_edit: cell {idx} out of range"
    new_src = args["new_source"]
    cells[idx]["source"] = new_src.splitlines(keepends=True)
    nb["cells"] = cells
    original = path.read_text(encoding="utf-8")
    path.write_text(json.dumps(nb, indent=1), encoding="utf-8")
    record_journal(state, "notebook_edit", args["path"], original,
                   path.read_text(encoding="utf-8"))
    msg = f"replaced cell {idx} in {args['path']}"
    if args.get("run"):
        for binary in ("/opt/homebrew/bin/jupyter", "/usr/local/bin/jupyter"):
            if Path(binary).is_file():
                try:
                    proc = subprocess.run(
                        [binary, "nbconvert", "--to", "notebook",
                         "--execute", "--inplace", str(path)],
                        capture_output=True, text=True, timeout=300,
                    )
                    tail = (proc.stdout + proc.stderr)[-2000:]
                    msg += f"\n\nexecute: rc={proc.returncode}\n{tail}"
                except subprocess.TimeoutExpired:
                    msg += "\n\nexecute: timed out"
                break
        else:
            msg += "\n\nexecute: jupyter CLI not found"
    return msg


def tool_notebook_append(state, args):
    path, nb = _load_notebook(state.workspace, args["path"])
    kind = args.get("kind", "code")
    new_cell = {"cell_type": kind, "metadata": {},
                "source": args["source"].splitlines(keepends=True)}
    if kind == "code":
        new_cell["outputs"] = []
        new_cell["execution_count"] = None
    nb.setdefault("cells", []).append(new_cell)
    original = path.read_text(encoding="utf-8")
    path.write_text(json.dumps(nb, indent=1), encoding="utf-8")
    record_journal(state, "notebook_append", args["path"], original,
                   path.read_text(encoding="utf-8"))
    return f"appended {kind} cell to {args['path']} (total {len(nb['cells'])} cells)"


# =============================================================================
# 8.0.0 — Worktree isolation for spawn_agent
# =============================================================================

WORKTREE_ROOT = Path.home() / ".loom" / "worktrees"


def make_worktree(parent_workspace, branch_hint="lmstudio-subagent"):
    """Create a temporary git worktree from the parent workspace's HEAD.
    Returns (worktree_path, branch_name) or raises RuntimeError on
    failure (e.g. parent isn't a git repo)."""
    parent = Path(parent_workspace).resolve()
    if not (parent / ".git").exists():
        raise RuntimeError("parent workspace is not a git repo")
    WORKTREE_ROOT.mkdir(parents=True, exist_ok=True)
    wid = uuid.uuid4().hex[:8]
    wt_path = WORKTREE_ROOT / wid
    branch = f"{branch_hint}-{wid}"
    proc = subprocess.run(
        ["/usr/bin/env", "git", "worktree", "add", "-b", branch,
         str(wt_path), "HEAD"],
        cwd=str(parent), capture_output=True, text=True, timeout=30,
    )
    if proc.returncode != 0:
        raise RuntimeError(f"git worktree add failed: {proc.stderr.strip()}")
    return wt_path, branch


def tear_down_worktree(wt_path, parent_workspace, keep=False):
    """Remove a worktree (and its branch when `keep` is False). Silent on
    error — callers may want to keep the wt around for inspection."""
    try:
        subprocess.run(
            ["/usr/bin/env", "git", "worktree", "remove", "--force",
             str(wt_path)],
            cwd=str(parent_workspace), capture_output=True, timeout=15,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    if keep:
        return
    # Branch cleanup is best-effort.
    try:
        proc = subprocess.run(
            ["/usr/bin/env", "git", "branch", "--list",
             f"lmstudio-subagent-{wt_path.name}"],
            cwd=str(parent_workspace), capture_output=True, text=True,
            timeout=10,
        )
        for line in proc.stdout.splitlines():
            name = line.strip().lstrip("* ")
            if name:
                subprocess.run(
                    ["/usr/bin/env", "git", "branch", "-D", name],
                    cwd=str(parent_workspace), capture_output=True,
                    timeout=10,
                )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass


# =============================================================================
# 8.0.0 — Slash command files (.md becomes /command)
# =============================================================================

def discover_slash_command_files(workspace):
    """Return a dict {command_name: {"path", "description", "model",
    "body"}} pulled from ~/.loom/commands/*.md and
    <workspace>/.loom/commands/*.md (workspace overrides user)."""
    found = {}
    for root in ((Path.home() / ".loom" / "commands"),
                 (Path(workspace) / ".loom" / "commands")):
        if not root.is_dir():
            continue
        for path in root.glob("*.md"):
            try:
                text = path.read_text(encoding="utf-8")
            except OSError:
                continue
            meta = {"description": "", "model": "", "body": text}
            # Strip frontmatter.
            if text.startswith("---"):
                end = text.find("\n---", 3)
                if end > 0:
                    fm_block = text[3:end].strip()
                    body = text[end + 4:].lstrip()
                    for line in fm_block.splitlines():
                        if ":" in line:
                            k, _, v = line.partition(":")
                            meta[k.strip()] = v.strip()
                    meta["body"] = body
            found[path.stem] = meta
    return found


# =============================================================================
# 8.0.0 — Skills (~/.loom/skills/<name>/)
# =============================================================================

SKILL_ROOT = Path.home() / ".loom" / "skills"


def discover_skills():
    """Return {name: skill_dir Path} for every directory under
    SKILL_ROOT that has a skill.md."""
    if not SKILL_ROOT.is_dir():
        return {}
    out = {}
    for sub in SKILL_ROOT.iterdir():
        if not sub.is_dir():
            continue
        if (sub / "skill.md").is_file():
            out[sub.name] = sub
    return out


def activate_skill(state, name):
    """Load the named skill: prepend its markdown to system_message and
    import its tools.py (if any). Idempotent."""
    skills = discover_skills()
    if name not in skills:
        return f"skill not found: {name}"
    if any(s["name"] == name for s in state.active_skills):
        return f"skill {name} already active"
    sk_dir = skills[name]
    skill_md = (sk_dir / "skill.md").read_text(encoding="utf-8",
                                                errors="replace")
    tools_added = []
    tools_py = sk_dir / "tools.py"
    if tools_py.is_file():
        import importlib.util
        try:
            spec = importlib.util.spec_from_file_location(
                f"lmstudio_skill_{name}", tools_py)
            module = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(module)
            for entry in getattr(module, "LMSTUDIO_TOOLS", []) or []:
                schema = entry.get("schema")
                func = entry.get("func")
                if not schema or not callable(func):
                    continue
                tn = schema.get("function", {}).get("name")
                if not tn:
                    continue
                BUILTIN_TOOL_SCHEMAS.append(schema)
                BUILTIN_TOOL_FUNCS[tn] = func
                tools_added.append(tn)
        except Exception as e:
            print(style(f"warning: skill {name} tools failed to load: {e}",
                        "warning"), file=sys.stderr)
    state.active_skills.append({
        "name": name,
        "system_text": skill_md,
        "tools_added": tools_added,
    })
    state.reset_transcript()
    return (f"activated skill `{name}`"
            + (f" (+{len(tools_added)} tools)" if tools_added else ""))


def tool_activate_skill(state, args):
    return activate_skill(state, args["name"])


# =============================================================================
# 8.0.0 — Auto-memory (cross-workspace user-level)
# =============================================================================

USER_MEMORY_ROOT = Path.home() / ".loom" / "memory"


def load_user_memory():
    """Read ~/.loom/memory/MEMORY.md plus any referenced files, return a
    single markdown blob suitable for the system prompt. Empty when no
    user memory exists."""
    index = USER_MEMORY_ROOT / "MEMORY.md"
    if not index.is_file():
        return ""
    try:
        head = index.read_text(encoding="utf-8", errors="replace")[:8000]
    except OSError:
        return ""
    return f"# User Memory (~/.loom/memory/MEMORY.md)\n\n{head}"


def tool_save_memory(state, args):
    """Write a per-user memory record. `name` is a kebab-case slug used
    as the filename; `body` is the memory content; `kind` (optional) is
    a tag the index can group on."""
    name = args["name"].strip().lower()
    name = re.sub(r"[^a-z0-9_-]+", "-", name).strip("-") or "memory"
    body = args["body"]
    kind = args.get("kind", "user")
    USER_MEMORY_ROOT.mkdir(parents=True, exist_ok=True)
    target = USER_MEMORY_ROOT / f"{name}.md"
    header = (f"---\nname: {name}\nkind: {kind}\nupdated: {_now_iso()}\n---\n\n")
    target.write_text(header + body.strip() + "\n", encoding="utf-8")
    # Update the index.
    index = USER_MEMORY_ROOT / "MEMORY.md"
    line = f"- [{name}]({name}.md) — {body.strip().splitlines()[0][:120] if body.strip() else kind}"
    existing = ""
    if index.is_file():
        existing = index.read_text(encoding="utf-8")
        if name in existing:
            # Remove the old line.
            existing = "\n".join(
                l for l in existing.splitlines() if not l.startswith(f"- [{name}](")
            )
    if not existing.strip():
        existing = "# User Memory\n\nLines below point to files under ~/.loom/memory/.\n"
    if not existing.endswith("\n"):
        existing += "\n"
    index.write_text(existing + line + "\n", encoding="utf-8")
    return f"saved memory `{name}` -> {target}"


